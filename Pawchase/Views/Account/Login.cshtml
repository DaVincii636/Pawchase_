@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var returnUrl = ViewBag.ReturnUrl as string;
}
@section styles {
    <link href="@Url.Content("~/Content/css/account.css")" rel="stylesheet" />
}

<section class="auth-section">
    <div class="auth-card">
        <div class="auth-logo">
            <img src="@Url.Content("~/Content/images/PawV2.png")" alt="PawChase" class="auth-logo-img" />
            <h2>PawChase</h2>
            <p>Sign in to your account</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="auth-error"><i class="fa-solid fa-circle-exclamation"></i> @ViewBag.Error</div>
        }

        <a href="@Url.Action("GoogleLogin", "Account", new { returnUrl = returnUrl })" class="google-btn">
            <i class="fa-brands fa-google"></i> Continue with Google
        </a>

        <div class="auth-divider"><span>or sign in with email</span></div>

        <form method="post" action="@Url.Action("Login","Account",new{returnUrl})">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label><i class="fa-regular fa-envelope"></i> Email Address</label>
                <input type="email" name="email" placeholder="Enter your email" required />
            </div>
            <div class="form-group">
                <label><i class="fa-solid fa-lock"></i> Password</label>
                <div class="password-wrap">
                    <input type="password" id="pw" name="password" placeholder="Enter your password" required />
                    <button type="button" class="toggle-pw" onclick="togglePw('pw','pw-icon')">
                        <i class="fa-regular fa-eye" id="pw-icon"></i>
                    </button>
                </div>
            </div>
            <button type="submit" class="btn-primary auth-btn">
                <i class="fa-solid fa-right-to-bracket"></i> Sign In
            </button>
        </form>

        <div class="auth-hint">
            <strong>Test:</strong> alex@email.com / user123
        </div>

        <div class="auth-footer">
            Don't have an account?
            <a href="@Url.Action("Register","Account",new{returnUrl})">Create one here</a>
        </div>
    </div>
</section>

@section scripts {
    <script src="@Url.Content("~/Scripts/account.js")"></script>
}
