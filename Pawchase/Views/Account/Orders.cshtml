@using Pawchase.Models
@model List<Pawchase.Models.Order>
@{
    ViewBag.Title = "My Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var tab = ViewBag.Tab as string ?? "Profile";
    var profileUser = ViewBag.ProfileUser as User;
}
@section styles {
    <link href="@Url.Content("~/Content/css/account.css")" rel="stylesheet" />
}

<div class="page-hero"><h1>My Account</h1><p>View and manage your profile</p></div>

<section class="account-section">
    <div style="max-width:760px;margin:0 auto;width:100%;">

        @if (TempData["ProfileSuccess"] != null)
        {
            <div style="background:rgba(46,204,113,0.1);border:1px solid rgba(46,204,113,0.3);color:#1e8449;border-radius:var(--radius-sm);padding:12px 16px;font-size:13px;margin-bottom:1.2rem;display:flex;align-items:center;gap:8px;">
                <i class="fa-solid fa-circle-check"></i> @TempData["ProfileSuccess"]
            </div>
        }
        @if (TempData["ProfileError"] != null)
        {
            <div style="background:rgba(224,85,85,0.08);border:1px solid rgba(224,85,85,0.25);color:#c0392b;border-radius:var(--radius-sm);padding:12px 16px;font-size:13px;margin-bottom:1.2rem;display:flex;align-items:center;gap:8px;">
                <i class="fa-solid fa-triangle-exclamation"></i> @TempData["ProfileError"]
            </div>
        }

        <div class="order-card" style="padding:2rem;">
            <!-- Profile Header -->
            <div style="display:flex;align-items:center;gap:1rem;padding-bottom:1.2rem;margin-bottom:1.5rem;border-bottom:1px solid rgba(210,196,180,0.4);">
                <div style="width:56px;height:56px;border-radius:50%;background:linear-gradient(145deg,var(--blue),var(--blue-dark));display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 4px 14px rgba(129,166,198,0.35);">
                    <i class="fa-solid fa-user" style="font-size:22px;color:#fff;"></i>
                </div>
                <div>
                    <div style="font-size:16px;font-weight:800;color:var(--text);">@(profileUser?.FullName ?? Session["UserName"])</div>
                    <div style="font-size:12px;color:var(--text-light);margin-top:2px;">@(profileUser?.Email ?? Session["UserEmail"])</div>
                </div>
            </div>

            @using (Html.BeginForm("SaveProfile", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <!-- Account Information -->
                <div style="margin-bottom:1.5rem;">
                    <h3 style="font-size:13px;font-weight:700;color:var(--text);margin-bottom:1rem;display:flex;align-items:center;gap:6px;">
                        <i class="fa-solid fa-circle-info" style="color:var(--blue);font-size:12px;"></i> Account Information
                    </h3>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
                        <div>
                            <label style="display:block;font-size:11px;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px;">Full Name</label>
                            <input type="text" name="fullName" value="@(profileUser?.FullName ?? "")"
                                   required maxlength="100"
                                   style="width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:'Poppins',sans-serif;outline:none;transition:border-color .2s;box-sizing:border-box;"
                                   onfocus="this.style.borderColor='var(--blue)'" onblur="this.style.borderColor='var(--border)'" />
                        </div>
                        <div>
                            <label style="display:block;font-size:11px;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px;">Email Address</label>
                            <input type="email" name="email" value="@(profileUser?.Email ?? "")"
                                   required maxlength="200"
                                   style="width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:'Poppins',sans-serif;outline:none;transition:border-color .2s;box-sizing:border-box;"
                                   onfocus="this.style.borderColor='var(--blue)'" onblur="this.style.borderColor='var(--border)'" />
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                        <div>
                            <label style="display:block;font-size:11px;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px;">Phone Number</label>
                            <input type="tel" name="phone" value="@(profileUser?.Phone ?? "")"
                                   maxlength="20" placeholder="e.g. 09171234567"
                                   style="width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:'Poppins',sans-serif;outline:none;transition:border-color .2s;box-sizing:border-box;"
                                   onfocus="this.style.borderColor='var(--blue)'" onblur="this.style.borderColor='var(--border)'" />
                        </div>
                        <div>
                            <label style="display:block;font-size:11px;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px;">
                                GCash Number
                                <span style="background:rgba(0,119,255,.1);color:#0055bb;font-size:9px;font-weight:700;padding:2px 7px;border-radius:50px;margin-left:4px;vertical-align:middle;">for refunds</span>
                            </label>
                            <input type="tel" name="gcashNumber" value="@(profileUser?.GCashNumber ?? "")"
                                   maxlength="20" placeholder="GCash number"
                                   style="width:100%;padding:10px 14px;border:1.5px solid rgba(0,119,255,.25);border-radius:var(--radius-sm);font-size:13px;font-family:'Poppins',sans-serif;outline:none;transition:border-color .2s;box-sizing:border-box;background:rgba(0,119,255,.02);"
                                   onfocus="this.style.borderColor='#0077FF'" onblur="this.style.borderColor='rgba(0,119,255,.25)'" />
                            <small style="font-size:10px;color:var(--text-light);margin-top:4px;display:block;"><i class="fa-solid fa-circle-info"></i> Used to process approved refunds via GCash.</small>
                        </div>
                    </div>
                </div>

                <!-- Change Password -->
                <div style="margin-bottom:1.5rem;">
                    <h3 style="font-size:13px;font-weight:700;color:var(--text);margin-bottom:.4rem;display:flex;align-items:center;gap:6px;">
                        <i class="fa-solid fa-lock" style="color:var(--blue);font-size:12px;"></i> Change Password
                    </h3>
                    <p style="font-size:11px;color:var(--text-light);margin-bottom:1rem;">Leave blank to keep your current password.</p>
                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;">
                        <div>
                            <label style="display:block;font-size:11px;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px;">Current Password</label>
                            <div class="password-wrap">
                                <input type="password" name="currentPassword" id="cur-pw" placeholder="Current password"
                                       style="width:100%;padding:10px 40px 10px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:'Poppins',sans-serif;outline:none;transition:border-color .2s;box-sizing:border-box;"
                                       onfocus="this.style.borderColor='var(--blue)'" onblur="this.style.borderColor='var(--border)'" />
                                <button type="button" class="toggle-pw" onclick="togglePw('cur-pw','cur-pw-ic')"><i id="cur-pw-ic" class="fa-regular fa-eye"></i></button>
                            </div>
                        </div>
                        <div>
                            <label style="display:block;font-size:11px;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px;">New Password</label>
                            <div class="password-wrap">
                                <input type="password" name="newPassword" id="new-pw" placeholder="New password"
                                       style="width:100%;padding:10px 40px 10px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:'Poppins',sans-serif;outline:none;transition:border-color .2s;box-sizing:border-box;"
                                       onfocus="this.style.borderColor='var(--blue)'" onblur="this.style.borderColor='var(--border)'" />
                                <button type="button" class="toggle-pw" onclick="togglePw('new-pw','new-pw-ic')"><i id="new-pw-ic" class="fa-regular fa-eye"></i></button>
                            </div>
                        </div>
                        <div>
                            <label style="display:block;font-size:11px;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px;">Confirm New Password</label>
                            <div class="password-wrap">
                                <input type="password" name="confirmPassword" id="conf-pw" placeholder="Confirm new password"
                                       style="width:100%;padding:10px 40px 10px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:'Poppins',sans-serif;outline:none;transition:border-color .2s;box-sizing:border-box;"
                                       onfocus="this.style.borderColor='var(--blue)'" onblur="this.style.borderColor='var(--border)'" />
                                <button type="button" class="toggle-pw" onclick="togglePw('conf-pw','conf-pw-ic')"><i id="conf-pw-ic" class="fa-regular fa-eye"></i></button>
                            </div>
                            <span id="pw-match-profile" style="display:none;font-size:11px;color:#e05555;margin-top:4px;">Passwords do not match.</span>
                        </div>
                    </div>
                </div>

                <div style="display:flex;justify-content:flex-end;padding-top:1rem;border-top:1px solid rgba(210,196,180,0.4);">
                    <button type="submit" class="btn-primary" id="save-profile-btn" style="padding:10px 28px;font-size:13px;">
                        <i class="fa-solid fa-floppy-disk"></i> Save Changes
                    </button>
                </div>
            }
        </div>
    </div>
</section>

@section scripts {
    <script src="@Url.Content("~/Scripts/account.js")"></script>
    <script>
        (function () {
            var newPw  = document.getElementById('new-pw');
            var confPw = document.getElementById('conf-pw');
            var msg    = document.getElementById('pw-match-profile');
            var btn    = document.getElementById('save-profile-btn');
            if (!newPw || !confPw) return;
            function check() {
                if (!confPw.value && !newPw.value) { msg.style.display = 'none'; btn.disabled = false; return; }
                var ok = newPw.value === confPw.value;
                msg.style.display = ok ? 'none' : 'block';
                confPw.style.borderColor = ok ? '' : '#e05555';
                btn.disabled = !ok;
            }
            newPw.addEventListener('input', check);
            confPw.addEventListener('input', check);
        })();
    </script>
}
