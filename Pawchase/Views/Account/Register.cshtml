@{
    ViewBag.Title = "Create Account";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var returnUrl = ViewBag.ReturnUrl as string;
}
@section styles {
    <link href="@Url.Content("~/Content/css/account.css")" rel="stylesheet"/>
}

<section class="auth-section">
    <div class="auth-card">
        <div class="auth-logo">
            <i class="fa-solid fa-paw"></i>
            <h2>PawChase</h2>
            <p>Create your account</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="auth-error"><i class="fa-solid fa-circle-exclamation"></i> @ViewBag.Error</div>
        }

        <a href="@Url.Action("GoogleLogin","Account",new{returnUrl})" class="google-btn">
            <i class="fa-brands fa-google"></i> Sign up with Google
        </a>

        <div class="auth-divider"><span>or sign up with email</span></div>

        <form method="post" action="@Url.Action("Register","Account")">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label><i class="fa-regular fa-user"></i> Full Name</label>
                <input type="text" name="fullName" placeholder="Juan dela Cruz" required/>
            </div>
            <div class="form-group">
                <label><i class="fa-regular fa-envelope"></i> Email Address</label>
                <input type="email" name="email" placeholder="juan@email.com" required/>
            </div>
            <div class="form-group">
                <label><i class="fa-solid fa-lock"></i> Password</label>
                <div class="password-wrap">
                    <input type="password" id="pw" name="password" placeholder="At least 6 characters" required minlength="6"/>
                    <button type="button" class="toggle-pw" onclick="togglePw('pw','pw-icon')">
                        <i class="fa-regular fa-eye" id="pw-icon"></i>
                    </button>
                </div>
            </div>
            <div class="form-group">
                <label><i class="fa-solid fa-lock"></i> Confirm Password</label>
                <div class="password-wrap">
                    <input type="password" id="cpw" name="confirmPassword" placeholder="Re-enter your password" required/>
                    <button type="button" class="toggle-pw" onclick="togglePw('cpw','cpw-icon')">
                        <i class="fa-regular fa-eye" id="cpw-icon"></i>
                    </button>
                </div>
                <small id="pw-match" style="display:none;color:#e05555;">
                    <i class="fa-solid fa-triangle-exclamation"></i> Passwords do not match.
                </small>
            </div>
            <button type="submit" class="btn-primary auth-btn" id="reg-btn">
                <i class="fa-solid fa-user-plus"></i> Create Account
            </button>
        </form>

        <div class="auth-footer">
            Already have an account?
            <a href="@Url.Action("Login","Account",new{returnUrl})">Sign in here</a>
        </div>
    </div>
</section>

@section scripts {
    <script src="@Url.Content("~/Scripts/account.js")"></script>
}
