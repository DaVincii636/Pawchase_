@{
    ViewBag.Title = "Something went wrong";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section styles {
<style>
.error-page { text-align:center; padding:6rem 2rem; }
.error-code { font-size:5rem; font-weight:800; color:var(--blue); margin-bottom:.5rem; }
.error-title { font-size:1.5rem; font-weight:700; color:var(--text); margin-bottom:1rem; }
.error-msg { color:var(--text-mid); font-size:14px; margin-bottom:2rem; }
.error-actions { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; }
</style>
}
<div class="error-page">
    <div class="error-code"><i class="fa-solid fa-circle-exclamation" style="color:var(--blue)"></i></div>
    <h1 class="error-title">Something went wrong</h1>
    <p class="error-msg">An unexpected error occurred. Please try again or go back to the homepage.</p>
    <div class="error-actions">
        <a href="@Url.Action("Index","Home")" class="btn-primary">Go to Homepage</a>
        <a href="javascript:history.back()" class="btn-outline">Go Back</a>
    </div>
</div>
