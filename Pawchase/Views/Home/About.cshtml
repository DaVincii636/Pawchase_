@{
    ViewBag.Title = "About Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section styles {
    <link href="@Url.Content("~/Content/css/home.css")" rel="stylesheet" />
}

<div class="pc-hero">
    <div class="pc-hero-bg" style="background-image: url('@Url.Content("~/Content/images/hero-dog.png")');"></div>
    <div class="pc-hero-overlay"></div>
    <div class="pc-hero-blob pc-hero-blob--1"></div>
    <div class="pc-hero-blob pc-hero-blob--2"></div>
    <div class="pc-hero-content">
        <h1 class="pc-hero-title">About <span>Pawchase</span></h1>
        <p class="pc-hero-subtitle">A store built by dog lovers, for dog lovers &mdash; every product chosen with care.</p>
        <div class="pc-hero-divider">
            <div class="pc-hero-divider-line"></div>
            <i class="fa-solid fa-bone"></i>
            <div class="pc-hero-divider-line"></div>
        </div>
    </div>
</div>

<section class="pc-about-section">
    <div class="pc-about-inner">

        <div class="pc-about-left">
            <div class="pc-about-block">
                <div class="pc-about-label">
                    <i class="fa-solid fa-book-open"></i>
                    Our Story
                </div>
                <h2 class="pc-about-h2">We Built What Dog<br>Owners Were Missing</h2>
                <p class="pc-about-p">
                    Pawchase was born out of a simple love for dogs. We noticed how hard it was to find quality, trusted
                    products for dogs in one place &mdash; so we built it ourselves.
                </p>
                <p class="pc-about-p">
                    We carry only products we&rsquo;d use on our own dogs. Every item is carefully selected for quality,
                    safety, and value &mdash; whether you have a tiny Chihuahua or a massive German Shepherd.
                </p>
            </div>

            <div class="pc-about-divider">
                <div class="pc-about-divider-line"></div>
                <i class="fa-solid fa-paw"></i>
                <div class="pc-about-divider-line"></div>
            </div>

            <div class="pc-about-block">
                <div class="pc-about-label">
                    <i class="fa-solid fa-bullseye"></i>
                    Our Mission
                </div>
                <h2 class="pc-about-h2">Caring for Every Dog,<br>Every Day</h2>
                <div class="pc-mission-box">
                    <p class="pc-mission-quote">
                        &ldquo;To make dog care simpler, more affordable, and more enjoyable for every Filipino dog owner
                        &mdash; one happy tail at a time.&rdquo;
                    </p>
                </div>
            </div>
        </div>

        <div class="pc-about-right">
            <div class="pc-feature-card">
                <div class="pc-feature-icon-wrap pc-feature-icon-wrap--blue">
                    <i class="fa-solid fa-dog"></i>
                </div>
                <div class="pc-feature-text">
                    <div class="pc-feature-title">Dogs Only</div>
                    <div class="pc-feature-desc">
                        Specialized exclusively for man&rsquo;s best friend &mdash; every product
                        on our store is dog-specific and carefully chosen.
                    </div>
                </div>
            </div>

            <div class="pc-feature-card">
                <div class="pc-feature-icon-wrap pc-feature-icon-wrap--teal">
                    <i class="fa-solid fa-shield-halved"></i>
                </div>
                <div class="pc-feature-text">
                    <div class="pc-feature-title">Quality Assured</div>
                    <div class="pc-feature-desc">
                        Every product is vet-approved or trusted by breeders before we list it.
                        No compromises on what goes into your dog&rsquo;s life.
                    </div>
                </div>
            </div>

            <div class="pc-feature-card">
                <div class="pc-feature-icon-wrap pc-feature-icon-wrap--orange">
                    <i class="fa-solid fa-truck-fast"></i>
                </div>
                <div class="pc-feature-text">
                    <div class="pc-feature-title">Fast Delivery</div>
                    <div class="pc-feature-desc">
                        Get your orders delivered across the Philippines &mdash; fast, reliable,
                        and right to your doorstep when your dog needs it most.
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>