@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var reviews = ViewBag.Reviews as List<Pawchase.Models.Review>;
}

@section styles {
    <link href="@Url.Content("~/Content/css/home.css")" rel="stylesheet" />
}

<!-- HERO -->
<section class="hero">
    <div class="hero-content">
        <span class="hero-tag"><i class="fa-solid fa-paw"></i> Your Dog Deserves the Best</span>
        <h1 class="hero-headline">Find Everything<br /><span class="highlight">Your Dog Loves</span></h1>
        <p class="hero-sub">Premium treats, toys, accessories &amp; health products<br />for every breed and every size.</p>
        <div class="hero-actions">
            <a href="@Url.Action("Index","Product")" class="btn-primary"><i class="fa-solid fa-bag-shopping"></i> Shop Now</a>
            <a href="@Url.Action("Index","Reviews")" class="btn-outline">Browse Reviews</a>
        </div>
        <div class="hero-stats">
            <div class="stat"><strong>500+</strong><span>Products</span></div>
            <div class="stat-divider"></div>
            <div class="stat"><strong>2K+</strong><span>Happy Dogs</span></div>
            <div class="stat-divider"></div>
            <div class="stat"><strong>Free</strong><span>Ship &#8369;500+</span></div>
        </div>
    </div>
    <div class="hero-image">
        <div class="hero-img-wrapper">
            <div class="hero-img-placeholder">
                <i class="fa-solid fa-dog"></i>
                <p>Hero Image</p>
                <small>Recommended: 600&times;480px</small>
            </div>
        </div>
    </div>
</section>

<!-- BREED SIZE -->
<section class="breed-section">
    <div class="section-header">
        <h2>Shop for Your Breed</h2>
        <p>Find the right products based on your dog's size</p>
    </div>
    <div class="breed-grid">
        <a href="@Url.Action("Index","Product", new{size="Small"})" class="breed-card">
            <i class="fa-solid fa-dog"></i>
            <h3>Small</h3>
            <p>Under 10 kg</p>
            <small>Chihuahua &middot; Shih Tzu &middot; Pomeranian</small>
            <span class="view-link">View Products</span>
        </a>
        <a href="@Url.Action("Index","Product", new{size="Medium"})" class="breed-card">
            <i class="fa-solid fa-dog"></i>
            <h3>Medium</h3>
            <p>10 &ndash; 25 kg</p>
            <small>Beagle &middot; Bulldog &middot; Labrador Mix</small>
            <span class="view-link">View Products</span>
        </a>
        <a href="@Url.Action("Index","Product", new{size="Large"})" class="breed-card">
            <i class="fa-solid fa-dog"></i>
            <h3>Large</h3>
            <p>25 kg and above</p>
            <small>German Shepherd &middot; Husky &middot; Labrador</small>
            <span class="view-link">View Products</span>
        </a>
    </div>
</section>

<!-- CATEGORIES -->
<section class="categories-section">
    <div class="section-header">
        <h2>Browse by Category</h2>
        <p>Everything your dog needs, organized just for you</p>
    </div>
    <div class="categories-grid">
        <a href="@Url.Action("Index","Product",new{category="Treats"})" class="category-card"><i class="fa-solid fa-bone"></i><h3>Treats</h3><span>View All</span></a>
        <a href="@Url.Action("Index","Product",new{category="Toys"})" class="category-card"><i class="fa-regular fa-circle-dot"></i><h3>Toys</h3><span>View All</span></a>
        <a href="@Url.Action("Index","Product",new{category="Accessories"})" class="category-card"><i class="fa-solid fa-tag"></i><h3>Accessories</h3><span>View All</span></a>
        <a href="@Url.Action("Index","Product",new{category="Health"})" class="category-card"><i class="fa-solid fa-pills"></i><h3>Health &amp; Care</h3><span>View All</span></a>
        <a href="@Url.Action("Index","Product",new{category="Others"})" class="category-card"><i class="fa-regular fa-box"></i><h3>Others</h3><span>View All</span></a>
    </div>
</section>

<!-- FEATURES STRIP -->
<section class="features-strip">
    <div class="feature-item"><i class="fa-solid fa-truck"></i><div><h4>Free Delivery</h4><p>On orders over &#8369;500</p></div></div>
    <div class="feature-item"><i class="fa-solid fa-percent"></i><div><h4>Up to 30% Off</h4><p>On selected products</p></div></div>
    <div class="feature-item"><i class="fa-solid fa-headset"></i><div><h4>Customer Support</h4><p>Mon&ndash;Sat, 8AM&ndash;6PM</p></div></div>
    <div class="feature-item"><i class="fa-solid fa-rotate-left"></i><div><h4>Easy Returns</h4><p>30-day return policy</p></div></div>
</section>

<!-- PROMO BANNERS -->
<section class="promo-section">
    <div class="section-header"><h2>Hot Deals &#128293;</h2></div>
    <div class="promo-grid">
        <a href="@Url.Action("Index","Product",new{category="Treats"})" class="promo-card" style="background:linear-gradient(145deg,#ffe8d6,#ffd4b5);">
            <div class="pct">50%<span> OFF</span></div>
            <h4>Dog Treats</h4>
            <p>Premium flavors your dog will love</p>
            <span class="shop-now-btn">Shop Now</span>
        </a>
        <a href="@Url.Action("Index","Product",new{category="Toys"})" class="promo-card" style="background:linear-gradient(145deg,var(--lblue),#c8e0ea);">
            <div class="pct">Buy 1</div>
            <h4>Get 1 Free &mdash; Toys</h4>
            <p>Keep your pup entertained for less</p>
            <span class="shop-now-btn">Shop Now</span>
        </a>
        <a href="@Url.Action("Index","Product",new{category="Health"})" class="promo-card" style="background:linear-gradient(145deg,var(--peach),#eedfd0);">
            <div class="pct">30%<span> OFF</span></div>
            <h4>Health &amp; Care</h4>
            <p>Keep your dog healthy for less</p>
            <span class="shop-now-btn">Shop Now</span>
        </a>
    </div>
</section>

<!-- REVIEWS -->
@if (reviews != null && reviews.Any())
{
    <section class="reviews-section">
        <div class="section-header">
            <h2>From Our Pack <i class="fa-brands fa-instagram" style="color:#E6A520;"></i></h2>
            <p>Real dogs, real reviews from verified buyers</p>
            <a href="@Url.Action("Index","Reviews")" style="display:inline-flex;align-items:center;gap:6px;margin-top:1rem;font-size:13px;font-weight:700;color:var(--blue-dark);text-decoration:none">
                View All Reviews <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>
        <div class="reviews-grid">
            @foreach (var r in reviews)
            {
                var dogIcons = new[] { "fa-dog", "fa-paw", "fa-bone" };
                var colors = new[] { "#ffe8d6", "#ddeaf3", "#f3e3d0" };
                var color = colors[r.Id % colors.Length];
                var icon = dogIcons[r.Id % dogIcons.Length];

                <div class="review-card">
                    <div class="review-card-icon" style="width:100%;height:80px;background:@color;display:flex;align-items:center;justify-content:center">
                        <i class="fa-solid @icon" style="font-size:2rem;color:rgba(0,0,0,.1)"></i>
                    </div>
                    <div class="review-info">
                        <div class="review-header" style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
                            <div class="review-avatar" style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--blue-dark));display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:700">@r.CustomerName[0]</div>
                            <div>
                                <div style="font-size:12px;font-weight:700;color:var(--text)">@r.CustomerName</div>
                                <div style="font-size:10px;color:var(--text-light)">Verified Buyer</div>
                            </div>
                        </div>
                        <div class="review-stars">
                            @for (int i = 1; i <= 5; i++)
                            {<i class="@(i <= r.Stars ? "fa-solid" : "fa-regular") fa-star"></i>}
                        </div>
                        <p style="font-size:12px;color:var(--text-mid);line-height:1.5;margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">"@r.Comment"</p>
                        <div style="display:flex;align-items:center;gap:8px;padding-top:8px;border-top:1px solid rgba(129,166,198,.1);font-size:11px;color:var(--text-light)">
                            <i class="fa-regular fa-heart"></i> @r.Likes
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

@section scripts {
    <script src="@Url.Content("~/Scripts/home.js")"></script>
}
