@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var reviews = ViewBag.Reviews as List<Pawchase.Models.Review>;
}

@section styles {
    <link href="@Url.Content("~/Content/css/home.css")" rel="stylesheet" />
}

<!-- HERO -->
<section class="hero">
    <div class="hero-content">
        <span class="hero-tag"><i class="fa-solid fa-paw"></i> Your Dog Deserves the Best</span>
        <h1 class="hero-headline">Find Everything<br /><span class="highlight">Your Dog Loves</span></h1>
        <p class="hero-sub">Premium treats, toys, accessories &amp; health products<br />for every breed and every size.</p>
        <div class="hero-actions">
            <a href="@Url.Action("Index","Product")" class="btn-primary"><i class="fa-solid fa-bag-shopping"></i> Shop Now</a>
            <a href="@Url.Action("Index","Reviews")" class="btn-outline">Browse Reviews</a>
        </div>
        <div class="hero-stats">
            <div class="stat"><strong>500+</strong><span>Products</span></div>
            <div class="stat-divider"></div>
            <div class="stat"><strong>2K+</strong><span>Happy Dogs</span></div>
            <div class="stat-divider"></div>
            <div class="stat"><strong>Free</strong><span>Ship &#8369;500+</span></div>
        </div>
    </div>
</section>

<!-- BREED SIZE -->
<section class="breed-section">
    <div class="section-header">
        <h2>Shop for Your Breed</h2>
        <p>Find the right products based on your dog's size</p>
    </div>
    <div class="breed-grid">
        <a href="@Url.Action("Index","Product", new{size="Small",fromHome=1})" class="breed-card">
            <div class="breed-card-top">
                <img src="/Content/images/small-dog.png" alt="Small dog" class="breed-img" />
                <span class="breed-size-tag">Small</span>
            </div>
            <div class="breed-card-body">
                <h3>Small Breeds</h3>
                <p class="breed-weight"><i class="fa-solid fa-weight-scale"></i> Under 10 kg</p>
                <p class="breed-examples">Chihuahua &middot; Shih Tzu &middot; Pomeranian</p>
                <div class="breed-features">
                    <span><i class="fa-solid fa-cookie-bite"></i> Bite-size treats</span>
                    <span><i class="fa-solid fa-shirt"></i> Tiny accessories</span>
                </div>
                <span class="view-link">Shop Small Breeds <i class="fa-solid fa-arrow-right"></i></span>
            </div>
        </a>
        <a href="@Url.Action("Index","Product", new{size="Medium",fromHome=1})" class="breed-card breed-card--featured">
            <div class="breed-card-top">
                <img src="/Content/images/medium-dog.png" alt="Medium dog" class="breed-img" />
                <span class="breed-size-tag">Medium</span>
                <span class="breed-popular-tag">Most Popular</span>
            </div>
            <div class="breed-card-body">
                <h3>Medium Breeds</h3>
                <p class="breed-weight"><i class="fa-solid fa-weight-scale"></i> 10 &ndash; 25 kg</p>
                <p class="breed-examples">Beagle &middot; Bulldog &middot; Labrador Mix</p>
                <div class="breed-features">
                    <span><i class="fa-solid fa-bone"></i> Premium chews</span>
                    <span><i class="fa-solid fa-ball"></i> Active toys</span>
                </div>
                <span class="view-link">Shop Medium Breeds <i class="fa-solid fa-arrow-right"></i></span>
            </div>
        </a>
        <a href="@Url.Action("Index","Product", new{size="Large",fromHome=1})" class="breed-card">
            <div class="breed-card-top">
                <img src="/Content/images/large-dog.png" alt="Large dog" class="breed-img" />
                <span class="breed-size-tag">Large</span>
            </div>
            <div class="breed-card-body">
                <h3>Large Breeds</h3>
                <p class="breed-weight"><i class="fa-solid fa-weight-scale"></i> 25 kg and above</p>
                <p class="breed-examples">German Shepherd &middot; Husky &middot; Labrador</p>
                <div class="breed-features">
                    <span><i class="fa-solid fa-dumbbell"></i> Joint support</span>
                    <span><i class="fa-solid fa-shield-dog"></i> Heavy-duty toys</span>
                </div>
                <span class="view-link">Shop Large Breeds <i class="fa-solid fa-arrow-right"></i></span>
            </div>
        </a>
    </div>
</section>

<!-- CATEGORIES -->
<section class="categories-section">
    <div class="section-header">
        <h2>Browse by Category</h2>
        <p>Everything your dog needs, organized just for you</p>
    </div>
    <div class="categories-grid">
        <a href="@Url.Action("Index","Product",new{category="Treats",fromHome=1})" class="category-card cat-treats">
            <div class="cat-icon-wrap"><i class="fa-solid fa-bone"></i></div>
            <div class="cat-label"><h3>Treats</h3><span>View All</span></div>
        </a>
        <a href="@Url.Action("Index","Product",new{category="Toys",fromHome=1})" class="category-card cat-toys">
            <div class="cat-icon-wrap"><i class="fa-regular fa-circle-dot"></i></div>
            <div class="cat-label"><h3>Toys</h3><span>View All</span></div>
        </a>
        <a href="@Url.Action("Index","Product",new{category="Accessories",fromHome=1})" class="category-card cat-acc">
            <div class="cat-icon-wrap"><i class="fa-solid fa-tag"></i></div>
            <div class="cat-label"><h3>Accessories</h3><span>View All</span></div>
        </a>
        <a href="@Url.Action("Index","Product",new{category="Health",fromHome=1})" class="category-card cat-health">
            <div class="cat-icon-wrap"><i class="fa-solid fa-pills"></i></div>
            <div class="cat-label"><h3>Health &amp; Care</h3><span>View All</span></div>
        </a>
        <a href="@Url.Action("Index","Product",new{category="Others",fromHome=1})" class="category-card cat-others">
            <div class="cat-icon-wrap"><i class="fa-solid fa-ellipsis"></i></div>
            <div class="cat-label"><h3>Others</h3><span>View All</span></div>
        </a>
    </div>
</section>

<!-- FEATURES STRIP -->
<section class="features-strip">
    <div class="feature-item"><i class="fa-solid fa-truck"></i><div><h4>Free Delivery</h4><p>On orders over &#8369;500</p></div></div>
    <div class="feature-item"><i class="fa-solid fa-percent"></i><div><h4>Up to 30% Off</h4><p>On selected products</p></div></div>
    <div class="feature-item"><i class="fa-solid fa-headset"></i><div><h4>Customer Support</h4><p>Mon&ndash;Sat, 8AM&ndash;6PM</p></div></div>
    <div class="feature-item"><i class="fa-solid fa-rotate-left"></i><div><h4>Easy Returns</h4><p>30-day return policy</p></div></div>
</section>

<!-- PROMO BANNERS -->
<section class="promo-section">
    <div class="promo-header">
        <div class="promo-header-left">
            <div class="promo-eyebrow">
                <span class="promo-live-dot"></span>
                <span class="promo-eyebrow-text">Limited Time Offers</span>
            </div>
            <h2 class="promo-title">
                <i class="fa-solid fa-fire promo-fire-icon"></i> Hot Deals
            </h2>
            <p class="promo-tagline">Don&rsquo;t miss out &mdash; these prices are going fast!</p>
        </div>
        <a href="@Url.Action("Index","Product",new{onSale=true,fromHome=1})" class="promo-view-all">
            View All Deals <i class="fa-solid fa-arrow-right"></i>
        </a>
    </div>
    <div class="promo-grid">
        <a href="@Url.Action("Index","Product",new{category="Treats",onSale=true,fromHome=1})" class="promo-card promo-card--imgbg promo-card--treats">
            <div class="promo-imgbg-layer" style="background-image:url('/Content/images/promo1-bg.png');"></div>
            <div class="promo-imgbg-overlay promo-overlay--treats"></div>
            <div class="promo-imgbg-content">
                <div class="promo-imgbg-top">
                    <span class="promo-badge">50% OFF</span>
                </div>
                <div class="promo-imgbg-body">
                    <span class="promo-cat-label"><i class="fa-solid fa-bone"></i> Treats</span>
                    <h4>Dog Treats</h4>
                    <p>Premium flavors your dog will love</p>
                    <span class="promo-shop-btn">
                        Shop Now <i class="fa-solid fa-arrow-right"></i>
                    </span>
                </div>
            </div>
        </a>
        <a href="@Url.Action("Index","Product",new{category="Toys",onSale=true,fromHome=1})" class="promo-card promo-card--imgbg promo-card--toys promo-card--star">
            <div class="promo-imgbg-layer" style="background-image: url('/Content/images/promo2-bg.png');"></div>
            <div class="promo-imgbg-overlay promo-overlay--toys"></div>
            <div class="promo-imgbg-content">
                <div class="promo-imgbg-top">
                    <span class="promo-badge promo-badge--bogo">Buy 1 Get 1</span>
                </div>
                <div class="promo-imgbg-body">
                    <span class="promo-cat-label"><i class="fa-regular fa-circle-dot"></i> Toys</span>
                    <h4>Interactive Dog Toys</h4>
                    <p>Buy one, take one free &mdash; double the fun!</p>
                    <span class="promo-shop-btn">
                        Shop Now <i class="fa-solid fa-arrow-right"></i>
                    </span>
                </div>
            </div>
        </a>
        <a href="@Url.Action("Index","Product",new{category="Health",onSale=true,fromHome=1})" class="promo-card promo-card--imgbg promo-card--health">
            <div class="promo-imgbg-layer" style="background-image: url('/Content/images/promo3-bg.png');"></div>
            <div class="promo-imgbg-overlay promo-overlay--health"></div>
            <div class="promo-imgbg-content">
                <div class="promo-imgbg-top">
                    <span class="promo-badge promo-badge--green">30% OFF</span>
                </div>
                <div class="promo-imgbg-body">
                    <span class="promo-cat-label"><i class="fa-solid fa-pills"></i> Health &amp; Care</span>
                    <h4>Health &amp; Care Essentials</h4>
                    <p>Keep your dog healthy for less &mdash; vitamins &amp; more on sale.</p>
                    <span class="promo-shop-btn">
                        Shop Now <i class="fa-solid fa-arrow-right"></i>
                    </span>
                </div>
            </div>
        </a>
    </div>
</section>

<!-- FEATURED PRODUCTS -->
@{
    var featured = ViewBag.FeaturedProducts as List<Pawchase.Models.Product>;
}
@if (featured != null && featured.Any())
{
    <section class="featured-section">
        <div class="featured-bg-pattern"></div>
        <div class="featured-inner">
            <div class="section-header">
                <h2><i class="fa-solid fa-star" style="color:#E6A520;margin-right:8px;"></i>Featured Products</h2>
                <p>Top picks your dog will love</p>
            </div>
            <div class="featured-grid">
                @foreach (var p in featured)
                {
                    bool isOnSale = p.OriginalPrice.HasValue && p.OriginalPrice > p.Price;
                    int disc = isOnSale ? (int)Math.Round((1 - (double)p.Price / (double)p.OriginalPrice.Value) * 100) : 0;
                    <a href="@Url.Action("Details","Product",new{id=p.Id})" class="featured-card">
                        @if (isOnSale && disc > 0)
                        {
                            <span class="discount-pct-badge">-@disc%</span>
                        }
                        <div class="featured-img">
                            <img src="@p.ImageUrl" alt="@p.Name"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                            <div class="featured-img-fallback">
                                <i class="fa-solid fa-bone"></i>
                            </div>
                        </div>
                        <div class="featured-info">
                            <span class="featured-cat-label">@p.Category &middot; @p.BreedSize</span>
                            <h3>@p.Name</h3>
                            <div class="product-price">
                                <span class="price">&#8369;@p.Price.ToString("N2")</span>
                                @if (isOnSale)
                                {
                                    <span class="original-price">&#8369;@p.OriginalPrice.Value.ToString("N2")</span>
                                }
                            </div>
                            <div class="featured-card-footer">
                                <span class="featured-view-btn">
                                    View Product <i class="fa-solid fa-arrow-right"></i>
                                </span>
                            </div>
                        </div>
                    </a>
                }
            </div>
            <div class="view-all-wrap">
                <a href="@Url.Action("Index","Product")" class="btn-outline featured-viewall-btn">
                    <i class="fa-solid fa-store"></i> View All Products
                </a>
            </div>
        </div>
    </section>
}

<!-- REVIEWS -->
@if (reviews != null && reviews.Any())
{
    <section class="reviews-section">
        <div class="section-header">
            <h2>From Our Pack <i class="fa-brands fa-instagram" style="color:#E6A520;"></i></h2>
            <p>Real dogs, real reviews from verified buyers</p>
            <a href="@Url.Action("Index","Reviews")" style="display:inline-flex;align-items:center;gap:6px;margin-top:1rem;font-size:13px;font-weight:700;color:var(--blue-dark);text-decoration:none">
                View All Reviews <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>
        <div class="reviews-grid">
            @foreach (var r in reviews)
            {
                var dogIcons = new[] { "fa-dog", "fa-paw", "fa-bone" };
                var colors = new[] { "#ffe8d6", "#ddeaf3", "#f3e3d0" };
                var color = colors[r.Id % colors.Length];
                var icon = dogIcons[r.Id % dogIcons.Length];

                <div class="review-card">
                    <div class="review-card-icon" style="width:100%;height:80px;background:@color;display:flex;align-items:center;justify-content:center">
                        <i class="fa-solid @icon" style="font-size:2rem;color:rgba(0,0,0,.1)"></i>
                    </div>
                    <div class="review-info">
                        <div class="review-header" style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
                            <div class="review-avatar" style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--blue-dark));display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:700">@r.CustomerName[0]</div>
                            <div>
                                <div style="font-size:12px;font-weight:700;color:var(--text)">@r.CustomerName</div>
                                <div style="font-size:10px;color:var(--text-light)">Verified Buyer</div>
                            </div>
                        </div>
                        <div class="review-stars">
                            @for (int i = 1; i <= 5; i++)
                            {<i class="@(i <= r.Stars ? "fa-solid" : "fa-regular") fa-star"></i>}
                        </div>
                        <p style="font-size:12px;color:var(--text-mid);line-height:1.5;margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">"@r.Comment"</p>
                        <div style="display:flex;align-items:center;gap:8px;padding-top:8px;border-top:1px solid rgba(129,166,198,.1);font-size:11px;color:var(--text-light)">
                            <i class="fa-regular fa-heart"></i> @r.Likes
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

@section scripts {
    <script src="@Url.Content("~/Scripts/home.js")"></script>
}   