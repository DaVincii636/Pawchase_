<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - PawChase</title>
    <link rel="icon" href="@Url.Content("~/Content/images/favicon.png")" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet" />
    <link href="@Url.Content("~/Content/css/site.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/css/navbar.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/css/mobile.css")" rel="stylesheet" />
    @RenderSection("styles", required: false)
</head>
<body>

    @Html.Partial("_Navbar")



    <main>@RenderBody()</main>

    @Html.Partial("_Footer")


    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
    <script src="@Url.Content("~/Scripts/pawchase.js")"></script>
    @RenderSection("scripts", required: false)

    <!-- ── LOGOUT CONFIRMATION MODAL ── -->
    <div id="logoutModal" class="pc-modal-overlay" onclick="if(event.target===this)closeLogoutModal()">
        <div class="pc-modal-box">

            <div class="pc-modal-icon" style="background:rgba(66,133,244,.10);">
                <i class="fa-solid fa-right-from-bracket" style="color:#4285f4;"></i>
            </div>

            <div class="pc-modal-title">Log out?</div>

            <div class="pc-modal-body">
                Are you sure you want to logout?
            </div>

            <div class="pc-modal-btns">
                <button class="pc-modal-cancel" onclick="closeLogoutModal()">Cancel</button>

                <form method="post" action="@Url.Action("Logout","Account")" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="pc-modal-confirm-blue">
                        <i class="fa-solid fa-right-from-bracket"></i> Logout
                    </button>
                </form>
            </div>

        </div>
    </div>

</body>
</html>
