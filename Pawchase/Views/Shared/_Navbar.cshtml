@{
    var isLoggedIn = Session["UserId"] != null;
    var userName = Session["UserName"] as string;
    var cart = Session["Cart"] as List<Pawchase.Models.CartItem>;
    var cartCount = cart != null ? cart.Sum(c => c.Quantity) : 0;
    var path = Request.Url.AbsolutePath.ToLower();
}

<div class="announcement-bar">
    <div class="announcement-track">
        <span><i class="fa-solid fa-truck"></i> FREE SHIPPING on orders over &#8369;500!</span>
        <span class="sep">|</span>
        <span>Use code <strong>PAWSOME</strong> for 10% off your first order!</span>
        <span class="sep">|</span>
        <span><i class="fa-solid fa-star"></i> New arrivals every week &mdash; Shop now!</span>
        <span class="sep">|</span>
        <span><i class="fa-solid fa-truck"></i> FREE SHIPPING on orders over &#8369;500!</span>
        <span class="sep">|</span>
        <span>Use code <strong>PAWSOME</strong> for 10% off!</span>
    </div>
</div>

<nav class="navbar">
    <div class="nav-logo">
        <a href="@Url.Action("Index","Home")">
            <img src="@Url.Content("~/Content/images/Pawchase_logo.png")" alt="PawChase"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
            <span class="logo-text-fallback" style="display:none;">
                <i class="fa-solid fa-paw"></i> PawChase
            </span>
        </a>
    </div>

    <ul class="nav-left">
        <li class="@(path == "/" || path.Contains("/home/index") ? "active" : "")">
            @Html.ActionLink("Home", "Index", "Home")
        </li>
        <li class="@(path.Contains("/product") ? "active" : "")">
            @Html.ActionLink("Products", "Index", "Product")
        </li>
        <li class="@((path == "/reviews" || path.Contains("/reviews/index")) ? "active" : "")">
            @Html.ActionLink("Reviews", "Index", "Reviews")
        </li>
        <li class="@(path.Contains("/home/about") ? "active" : "")">
            @Html.ActionLink("About", "About", "Home")
        </li>
        <li class="@(path.Contains("/home/contact") ? "active" : "")">
            @Html.ActionLink("Contact", "Contact", "Home")
        </li>
    </ul>

    <div class="nav-right">
        <a href="@Url.Action("Index","Cart")" class="nav-cart">
            <i class="fa-solid fa-cart-shopping"></i>
            <span>Cart</span>
            @if (cartCount > 0)
            {<span class="cart-badge">@cartCount</span>}
        </a>

        <a href="@Url.Action("Track","Order")" class="nav-link-icon">
            <i class="fa-solid fa-list-check"></i>
            <span>Orders</span>
        </a>

        @if (isLoggedIn)
        {
            <div class="nav-account">
                <i class="fa-regular fa-user"></i>
                <span>@(userName != null && userName.Length > 10 ? userName.Substring(0, 10) + "&hellip;" : userName)</span>
                <div class="account-dropdown">
                    <a href="@Url.Action("Orders","Account")"><i class="fa-solid fa-list-check"></i> My Orders</a>
                    <a href="@Url.Action("MyReviews","Reviews")" class="@(path.Contains("/reviews/myreviews") ? "active" : "")"><i class="fa-solid fa-bookmark"></i> My Reviews</a>
                    <a href="@Url.Action("Logout","Account")" class="logout-link"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
                </div>
            </div>
        }
        else
        {
            <a href="@Url.Action("Login","Account")" class="nav-link-icon">
                <i class="fa-regular fa-user"></i>
                <span>Login</span>
            </a>
        }
    </div>
</nav>
