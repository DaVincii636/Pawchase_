@model Pawchase.Models.Product
@{
    ViewBag.Title = "Edit Product";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    var categories = new[] { "Food & Treats", "Accessories & Apparel", "Care & Hygiene", "Toys", "Health", "Others" };
    var sizes = new[] { "Small", "Medium", "Large", "All" };
}

<style>
    .add-product-wrap {
        max-width: 820px;
    }

    .form-section {
        background: var(--white);
        border-radius: var(--radius-lg);
        border: 1.5px solid var(--border);
        padding: 1.8rem;
        box-shadow: var(--shadow-card);
        margin-bottom: 1.2rem;
    }

    .form-section-title {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 1.4rem;
        padding-bottom: .75rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .form-section-title i {
            color: var(--blue);
            font-size: 14px;
        }

    .img-preview-current {
        width: 110px;
        height: 110px;
        border-radius: var(--radius);
        background: linear-gradient(145deg,var(--peach),#eedfd0);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border: 1.5px solid var(--border);
        box-shadow: var(--shadow-sm);
        margin-bottom: .75rem;
    }

        .img-preview-current img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .img-preview-current i {
            font-size: 2.5rem;
            color: var(--blue);
            opacity: .45;
        }

    .img-path-row {
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--bg);
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 8px 12px;
        box-shadow: var(--shadow-inset);
    }

        .img-path-row i {
            color: var(--blue);
            font-size: 13px;
            flex-shrink: 0;
        }

        .img-path-row input {
            flex: 1;
            border: none;
            background: transparent;
            font-size: 12px;
            color: var(--text-mid);
            outline: none;
            font-family: 'Poppins', sans-serif;
        }

    .img-path-note {
        font-size: 11px;
        color: var(--text-light);
        margin-top: 6px;
        display: flex;
        align-items: flex-start;
        gap: 5px;
    }

        .img-path-note i {
            color: var(--blue);
            flex-shrink: 0;
            margin-top: 2px;
        }

    .form-2col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.2rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .form-group label {
            font-size: 12px;
            font-weight: 700;
            color: var(--text-mid);
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .form-group label i {
                color: var(--blue);
                font-size: 12px;
            }

            .form-group label .req {
                color: #e05555;
            }

        .form-group input, .form-group select, .form-group textarea {
            padding: 11px 14px;
            border: 1.5px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-family: 'Poppins', sans-serif;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
            background: var(--white);
            color: var(--text);
            box-shadow: var(--shadow-inset);
        }

            .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 3px rgba(129,166,198,0.15);
            }

    .form-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
        padding: .5rem 0;
    }

    .img-upload-box {
        width: 100%;
        background: linear-gradient(145deg,var(--peach),#eedfd0);
        border-radius: 12px;
        border: 2px dashed rgba(129,166,198,.4);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        overflow: hidden;
        transition: border-color .2s;
        margin-bottom: 12px;
    }

        .img-upload-box:hover {
            border-color: var(--blue);
        }

        .img-upload-box .placeholder {
            text-align: center;
            color: var(--blue-dark);
            pointer-events: none;
        }

            .img-upload-box .placeholder i {
                font-size: 2.2rem;
                display: block;
                margin-bottom: .5rem;
            }

            .img-upload-box .placeholder span {
                font-size: 12px;
                font-weight: 600;
                display: block;
            }

            .img-upload-box .placeholder small {
                font-size: 10px;
                color: var(--text-light);
            }
</style>

<div class="admin-page-header">
    <h1>Edit Product</h1>
    <a href="@Url.Action("Products","Admin")" class="btn-outline" style="padding:8px 16px;font-size:12px;">
        <i class="fa-solid fa-arrow-left"></i> Back
    </a>
</div>

<form method="post" action="@Url.Action("EditProduct","Admin")" class="add-product-wrap">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id" />

    <!-- IMAGE -->
    <div class="form-section">
        <div class="form-section-title">
            <i class="fa-regular fa-image"></i> Product Image
        </div>
        <label style="font-size:12px;font-weight:700;color:var(--text-mid);display:block;margin-bottom:6px;">
            Main Image <span style="color:#e05555;">*</span>
        </label>
        <!-- Hidden file input first so label[for] can reference it -->
        <input type="file" id="editImgFile0" accept="image/*" style="display:none" onchange="previewMainEdit(this)" />
        <label for="editImgFile0" style="display:block;cursor:pointer;">
            <div class="img-upload-box" id="editImgBox0" style="height:150px;margin-bottom:0;">
                <img id="editImgPreview0" src="@Model.ImageUrl" alt="@Model.Name"
                     style="max-height:150px;max-width:100%;object-fit:contain;border-radius:10px;@(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "display:block;")"
                     onerror="this.style.display='none';document.getElementById('editImgIcon0').style.display='flex';" />
                <div class="placeholder" id="editImgIcon0"
                     style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "" : "display:none;")">
                    <i class="fa-regular fa-image"></i>
                    <span>Click to replace image</span>
                    <small>PNG, JPG up to 5MB</small>
                </div>
            </div>
        </label>
        <!-- Holds current or newly-selected image URL; starts with existing value -->
        <input type="hidden" name="ImageUrl" id="editImgPath0" value="@Model.ImageUrl" />
        <p id="editImg-filename0" style="font-size:11px;color:var(--text-light);margin-top:6px;"></p>
    </div>


    <!-- VARIANTS -->
    <div class="form-section">
        <div class="form-section-title"><i class="fa-solid fa-palette"></i> Color / Style Variants <span style="font-size:10px;font-weight:400;color:var(--text-light)">&mdash; optional, up to 4</span></div>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:.75rem">
            @{ var existingVariants = Model.Variants ?? new System.Collections.Generic.List<Pawchase.Models.ProductVariant>(); }
            @for (int vi = 1; vi <= 4; vi++)
            {
                var ev = existingVariants.Count >= vi ? existingVariants[vi - 1] : null;
                <div>
                    <!-- Hidden file input first so label[for] can reference it -->
                    <input type="file" id="evFile@(vi)" accept="image/*" style="display:none"
                           onchange="previewEditVariant(this,@(vi))" />
                    <!-- label[for] is the reliable cross-browser way to trigger file picker -->
                    <label for="evFile@(vi)" style="display:block;cursor:pointer;margin-bottom:6px;">
                        <div class="img-upload-box" style="height:90px;margin-bottom:0;position:relative;"
                             id="evBox@(vi)">
                            <img id="evPreview@(vi)"
                                 src="@(ev != null && !string.IsNullOrEmpty(ev.ImageUrl) ? ev.ImageUrl : "")"
                                 alt=""
                                 style="@(ev != null && !string.IsNullOrEmpty(ev.ImageUrl) ? "display:block;" : "display:none;")max-height:88px;pointer-events:none;width:100%;object-fit:cover;"
                                 onerror="this.style.display='none';var ic=document.getElementById('evIcon@(vi)');if(ic)ic.style.display='flex';" />
                            <div class="placeholder" id="evIcon@(vi)"
                                 style="padding:.4rem;pointer-events:none;@(ev != null && !string.IsNullOrEmpty(ev.ImageUrl) ? "display:none;" : "")">
                                <i class="fa-solid fa-@(ev != null && !string.IsNullOrEmpty(ev.ImageUrl) ? "arrows-rotate" : "plus")" style="font-size:1.1rem"></i>
                                <span style="font-size:10px">Variant @vi</span>
                            </div>
                        </div>
                    </label>
                    <input type="hidden" id="evPath@(vi)" name="VariantImagePaths"
                           value="@(ev != null ? ev.ImageUrl : "")" />
                    <input type="text" id="evLabel@(vi)" name="VariantLabels"
                           placeholder="e.g. Red, Blue"
                           value="@(ev != null ? ev.Label : "")"
                           style="width:100%;padding:5px 8px;border:1.5px solid var(--border);border-radius:6px;font-size:11px;font-family:Poppins,sans-serif;box-sizing:border-box;background:var(--white);color:var(--text)" />
                </div>
            }
        </div>
    </div>

    <!-- DETAILS -->
    <div class="form-section">
        <div class="form-section-title">
            <i class="fa-solid fa-tag"></i> Product Details
        </div>
        <div class="form-2col" style="margin-bottom:1.2rem;">
            <div class="form-group">
                <label><i class="fa-solid fa-pen"></i> Product Name <span class="req">*</span></label>
                <input type="text" name="Name" value="@Model.Name" required />
            </div>
            <div class="form-group">
                <label><i class="fa-solid fa-list"></i> Category <span class="req">*</span></label>
                <select name="Category" required>
                    @foreach (var c in categories)
                    {
                        <option value="@c" @(Model.Category == c ? "selected" : "")>@c</option>
                    }
                </select>
            </div>
        </div>
        <div class="form-2col" style="margin-bottom:1.2rem;">
            <div class="form-group">
                <label><i class="fa-solid fa-dog"></i> Breed Size <span class="req">*</span></label>
                <select name="BreedSize" required>
                    @foreach (var s in sizes)
                    {
                        <option value="@s" @(Model.BreedSize == s ? "selected" : "")>@s</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label><i class="fa-solid fa-boxes-stacked"></i> Stock <span class="req">*</span></label>
                <input type="number" name="Stock" min="0" value="@Model.Stock" required />
            </div>
        </div>
        <div class="form-group">
            <label><i class="fa-regular fa-message"></i> Description <span class="req">*</span></label>
            <textarea name="Description" rows="4" required>@Model.Description</textarea>
        </div>
    </div>

    <!-- PRICING -->
    <div class="form-section">
        <div class="form-section-title">
            <i class="fa-solid fa-peso-sign"></i> Pricing
        </div>
        <div class="form-2col">
            <div class="form-group">
                <label><i class="fa-solid fa-peso-sign"></i> Price <span class="req">*</span></label>
                <input type="number" name="Price" step="0.01" value="@Model.Price" required />
            </div>
            <div class="form-group">
                <label>
                    <i class="fa-solid fa-percent"></i> Original Price
                    <span style="font-size:10px;font-weight:400;color:var(--text-light);margin-left:4px;">&mdash; blank if not on sale</span>
                </label>
                <input type="number" name="OriginalPrice" step="0.01"
                       value="@(Model.OriginalPrice.HasValue ? Model.OriginalPrice.Value.ToString() : "")" />
            </div>
        </div>
        <div style="margin-top:.75rem;padding:.75rem 1rem;background:rgba(129,166,198,0.08);border-radius:var(--radius-sm);border:1px solid rgba(129,166,198,0.2);font-size:12px;color:var(--text-mid);display:flex;align-items:center;gap:8px;">
            <i class="fa-solid fa-circle-info" style="color:var(--blue);"></i>
            If <strong>Original Price</strong> is higher than <strong>Price</strong>, a <span style="background:rgba(232,93,93,0.15);color:#c94040;font-size:10px;font-weight:700;padding:2px 6px;border-radius:50px;">SALE</span> badge will appear.
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn-primary" style="padding:11px 26px;font-size:13px;">
            <i class="fa-solid fa-floppy-disk"></i> Save Changes
        </button>
        <a href="@Url.Action("Products","Admin")" class="btn-outline" style="padding:11px 26px;font-size:13px;">
            Cancel
        </a>
    </div>
</form>

@section scripts {
    <script>
        // ?? Main image preview (edit mode) ???????????????????????????????????????????
        function previewMainEdit(input) {
            if (!input.files || !input.files[0]) return;
            var reader = new FileReader();
            reader.onload = function (e) {
                var preview = document.getElementById("editImgPreview0");
                var icon = document.getElementById("editImgIcon0");
                preview.src = e.target.result;
                preview.style.display = "block";
                if (icon) icon.style.display = "none";
                // Store base64 data URL in the hidden field so the controller receives it
                document.getElementById("editImgPath0").value = e.target.result;
                document.getElementById("editImg-filename0").textContent = input.files[0].name;
            };
            reader.readAsDataURL(input.files[0]);
        }

        // ?? Variant image preview ????????????????????????????????????????????????????
        // previewEditVariant — called by onchange on each variant file input.
        // Reads the file as base64, shows the preview, hides the placeholder,
        // and stores the data URL in the hidden field for form submission.
        function previewEditVariant(input, slot) {
            if (!input.files || !input.files[0]) return;
            var reader = new FileReader();
            reader.onload = function (e) {
                var dataUrl = e.target.result;
                var preview = document.getElementById("evPreview" + slot);
                var icon = document.getElementById("evIcon" + slot);
                preview.src = dataUrl;
                preview.style.display = "block";
                if (icon) icon.style.display = "none";
                // Store base64 data URL so the image displays on the product detail page
                document.getElementById("evPath" + slot).value = dataUrl;
            };
            reader.readAsDataURL(input.files[0]);
        }
    </script>
}