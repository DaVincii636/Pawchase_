@model Pawchase.Models.Product
@{
    ViewBag.Title = "Edit Product";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    var categories = new[] { "Treats", "Toys", "Accessories", "Health", "Others" };
    var sizes = new[] { "Small", "Medium", "Large", "All" };
}
<style>
    /* ── TWO-COLUMN GRID ─────────────────────────── */
    .ap-grid {
        display: grid;
        grid-template-columns: 420px 1fr;
        gap: 1.2rem;
        align-items: start;
    }
    .ap-left  { display: flex; flex-direction: column; }
    .ap-right { display: flex; flex-direction: column; gap: 1.2rem; }

    /* ── CARD ────────────────────────────────────── */
    .form-section {
        background: var(--white);
        border-radius: var(--radius-lg);
        border: 1.5px solid var(--border);
        padding: 1.8rem;
        box-shadow: var(--shadow-card);
    }
    .form-section-title {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 1.2rem;
        padding-bottom: .75rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .form-section-title i { color: var(--blue); }

    /* ── MAIN IMAGE UPLOAD ───────────────────────── */
    .main-img-label {
        font-size: 12px;
        font-weight: 700;
        color: var(--text-mid);
        display: block;
        margin-bottom: 6px;
    }
    .main-img-box {
        width: 100%;
        height: 200px;
        background: linear-gradient(145deg, var(--peach), #eedfd0);
        border-radius: 12px;
        border: 2px dashed rgba(129,166,198,.45);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        overflow: hidden;
        transition: border-color .2s;
        margin-bottom: 6px;
        box-sizing: border-box;
    }
    .main-img-box:hover { border-color: var(--blue); }
    .main-img-box img {
        max-height: 198px;
        max-width: 100%;
        object-fit: contain;
        border-radius: 10px;
    }
    .upload-placeholder {
        text-align: center;
        color: var(--blue-dark);
        pointer-events: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
    }
    .upload-placeholder .up-icon-wrap {
        width: 56px; height: 56px;
        background: rgba(129,166,198,.18);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
    }
    .upload-placeholder i    { font-size: 1.6rem; color: var(--blue); }
    .upload-placeholder span { font-size: 12px; font-weight: 700; color: var(--text); }
    .upload-placeholder small{ font-size: 10px; color: var(--text-light); }

    /* ── VARIANTS SECTION ────────────────────────── */
    .variants-wrap {
        border-top: 1px solid var(--border);
        padding-top: 1.2rem;
        margin-top: 1.2rem;
    }
    .variants-label {
        font-size: 12px;
        font-weight: 700;
        color: var(--text-mid);
        display: block;
        margin-bottom: .75rem;
    }
    .variants-label span {
        font-size: 10px;
        font-weight: 400;
        color: var(--text-light);
    }
    .variants-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .7rem;
    }
    .variant-item { display: flex; flex-direction: column; gap: 5px; }
    .variant-img-box {
        width: 100%;
        aspect-ratio: 1 / 1;
        background: linear-gradient(145deg, var(--peach), #eedfd0);
        border-radius: 10px;
        border: 2px dashed rgba(129,166,198,.4);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        overflow: hidden;
        transition: border-color .2s;
    }
    .variant-img-box:hover { border-color: var(--blue); }
    .variant-img-box img {
        width: 100%; height: 100%;
        object-fit: cover;
        pointer-events: none;
    }
    .variant-placeholder {
        text-align: center;
        color: var(--blue-dark);
        pointer-events: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
    }
    .variant-placeholder i    { font-size: 1.2rem; }
    .variant-placeholder span { font-size: 10px; font-weight: 600; }
    .variant-text-input {
        width: 100%;
        padding: 6px 8px;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        font-size: 10px;
        font-family: 'Poppins', sans-serif;
        box-sizing: border-box;
        background: var(--white);
        color: var(--text);
        outline: none;
        transition: border-color .2s;
    }
    .variant-text-input:focus { border-color: var(--blue); }

    /* ── FORM FIELDS ─────────────────────────────── */
    .form-2col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-group label {
        font-size: 12px;
        font-weight: 700;
        color: var(--text-mid);
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .form-group label i { color: var(--blue); font-size: 12px; }
    .form-group label .req { color: #e05555; }
    .form-group input,
    .form-group select,
    .form-group textarea {
        padding: 10px 13px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: 13px;
        font-family: 'Poppins', sans-serif;
        outline: none;
        transition: border-color .2s, box-shadow .2s;
        background: var(--white);
        color: var(--text);
        width: 100%;
        box-sizing: border-box;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
        border-color: var(--blue);
        box-shadow: 0 0 0 3px rgba(129,166,198,.15);
    }
    .form-group textarea { resize: vertical; }

    /* ── ACTION BUTTONS ──────────────────────────── */
    .form-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-start;
    }

    /* ── MODAL ───────────────────────────────────── */
    .pc-modal-overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(0,0,0,0.45); z-index: 1000;
        align-items: center; justify-content: center;
    }
    .pc-modal-box {
        background: var(--white); border-radius: var(--radius-lg);
        padding: 2rem; max-width: 420px; width: 90%;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2); text-align: center;
    }
    .pc-modal-icon {
        width: 58px; height: 58px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1rem; font-size: 1.5rem;
    }
    .pc-modal-title { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: .5rem; }
    .pc-modal-body  { font-size: 13px; color: var(--text-mid); margin-bottom: 1.5rem; line-height: 1.6; }
    .pc-modal-btns  { display: flex; gap: 10px; justify-content: center; }
    .pc-modal-cancel {
        padding: 9px 22px; border-radius: 50px; font-size: 13px; font-weight: 600;
        border: 1.5px solid var(--border); background: var(--white); color: var(--text-mid);
        cursor: pointer; font-family: 'Poppins', sans-serif; transition: all .2s;
    }
    .pc-modal-cancel:hover { background: var(--border); }
    .pc-modal-confirm-blue {
        padding: 9px 22px; border-radius: 50px; font-size: 13px; font-weight: 700;
        background: linear-gradient(135deg, var(--blue), var(--blue-dark)); color: #fff; border: none;
        cursor: pointer; font-family: 'Poppins', sans-serif; transition: all .2s;
        display: inline-flex; align-items: center; gap: 6px;
    }
    .pc-modal-confirm-blue:hover { opacity: .9; transform: translateY(-1px); }

    /* ── RESPONSIVE ──────────────────────────────── */
    @@media (max-width: 960px) {
        .ap-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="admin-page-header">
    <h1>Edit Product</h1>
    <a href="@Url.Action("Products","Admin")" class="btn-outline" style="padding:8px 16px;font-size:12px;">
        <i class="fa-solid fa-arrow-left"></i> Back
    </a>
</div>

<form id="editProductForm" method="post" action="@Url.Action("EditProduct","Admin")">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="ap-grid">

        <!-- ══════════════ LEFT: IMAGES ══════════════ -->
        <div class="ap-left">
            <div class="form-section">
                <div class="form-section-title">
                    <i class="fa-regular fa-image"></i> Product Images
                </div>

                <!-- Main Image -->
                <label class="main-img-label">
                    Main Image <span style="color:#e05555;">*</span>
                </label>
                <input type="file" id="editImgFile0" accept="image/*" style="display:none" onchange="previewMainEdit(this)" />
                <label for="editImgFile0" style="display:block;cursor:pointer;">
                    <div class="main-img-box" id="editImgBox0">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img id="editImgPreview0" src="@Model.ImageUrl" alt="@Model.Name"
                                 onerror="this.style.display='none';document.getElementById('editImgIcon0').style.display='flex';" />
                        }
                        else
                        {
                            <img id="editImgPreview0" src="" alt="" style="display:none;" />
                        }
                        <div class="upload-placeholder" id="editImgIcon0"
                             style="@(!string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")">
                            <div class="up-icon-wrap">
                                <i class="fa-regular fa-image"></i>
                            </div>
                            <span>Click to Replace Image</span>
                            <small>PNG, JPG up to 5MB</small>
                        </div>
                    </div>
                </label>
                <input type="hidden" name="ImageUrl" id="editImgPath0" value="@Model.ImageUrl" />
                <p id="editImg-filename0" style="font-size:11px;color:var(--text-light);margin-top:2px;margin-bottom:0;"></p>

                <!-- Variants -->
                <div class="variants-wrap">
                    <label class="variants-label">
                        Product Variants <span>&mdash; optional, up to 6</span>
                    </label>
                    <div class="variants-grid">
                        @{
                            var existingVariants = Model.Variants ?? new System.Collections.Generic.List<Pawchase.Models.ProductVariant>();
                        }
                        @for (int vi = 1; vi <= 6; vi++)
                        {
                            var ev = existingVariants.Count >= vi ? existingVariants[vi - 1] : null;
                            var hasImg = ev != null && !string.IsNullOrEmpty(ev.ImageUrl);
                            <div class="variant-item">
                                <input type="file" id="evFile@(vi)" accept="image/*" style="display:none"
                                       onchange="previewEditVariant(this,@(vi))" />
                                <label for="evFile@(vi)" style="display:block;cursor:pointer;">
                                    <div class="variant-img-box" id="evBox@(vi)">
                                        <img id="evPreview@(vi)"
                                             src="@(hasImg ? ev.ImageUrl : "")"
                                             alt=""
                                             style="@(hasImg ? "" : "display:none;")"
                                             onerror="this.style.display='none';var ic=document.getElementById('evIcon@(vi)');if(ic)ic.style.display='flex';" />
                                        <div class="variant-placeholder" id="evIcon@(vi)"
                                             style="@(hasImg ? "display:none;" : "")">
                                            <i class="fa-solid fa-plus"></i>
                                            <span>Add Variant</span>
                                        </div>
                                    </div>
                                </label>
                                <input type="hidden" id="evPath@(vi)" name="VariantImagePaths"
                                       value="@(ev != null ? ev.ImageUrl : "")" />
                                <input type="text" id="evLabel@(vi)" name="VariantLabels"
                                       placeholder="e.g. Red, Blue, Yellow"
                                       value="@(ev != null ? ev.Label : "")"
                                       class="variant-text-input" />
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ══════════════ RIGHT: DETAILS + PRICING ══════════════ -->
        <div class="ap-right">

            <!-- Product Details -->
            <div class="form-section">
                <div class="form-section-title">
                    <i class="fa-solid fa-tag"></i> Product Details
                </div>
                <div class="form-2col">
                    <div class="form-group">
                        <label><i class="fa-solid fa-pen"></i> Product Name <span class="req">*</span></label>
                        <input type="text" name="Name" id="editProductName" value="@Model.Name" required />
                    </div>
                    <div class="form-group">
                        <label><i class="fa-solid fa-list"></i> Category <span class="req">*</span></label>
                        <select name="Category" required>
                            @foreach (var c in categories)
                            {
                                <option value="@c" @(Model.Category == c ? "selected" : "")>@c</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="form-2col">
                    <div class="form-group">
                        <label><i class="fa-solid fa-dog"></i> Breed Size <span class="req">*</span></label>
                        <select name="BreedSize" required>
                            @foreach (var s in sizes)
                            {
                                <option value="@s" @(Model.BreedSize == s ? "selected" : "")>@s</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label><i class="fa-solid fa-boxes-stacked"></i> Stock <span class="req">*</span></label>
                        <input type="number" name="Stock" min="0" value="@Model.Stock" required />
                    </div>
                </div>
                <div class="form-group">
                    <label><i class="fa-regular fa-message"></i> Description <span class="req">*</span></label>
                    <textarea name="Description" rows="7" required>@Model.Description</textarea>
                </div>
            </div>

            <!-- Pricing -->
            <div class="form-section">
                <div class="form-section-title">
                    <i class="fa-solid fa-peso-sign"></i> Pricing
                </div>
                <div class="form-2col" style="margin-bottom:.75rem;">
                    <div class="form-group">
                        <label><i class="fa-solid fa-peso-sign"></i> Selling Price (&#8369;) <span class="req">*</span></label>
                        <input type="number" name="Price" step="0.01" min="0" value="@Model.Price" required />
                    </div>
                    <div class="form-group">
                        <label>
                            <i class="fa-solid fa-percent"></i> Original Price (&#8369;)
                            <span style="font-size:10px;font-weight:400;color:var(--text-light);">&mdash; blank if not on sale</span>
                        </label>
                        <input type="number" name="OriginalPrice" step="0.01" min="0"
                               value="@(Model.OriginalPrice.HasValue ? Model.OriginalPrice.Value.ToString() : "")" />
                    </div>
                </div>
                <div style="padding:.75rem 1rem;background:rgba(129,166,198,0.08);border-radius:var(--radius-sm);border:1px solid rgba(129,166,198,0.2);font-size:12px;color:var(--text-mid);display:flex;align-items:center;gap:8px;">
                    <i class="fa-solid fa-circle-info" style="color:var(--blue);flex-shrink:0;"></i>
                    If <strong style="margin:0 3px;">Original Price</strong> is higher than <strong style="margin:0 3px;">Selling Price</strong>, a
                    <span style="background:rgba(232,93,93,0.15);color:#c94040;font-size:10px;font-weight:700;padding:2px 8px;border-radius:50px;margin-left:3px;">SALE</span> badge will appear.
                </div>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <button type="button" class="btn-primary" style="padding:11px 28px;font-size:13px;"
                        onclick="openSaveModal()">
                    <i class="fa-solid fa-floppy-disk"></i> Save Changes
                </button>
                <a href="@Url.Action("Products","Admin")" class="btn-outline" style="padding:11px 28px;font-size:13px;">
                    Cancel
                </a>
            </div>

        </div>
    </div>
</form>

<!-- ── SAVE CONFIRMATION MODAL ── -->
<div id="saveModal" class="pc-modal-overlay">
    <div class="pc-modal-box">
        <div class="pc-modal-icon" style="background:rgba(129,166,198,.12);">
            <i class="fa-solid fa-floppy-disk" style="color:var(--blue);"></i>
        </div>
        <div class="pc-modal-title">Save Changes?</div>
        <div class="pc-modal-body" id="saveModalText"></div>
        <div class="pc-modal-btns">
            <button class="pc-modal-cancel" onclick="closeSaveModal()">Cancel</button>
            <button class="pc-modal-confirm-blue" onclick="submitEditForm()">
                <i class="fa-solid fa-floppy-disk"></i> Save Changes
            </button>
        </div>
    </div>
</div>

@section scripts {
    <script>
        function previewMainEdit(input) {
            if (!input.files || !input.files[0]) return;
            var reader = new FileReader();
            reader.onload = function (e) {
                var preview = document.getElementById("editImgPreview0");
                var icon    = document.getElementById("editImgIcon0");
                preview.src = e.target.result;
                preview.style.display = "block";
                if (icon) icon.style.display = "none";
                document.getElementById("editImgPath0").value = e.target.result;
                document.getElementById("editImg-filename0").textContent = input.files[0].name;
            };
            reader.readAsDataURL(input.files[0]);
        }

        function previewEditVariant(input, slot) {
            if (!input.files || !input.files[0]) return;
            var reader = new FileReader();
            reader.onload = function (e) {
                var dataUrl = e.target.result;
                var preview = document.getElementById("evPreview" + slot);
                var icon    = document.getElementById("evIcon"    + slot);
                preview.src = dataUrl;
                preview.style.display = "block";
                if (icon) icon.style.display = "none";
                document.getElementById("evPath" + slot).value = dataUrl;
            };
            reader.readAsDataURL(input.files[0]);
        }

        // ── Save modal ──
        function openSaveModal() {
            var name = document.getElementById('editProductName').value.trim() || 'this product';
            document.getElementById('saveModalText').textContent =
                'Are you sure you want to save changes to "' + name + '"?';
            document.getElementById('saveModal').style.display = 'flex';
        }
        function closeSaveModal() {
            document.getElementById('saveModal').style.display = 'none';
        }
        function submitEditForm() {
            document.getElementById('editProductForm').submit();
        }
        document.getElementById('saveModal').addEventListener('click', function(e) {
            if (e.target === this) closeSaveModal();
        });
    </script>
}
