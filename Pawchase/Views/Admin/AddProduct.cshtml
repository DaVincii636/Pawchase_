@{
    ViewBag.Title = "Add Product";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    var categories = new[] { "Treats", "Toys", "Accessories", "Health", "Others" };
    var sizes      = new[] { "Small", "Medium", "Large", "All" };
}
<style>
.add-product-wrap { max-width:820px; }
.form-section { background:var(--white); border-radius:var(--radius-lg); border:1.5px solid var(--border); padding:1.8rem; box-shadow:var(--shadow-card); margin-bottom:1.2rem; }
.form-section-title { font-size:13px; font-weight:700; color:var(--text); margin-bottom:1.4rem; padding-bottom:.75rem; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:8px; }
.form-section-title i { color:var(--blue); }
.img-upload-box { width:100%; height:150px; background:linear-gradient(145deg,var(--peach),#eedfd0); border-radius:12px; border:2px dashed rgba(129,166,198,.4); display:flex; align-items:center; justify-content:center; cursor:pointer; overflow:hidden; transition:border-color .2s; margin-bottom:12px; }
.img-upload-box:hover { border-color:var(--blue); }
.img-upload-box img { max-height:150px; max-width:100%; display:none; object-fit:contain; border-radius:10px; }
.img-upload-box .placeholder { text-align:center; color:var(--blue-dark); pointer-events:none; }
.img-upload-box .placeholder i { font-size:2.2rem; display:block; margin-bottom:.5rem; }
.img-upload-box .placeholder span { font-size:12px; font-weight:600; display:block; }
.img-upload-box .placeholder small { font-size:10px; color:var(--text-light); }
.form-2col { display:grid; grid-template-columns:1fr 1fr; gap:1.2rem; margin-bottom:1.2rem; }
.form-group { display:flex; flex-direction:column; gap:5px; }
.form-group label { font-size:12px; font-weight:700; color:var(--text-mid); }
.form-group input,.form-group select,.form-group textarea { padding:11px 14px; border:1.5px solid var(--border); border-radius:var(--radius-sm); font-size:13px; font-family:'Poppins',sans-serif; outline:none; transition:border-color .2s,box-shadow .2s; background:var(--white); color:var(--text); }
.form-group input:focus,.form-group select:focus,.form-group textarea:focus { border-color:var(--blue); box-shadow:0 0 0 3px rgba(129,166,198,.15); }
.req { color:#e05555; }
#discount-preview { display:none; margin-top:.6rem; padding:8px 12px; background:rgba(129,166,198,.1); border-radius:8px; border:1px solid rgba(129,166,198,.25); font-size:12px; color:var(--blue-dark); font-weight:600; }
</style>

<div class="admin-page-header">
    <h1>Add New Product</h1>
    <a href="@Url.Action("Products","Admin")" class="btn-outline" style="padding:8px 16px;font-size:12px"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

<form method="post" action="@Url.Action("AddProduct","Admin")" class="add-product-wrap">
    @Html.AntiForgeryToken()

    <div class="form-section">
        <div class="form-section-title"><i class="fa-regular fa-image"></i> Product Images</div>

        <!-- Main Image -->
        <label style="font-size:12px;font-weight:700;color:var(--text-mid);display:block;margin-bottom:6px">
            Main Image <span class="req">*</span>
        </label>
        <div class="img-upload-box" id="imgBox0" onclick="document.getElementById('imgFile0').click()">
            <img id="imgPreview0" src="" alt="Preview" style="display:none"/>
            <div class="placeholder" id="imgIcon0">
                <i class="fa-regular fa-image"></i>
                <span>Click to upload main image</span>
                <small>PNG, JPG up to 5MB</small>
            </div>
        </div>
        <input type="file" id="imgFile0" accept="image/*" style="display:none" onchange="previewImg(this,0)"/>
        <input type="hidden" name="ImageUrl" id="imgPath0" value="/Content/images/products/placeholder.png"/>
        <p id="img-filename0" style="font-size:11px;color:var(--text-light);margin-top:4px;margin-bottom:1.2rem"></p>

        <!-- Color Variants -->
        <div style="border-top:1px solid var(--border);padding-top:1.2rem;margin-top:.5rem">
            <label style="font-size:12px;font-weight:700;color:var(--text-mid);display:block;margin-bottom:8px">
                Color / Style Variants <span style="font-size:10px;font-weight:400;color:var(--text-light)">&mdash; optional, up to 4</span>
            </label>
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:.75rem">
                @for (int vi = 1; vi <= 4; vi++) {
                <div>
                    <div class="img-upload-box" style="height:90px;margin-bottom:6px" onclick="document.getElementById('vFile@(vi)').click()">
                        <img id="imgPreview@vi" src="" alt="" style="display:none;max-height:88px"/>
                        <div class="placeholder" id="imgIcon@vi" style="padding:.4rem">
                            <i class="fa-solid fa-plus" style="font-size:1.1rem"></i>
                            <span style="font-size:10px">Variant @vi</span>
                        </div>
                    </div>
                    <input type="file" id="vFile@vi" accept="image/*" style="display:none" onchange="previewImg(this,@vi)"/>
                    <input type="text" name="VariantLabels" placeholder="e.g. Red, Blue"
                           style="width:100%;padding:5px 8px;border:1.5px solid var(--border);border-radius:6px;font-size:11px;font-family:Poppins,sans-serif;box-sizing:border-box;background:var(--white);color:var(--text)"/>
                </div>
                }
            </div>
        </div>
    </div>

    <div class="form-section">
        <div class="form-section-title"><i class="fa-solid fa-tag"></i> Product Details</div>
        <div class="form-2col">
            <div class="form-group"><label>Product Name <span class="req">*</span></label><input type="text" name="Name" placeholder="e.g. Premium Chicken Treats" required/></div>
            <div class="form-group"><label>Category <span class="req">*</span></label>
                <select name="Category" required><option value="">-- Select --</option>
                @foreach (var c in categories) { <option value="@c">@c</option> }
                </select>
            </div>
        </div>
        <div class="form-2col">
            <div class="form-group"><label>Breed Size <span class="req">*</span></label>
                <select name="BreedSize" required><option value="">-- Select --</option>
                @foreach (var s in sizes) { <option value="@s">@s</option> }
                </select>
            </div>
            <div class="form-group"><label>Stock <span class="req">*</span></label><input type="number" name="Stock" min="0" placeholder="50" required/></div>
        </div>
        <div class="form-group"><label>Description <span class="req">*</span></label><textarea name="Description" rows="4" placeholder="Brief product description..." required></textarea></div>
    </div>

    <div class="form-section">
        <div class="form-section-title"><i class="fa-solid fa-peso-sign"></i> Pricing</div>
        <div class="form-2col">
            <div class="form-group"><label>Sale Price (&#8369;) <span class="req">*</span></label><input type="number" id="f-price" name="Price" step="0.01" min="0" placeholder="e.g. 299.00" required oninput="calcDiscount()"/></div>
            <div class="form-group">
                <label>Original Price (&#8369;) <span style="font-size:10px;font-weight:400;color:var(--text-light)">&mdash; blank if not on sale</span></label>
                <input type="number" id="f-orig" name="OriginalPrice" step="0.01" min="0" placeholder="e.g. 399.00" oninput="calcDiscount()"/>
            </div>
        </div>
        <div id="discount-preview"><i class="fa-solid fa-tag"></i> <span id="discount-text"></span></div>
    </div>

    <div style="display:flex;gap:10px;padding:.5rem 0">
        <button type="submit" class="btn-primary" style="padding:11px 26px;font-size:13px"><i class="fa-solid fa-plus"></i> Add Product</button>
        <a href="@Url.Action("Products","Admin")" class="btn-outline" style="padding:11px 26px;font-size:13px">Cancel</a>
    </div>
</form>



@section scripts {
<script>
function previewImg(input, slot) {
    if (!input.files || !input.files[0]) return;
    var reader = new FileReader();
    reader.onload = function(e) {
        var preview = document.getElementById("imgPreview" + slot);
        var icon    = document.getElementById("imgIcon" + slot);
        preview.src = e.target.result;
        preview.style.display = "block";
        if (icon) icon.style.display = "none";
        if (slot === 0) {
            document.getElementById("imgPath0").value = "/Content/images/products/" + input.files[0].name;
            document.getElementById("img-filename0").textContent = input.files[0].name;
        }
    };
    reader.readAsDataURL(input.files[0]);
}
function calcDiscount() {
    var price = parseFloat(document.getElementById("f-price").value);
    var orig  = parseFloat(document.getElementById("f-orig").value);
    var preview = document.getElementById("discount-preview");
    var text    = document.getElementById("discount-text");
    if (price > 0 && orig > price) {
        var pct = Math.round((orig - price) / orig * 100);
        preview.style.display = "block";
        text.textContent = pct + "% OFF - customers will see ₱" + price.toFixed(2) + " crossed from ₱" + orig.toFixed(2);
    } else {
        preview.style.display = "none";
    }
}
</script>
}