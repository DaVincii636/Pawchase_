@{
    ViewBag.Title = "Add Product";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    var categories = new[] { "Food & Treats", "Accessories & Apparel", "Care & Hygiene", "Toys", "Health", "Others" };
    var sizes = new[] { "Small", "Medium", "Large", "All" };
}
<style>
    /* ── TWO-COLUMN GRID ─────────────────────────── */
    .ap-grid {
        display: grid;
        grid-template-columns: 420px 1fr;
        gap: 1.2rem;
        align-items: start;
    }

    .ap-left {
        display: flex;
        flex-direction: column;
    }

    .ap-right {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    /* ── CARD ────────────────────────────────────── */
    .form-section {
        background: var(--white);
        border-radius: var(--radius-lg);
        border: 1.5px solid var(--border);
        padding: 1.8rem;
        box-shadow: var(--shadow-card);
    }

    .form-section-title {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 1.2rem;
        padding-bottom: .75rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .form-section-title i {
            color: var(--blue);
        }

    /* ── MAIN IMAGE UPLOAD ───────────────────────── */
    .main-img-label {
        font-size: 12px;
        font-weight: 700;
        color: var(--text-mid);
        display: block;
        margin-bottom: 6px;
    }

    .main-img-box {
        width: 100%;
        height: 200px;
        background: linear-gradient(145deg, var(--peach), #eedfd0);
        border-radius: 12px;
        border: 2px dashed rgba(129,166,198,.45);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        overflow: hidden;
        transition: border-color .2s;
        margin-bottom: 6px;
        box-sizing: border-box;
    }

        .main-img-box:hover {
            border-color: var(--blue);
        }

        .main-img-box img {
            max-height: 198px;
            max-width: 100%;
            display: none;
            object-fit: contain;
            border-radius: 10px;
        }

    .upload-placeholder {
        text-align: center;
        color: var(--blue-dark);
        pointer-events: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
    }

        .upload-placeholder .up-icon-wrap {
            width: 56px;
            height: 56px;
            background: rgba(129,166,198,.18);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .upload-placeholder i {
            font-size: 1.6rem;
            color: var(--blue);
        }

        .upload-placeholder span {
            font-size: 12px;
            font-weight: 700;
            color: var(--text);
        }

        .upload-placeholder small {
            font-size: 10px;
            color: var(--text-light);
        }

    /* ── VARIANTS SECTION ────────────────────────── */
    .variants-wrap {
        border-top: 1px solid var(--border);
        padding-top: 1.2rem;
        margin-top: 1.2rem;
    }

    .variants-label {
        font-size: 12px;
        font-weight: 700;
        color: var(--text-mid);
        display: block;
        margin-bottom: .75rem;
    }

        .variants-label span {
            font-size: 10px;
            font-weight: 400;
            color: var(--text-light);
        }

    .variants-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .7rem;
    }

    .variant-item {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .variant-img-box {
        width: 100%;
        aspect-ratio: 1 / 1;
        background: linear-gradient(145deg, var(--peach), #eedfd0);
        border-radius: 10px;
        border: 2px dashed rgba(129,166,198,.4);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        overflow: hidden;
        transition: border-color .2s;
    }

        .variant-img-box:hover {
            border-color: var(--blue);
        }

        .variant-img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
            pointer-events: none;
        }

    .variant-placeholder {
        text-align: center;
        color: var(--blue-dark);
        pointer-events: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
    }

        .variant-placeholder i {
            font-size: 1.2rem;
        }

        .variant-placeholder span {
            font-size: 10px;
            font-weight: 600;
        }

    .variant-text-input {
        width: 100%;
        padding: 6px 8px;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        font-size: 10px;
        font-family: 'Poppins', sans-serif;
        box-sizing: border-box;
        background: var(--white);
        color: var(--text);
        outline: none;
        transition: border-color .2s;
    }

        .variant-text-input:focus {
            border-color: var(--blue);
        }

    /* ── FORM FIELDS ─────────────────────────────── */
    .form-2col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .form-group label {
            font-size: 12px;
            font-weight: 700;
            color: var(--text-mid);
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            padding: 10px 13px;
            border: 1.5px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-family: 'Poppins', sans-serif;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
            background: var(--white);
            color: var(--text);
            width: 100%;
            box-sizing: border-box;
        }

            .form-group input:focus,
            .form-group select:focus,
            .form-group textarea:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 3px rgba(129,166,198,.15);
            }

        .form-group textarea {
            resize: vertical;
        }

    .req {
        color: #e05555;
    }

    /* ── DISCOUNT PREVIEW ────────────────────────── */
    #discount-preview {
        display: none;
        margin-top: .6rem;
        padding: 10px 14px;
        background: rgba(224,85,85,.07);
        border-radius: 8px;
        border: 1.5px solid rgba(224,85,85,.2);
        font-size: 12px;
        color: #c0392b;
        font-weight: 700;
    }

        #discount-preview i {
            margin-right: 4px;
        }

    /* ── ACTION BUTTONS ──────────────────────────── */
    .form-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-start;
    }

    /* ── RESPONSIVE ──────────────────────────────── */
    @@media (max-width: 960px) {
        .ap-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="admin-page-header">
    <h1>Add New Product</h1>
    <a href="@Url.Action("Products","Admin")" class="btn-outline" style="padding:8px 16px;font-size:12px">
        <i class="fa-solid fa-arrow-left"></i> Back
    </a>
</div>

<form method="post" action="@Url.Action("AddProduct","Admin")">
    @Html.AntiForgeryToken()

    <div class="ap-grid">

        <!-- ══════════════ LEFT: IMAGES ══════════════ -->
        <div class="ap-left">
            <div class="form-section">
                <div class="form-section-title">
                    <i class="fa-regular fa-image"></i> Product Images
                </div>

                <!-- Main Image -->
                <label class="main-img-label">
                    Main Image <span class="req">*</span>
                </label>
                <input type="file" id="imgFile0" accept="image/*" style="display:none" onchange="previewImg(this,0)" />
                <div onclick="document.getElementById('imgFile0').click()">
                    <div class="main-img-box" id="imgBox0">
                        <img id="imgPreview0" src="" alt="Preview" />
                        <div class="upload-placeholder" id="imgIcon0">
                            <div class="up-icon-wrap">
                                <i class="fa-regular fa-image"></i>
                            </div>
                            <span>Click to Upload Image</span>
                            <small>PNG, JPG up to 5MB</small>
                        </div>
                    </div>
                </div>
                <input type="hidden" name="ImageUrl" id="imgPath0" value="/Content/images/products/placeholder.png" />
                <p id="img-filename0" style="font-size:11px;color:var(--text-light);margin-top:2px;margin-bottom:0"></p>

                <!-- Variants -->
                <div class="variants-wrap">
                    <label class="variants-label">
                        Product Variants <span>&mdash; optional, up to 6</span>
                    </label>
                    <div class="variants-grid">
                        @for (int vi = 1; vi <= 6; vi++)
                        {
                            <div class="variant-item">
                                <input type="file" id="vFile@(vi)" accept="image/*" style="display:none"
                                       onchange="previewVariant(this,@(vi))" />
                                <div class="variant-img-box"
                                     onclick="document.getElementById('vFile@(vi)').click()"
                                     id="vBox@(vi)">
                                    <img id="imgPreview@(vi)" src="" alt="" />
                                    <div class="variant-placeholder" id="imgIcon@(vi)">
                                        <i class="fa-solid fa-plus"></i>
                                        <span>Add Variant</span>
                                    </div>
                                </div>
                                <input type="hidden" id="vPath@(vi)" name="VariantImagePaths" value="" />
                                <input type="text" id="vLabel@(vi)" name="VariantLabels"
                                       placeholder="e.g. Red, Blue, Yellow"
                                       class="variant-text-input" />
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ══════════════ RIGHT: DETAILS + PRICING ══════════════ -->
        <div class="ap-right">

            <!-- Product Details -->
            <div class="form-section">
                <div class="form-section-title">
                    <i class="fa-solid fa-tag"></i> Product Details
                </div>
                <div class="form-2col">
                    <div class="form-group">
                        <label>Product Name <span class="req">*</span></label>
                        <input type="text" name="Name" placeholder="e.g. Premium Chicken Treats" required />
                    </div>
                    <div class="form-group">
                        <label>Category <span class="req">*</span></label>
                        <select name="Category" required>
                            <option value="">--- Select ---</option>
                            @foreach (var c in categories)
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="form-2col">
                    <div class="form-group">
                        <label>Breed Size <span class="req">*</span></label>
                        <select name="BreedSize" required>
                            <option value="">--- Select ---</option>
                            @foreach (var s in sizes)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Stock <span class="req">*</span></label>
                        <input type="number" name="Stock" min="0" placeholder="50" required />
                    </div>
                </div>
                <div class="form-group">
                    <label>Description <span class="req">*</span></label>
                    <textarea name="Description" rows="7" placeholder="Brief product description..." required></textarea>
                </div>
            </div>

            <!-- Pricing -->
            <div class="form-section">
                <div class="form-section-title">
                    <i class="fa-solid fa-peso-sign"></i> Pricing
                </div>
                <div class="form-2col" style="margin-bottom:0">
                    <div class="form-group">
                        <label>Selling Price (&#8369;) <span class="req">*</span></label>
                        <input type="number" id="f-price" name="Price" step="0.01" min="0"
                               placeholder="e.g. 299.00" required oninput="calcDiscount()" />
                    </div>
                    <div class="form-group">
                        <label>
                            Original Price (&#8369;)
                            <span style="font-size:10px;font-weight:400;color:var(--text-light)">&mdash; blank if not on sale</span>
                        </label>
                        <input type="number" id="f-orig" name="OriginalPrice" step="0.01" min="0"
                               placeholder="e.g. 399.00" oninput="calcDiscount()" />
                    </div>
                </div>
                <div id="discount-preview">
                    <i class="fa-solid fa-tag"></i><span id="discount-text"></span>
                </div>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <button type="submit" class="btn-primary" style="padding:11px 28px;font-size:13px">
                    <i class="fa-solid fa-plus"></i> Add Product
                </button>
                <a href="@Url.Action("Products","Admin")" class="btn-outline" style="padding:11px 28px;font-size:13px">
                    Cancel
                </a>
            </div>

        </div>
    </div>
</form>

@section scripts {
    <script>
        function previewImg(input, slot) {
            if (!input.files || !input.files[0]) return;
            var reader = new FileReader();
            reader.onload = function (e) {
                var preview = document.getElementById("imgPreview" + slot);
                var icon = document.getElementById("imgIcon" + slot);
                preview.src = e.target.result;
                preview.style.display = "block";
                if (icon) icon.style.display = "none";
                if (slot === 0) {
                    document.getElementById("imgPath0").value = e.target.result;
                    document.getElementById("img-filename0").textContent = input.files[0].name;
                }
            };
            reader.readAsDataURL(input.files[0]);
        }

        function previewVariant(input, slot) {
            if (!input.files || !input.files[0]) return;
            var reader = new FileReader();
            reader.onload = function (e) {
                var dataUrl = e.target.result;
                var preview = document.getElementById("imgPreview" + slot);
                var icon = document.getElementById("imgIcon" + slot);
                preview.src = dataUrl;
                preview.style.display = "block";
                if (icon) icon.style.display = "none";
                document.getElementById("vPath" + slot).value = dataUrl;
            };
            reader.readAsDataURL(input.files[0]);
        }

        function calcDiscount() {
            var price = parseFloat(document.getElementById("f-price").value);
            var orig = parseFloat(document.getElementById("f-orig").value);
            var preview = document.getElementById("discount-preview");
            var text = document.getElementById("discount-text");
            if (price > 0 && orig > price) {
                var pct = Math.round((orig - price) / orig * 100);
                preview.style.display = "block";
                text.textContent = " " + pct + "% OFF \u2014 SALE badge will appear on product";
            } else {
                preview.style.display = "none";
            }
        }
    </script>
}