@{
    ViewBag.Title = "Add Product";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    var categories = new[] { "Food & Treats", "Accessories & Apparel", "Care & Hygiene", "Toys", "Health", "Others" };
    var sizes = new[] { "Small", "Medium", "Large", "All" };
}
<style>
    /* ── TWO-COLUMN GRID ─────────────────────────── */
    .ap-grid {
        display: grid;
        grid-template-columns: 420px 1fr;
        gap: 1.2rem;
        align-items: start;
    }
    .ap-left  { display: flex; flex-direction: column; }
    .ap-right { display: flex; flex-direction: column; gap: 1.2rem; }

    /* ── CARD ────────────────────────────────────── */
    .form-section {
        background: var(--white);
        border-radius: var(--radius-lg);
        border: 1.5px solid var(--border);
        padding: 1.8rem;
        box-shadow: var(--shadow-card);
    }
    .form-section-title {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 1.2rem;
        padding-bottom: .75rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .form-section-title i { color: var(--blue); }

    /* ── MAIN IMAGE UPLOAD ───────────────────────── */
    .main-img-label {
        font-size: 12px;
        font-weight: 700;
        color: var(--text-mid);
        display: block;
        margin-bottom: 6px;
    }
    .main-img-box {
        width: 100%;
        height: 200px;
        background: linear-gradient(145deg, var(--peach), #eedfd0);
        border-radius: 12px;
        border: 2px dashed rgba(129,166,198,.45);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        overflow: hidden;
        transition: border-color .2s;
        margin-bottom: 6px;
        box-sizing: border-box;
    }
    .main-img-box:hover { border-color: var(--blue); }
    .main-img-box img {
        max-height: 198px;
        max-width: 100%;
        display: none;
        object-fit: contain;
        border-radius: 10px;
    }
    .upload-placeholder {
        text-align: center;
        color: var(--blue-dark);
        pointer-events: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
    }
    .upload-placeholder .up-icon-wrap {
        width: 56px; height: 56px;
        background: rgba(129,166,198,.18);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
    }
    .upload-placeholder i    { font-size: 1.6rem; color: var(--blue); }
    .upload-placeholder span { font-size: 12px; font-weight: 700; color: var(--text); }
    .upload-placeholder small{ font-size: 10px; color: var(--text-light); }

    /* ── VARIANTS SECTION ────────────────────────── */
    .variants-wrap {
        border-top: 1px solid var(--border);
        padding-top: 1.2rem;
        margin-top: 1.2rem;
    }
    .variants-label {
        font-size: 12px;
        font-weight: 700;
        color: var(--text-mid);
        display: block;
        margin-bottom: .75rem;
    }
    .variants-label span {
        font-size: 10px;
        font-weight: 400;
        color: var(--text-light);
    }
    .variants-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .7rem;
    }
    .variant-item { display: flex; flex-direction: column; gap: 5px; }
    .variant-item.variant-hidden { display: none; }
    .extra-img-item { display: flex; flex-direction: column; align-items: center; gap: 4px; }
    .extra-img-item.extra-img-hidden { display: none; }
    .variant-img-box {
        width: 100%;
        aspect-ratio: 1 / 1;
        background: linear-gradient(145deg, var(--peach), #eedfd0);
        border-radius: 10px;
        border: 2px dashed rgba(129,166,198,.4);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        overflow: hidden;
        transition: border-color .2s;
    }
    .variant-img-box:hover { border-color: var(--blue); }
    .variant-img-box img {
        width: 100%; height: 100%;
        object-fit: cover;
        display: none;
        pointer-events: none;
    }
    .variant-placeholder {
        text-align: center;
        color: var(--blue-dark);
        pointer-events: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
    }
    .variant-placeholder i    { font-size: 1.2rem; }
    .variant-placeholder span { font-size: 10px; font-weight: 600; }
    .variant-text-input {
        width: 100%;
        padding: 6px 8px;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        font-size: 10px;
        font-family: 'Poppins', sans-serif;
        box-sizing: border-box;
        background: var(--white);
        color: var(--text);
        outline: none;
        transition: border-color .2s;
    }
    .variant-text-input:focus { border-color: var(--blue); }
    .variant-price-input { display: none; }
    .variant-item.variant-active .variant-price-input { display: block; }
    .variant-remove-btn {
        display: none;
        align-items: center;
        justify-content: center;
        gap: 5px;
        width: 100%;
        padding: 6px 8px;
        border: 1.5px solid rgba(224,85,85,.25);
        border-radius: 6px;
        background: rgba(224,85,85,.06);
        color: #c0392b;
        cursor: pointer;
        font-size: 10px;
        font-weight: 700;
        font-family: 'Poppins', sans-serif;
        transition: all .18s;
    }
    .variant-remove-btn:hover {
        background: #e05555;
        border-color: #e05555;
        color: #fff;
    }

    /* ── FORM FIELDS ─────────────────────────────── */
    .form-2col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-group label {
        font-size: 12px;
        font-weight: 700;
        color: var(--text-mid);
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
        padding: 10px 13px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: 13px;
        font-family: 'Poppins', sans-serif;
        outline: none;
        transition: border-color .2s, box-shadow .2s;
        background: var(--white);
        color: var(--text);
        width: 100%;
        box-sizing: border-box;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
        border-color: var(--blue);
        box-shadow: 0 0 0 3px rgba(129,166,198,.15);
    }
    .form-group textarea { resize: vertical; }
    .req { color: #e05555; }

    /* ── DISCOUNT PREVIEW ────────────────────────── */
    #discount-preview {
        display: none;
        margin-top: .6rem;
        padding: 10px 14px;
        background: rgba(224,85,85,.07);
        border-radius: 8px;
        border: 1.5px solid rgba(224,85,85,.2);
        font-size: 12px;
        color: #c0392b;
        font-weight: 700;
    }
    #discount-preview i { margin-right: 4px; }

    /* ── ACTION BUTTONS ──────────────────────────── */
    .form-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-start;
    }

    /* ── RESPONSIVE ──────────────────────────────── */
    @@media (max-width: 960px) {
        .ap-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="admin-page-header">
    <h1>Add New Product</h1>
    <a href="@Url.Action("Products","Admin")" class="btn-outline" style="padding:8px 16px;font-size:12px">
        <i class="fa-solid fa-arrow-left"></i> Back
    </a>
</div>

<form method="post" action="@Url.Action("AddProduct","Admin")" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="ap-grid">

        <!-- ══════════════ LEFT: IMAGES ══════════════ -->
        <div class="ap-left">
            <div class="form-section">
                <div class="form-section-title">
                    <i class="fa-regular fa-image"></i> Product Images
                </div>

                <!-- Main Image -->
                <label class="main-img-label">
                    Main Image <span class="req">*</span>
                </label>
                <input type="file" id="imgFile0" name="MainImageFile" accept="image/*" style="display:none" onchange="previewImg(this,0)" />
                <div onclick="document.getElementById('imgFile0').click()">
                    <div class="main-img-box" id="imgBox0">
                        <img id="imgPreview0" src="" alt="Preview" />
                        <div class="upload-placeholder" id="imgIcon0">
                            <div class="up-icon-wrap">
                                <i class="fa-regular fa-image"></i>
                            </div>
                            <span>Click to Upload Image</span>
                            <small>PNG, JPG up to 5MB</small>
                        </div>
                    </div>
                </div>
                <input type="hidden" name="ImageUrl" id="imgPath0" value="/Content/images/products/placeholder.png" />
                <p id="img-filename0" style="font-size:11px;color:var(--text-light);margin-top:2px;margin-bottom:0"></p>

                <!-- Additional Main Images -->
                <div style="margin-top:14px;">
                    <label class="variants-label" style="margin-bottom:8px;display:block;">
                        Additional Images <span>&mdash; optional, up to 4 extra photos for the carousel</span>
                    </label>
                    <div style="display:flex;gap:10px;flex-wrap:wrap;" id="extraImgsRow">
                        @for (int ei = 1; ei <= 4; ei++)
                        {
                            <div id="extraImgItem@(ei)" class="extra-img-item @(ei > 1 ? "extra-img-hidden" : "")">
                                <input type="file" id="extraFile@(ei)" name="AdditionalImageFile@(ei)" accept="image/*" style="display:none" onchange="previewExtraImg(this,@(ei))" />
                                <div onclick="document.getElementById('extraFile@(ei)').click()" style="cursor:pointer;position:relative;">
                                    <div style="width:80px;height:80px;border-radius:10px;border:2px dashed var(--border);background:var(--peach-light,#fdf6f1);display:flex;align-items:center;justify-content:center;overflow:hidden;" id="extraBox@(ei)">
                                        <img id="extraPreview@(ei)" src="" alt="" style="display:none;width:100%;height:100%;object-fit:cover;" />
                                        <i class="fa-regular fa-image" style="font-size:1.5rem;color:var(--text-light);" id="extraIcon@(ei)"></i>
                                    </div>
                                    <button type="button" id="extraClear@(ei)" onclick="clearExtraImg(@(ei),event)" style="display:none;position:absolute;top:2px;right:2px;width:18px;height:18px;border-radius:50%;background:#e05555;border:none;color:#fff;cursor:pointer;font-size:9px;line-height:1;z-index:5;align-items:center;justify-content:center;">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </div>
                                <input type="hidden" id="extraPath@(ei)" name="AdditionalImagePaths" value="" />
                                <span style="font-size:10px;color:var(--text-light);">Photo @(ei)</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Variants -->
                <div class="variants-wrap">
                    <label class="variants-label">
                        Product Variants <span>&mdash; optional, up to 6</span>
                    </label>
                    <div class="variants-grid">
                        @for (int vi = 1; vi <= 6; vi++)
                        {
                            <div class="variant-item @(vi == 1 ? "" : "variant-hidden")" id="vItem@(vi)">
                                <input type="file" id="vFile@(vi)" name="VariantImageFile@(vi)" accept="image/*" style="display:none"
                                       onchange="previewVariant(this,@(vi))" />
                                <div style="position:relative;">
                                    <div class="variant-img-box"
                                         onclick="document.getElementById('vFile@(vi)').click()"
                                         id="vBox@(vi)">
                                        <img id="imgPreview@(vi)" src="" alt="" style="display:none;width:100%;height:100%;object-fit:cover;" />
                                        <div class="variant-placeholder" id="imgIcon@(vi)">
                                            <i class="fa-solid fa-plus"></i>
                                            <span>Add Variant</span>
                                        </div>
                                    </div>
                                    <button type="button" id="vClear@(vi)"
                                            onclick="clearVariant(@(vi))"
                                            style="display:none;position:absolute;top:4px;right:4px;width:20px;height:20px;border-radius:50%;background:#e05555;border:none;color:#fff;cursor:pointer;font-size:10px;line-height:1;z-index:5;">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </div>
                                <input type="hidden" id="vPath@(vi)" name="VariantImagePaths" value="" />
                                 <input type="text" id="vLabel@(vi)" name="VariantLabels"
                                        placeholder="e.g. Red, Blue"
                                        oninput="updateVariantRemove(@(vi))"
                                        class="variant-text-input" />
                                  <input type="number" id="vStock@(vi)" name="VariantStocks"
                                         placeholder="Stock" min="0"
                                         oninput="updateVariantRemove(@(vi)); syncVariantStock()"
                                         class="variant-text-input" />
                                  <input type="number" id="vPrice@(vi)" name="VariantPrices"
                                         placeholder="Variant price (optional)" min="0" step="0.01"
                                         oninput="updateVariantRemove(@(vi))"
                                         class="variant-text-input variant-price-input" />
                                <button type="button" id="vRemove@(vi)" class="variant-remove-btn"
                                        onclick="clearVariant(@(vi))">
                                    <i class="fa-solid fa-trash"></i> Remove Variant
                                </button>
                             </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ══════════════ RIGHT: DETAILS + PRICING ══════════════ -->
        <div class="ap-right">

            <!-- Product Details -->
            <div class="form-section">
                <div class="form-section-title">
                    <i class="fa-solid fa-tag"></i> Product Details
                </div>
                <div class="form-2col">
                    <div class="form-group">
                        <label>Product Name <span class="req">*</span></label>
                        <input type="text" name="Name" placeholder="e.g. Premium Chicken Treats" required />
                    </div>
                    <div class="form-group">
                        <label>Category <span class="req">*</span></label>
                        <select name="Category" required>
                            <option value="">--- Select ---</option>
                            @foreach (var c in categories)
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="form-2col">
                    <div class="form-group">
                        <label>Breed Size <span class="req">*</span></label>
                        <select name="BreedSize" required>
                            <option value="">--- Select ---</option>
                            @foreach (var s in sizes)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Stock <span class="req">*</span></label>
                        <input type="number" id="generalStock" name="Stock" placeholder="Stock" min="0" required />
                    </div>
                </div>
                <div class="form-group">
                    <label>Description <span class="req">*</span></label>
                    <textarea name="Description" rows="7" placeholder="Brief product description..." required></textarea>
                </div>
            </div>

            <!-- Pricing -->
            <div class="form-section">
                <div class="form-section-title">
                    <i class="fa-solid fa-peso-sign"></i> Pricing
                </div>
                <div class="form-2col" style="margin-bottom:0">
                    <div class="form-group">
                        <label>Selling Price (&#8369;) <span class="req">*</span></label>
                        <input type="number" id="f-price" name="Price" step="0.01" min="0"
                               placeholder="e.g. 299.00" required oninput="calcDiscount()" />
                    </div>
                    <div class="form-group">
                        <label>
                            Original Price (&#8369;)
                            <span style="font-size:10px;font-weight:400;color:var(--text-light)">&mdash; blank if not on sale</span>
                        </label>
                        <input type="number" id="f-orig" name="OriginalPrice" step="0.01" min="0"
                               placeholder="e.g. 399.00" oninput="calcDiscount()" />
                    </div>
                </div>
                <div id="discount-preview">
                    <i class="fa-solid fa-tag"></i><span id="discount-text"></span>
                </div>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <button type="submit" class="btn-primary" style="padding:11px 28px;font-size:13px">
                    <i class="fa-solid fa-plus"></i> Add Product
                </button>
                <a href="@Url.Action("Products","Admin")" class="btn-outline" style="padding:11px 28px;font-size:13px">
                    Cancel
                </a>
            </div>

        </div>
    </div>
</form>

@section scripts {
    <script>
        // Resize and compress an image file to a canvas-based JPEG data URL.
        // maxPx caps the longer dimension; quality is JPEG 0-1.
        function compressImage(file, maxPx, quality, callback) {
            var reader = new FileReader();
            reader.onload = function (e) {
                var img = new Image();
                img.onload = function () {
                    var w = img.width, h = img.height;
                    if (w > maxPx || h > maxPx) {
                        if (w >= h) { h = Math.round(h * maxPx / w); w = maxPx; }
                        else        { w = Math.round(w * maxPx / h); h = maxPx; }
                    }
                    var canvas = document.createElement('canvas');
                    canvas.width = w; canvas.height = h;
                    canvas.getContext('2d').drawImage(img, 0, 0, w, h);
                    callback(canvas.toDataURL('image/jpeg', quality));
                };
                img.src = e.target.result;
            };
            reader.readAsDataURL(file);
        }

        function previewImg(input, slot) {
            if (!input.files || !input.files[0]) return;
            compressImage(input.files[0], 1200, 0.82, function (dataUrl) {
                var preview = document.getElementById("imgPreview" + slot);
                var icon    = document.getElementById("imgIcon"    + slot);
                preview.src = dataUrl;
                preview.style.display = "block";
                if (icon) icon.style.display = "none";
                if (slot === 0) {
                    document.getElementById("img-filename0").textContent = input.files[0].name;
                }
            });
        }

        function extraImgSlotHasValue(slot) {
            var file = document.getElementById('extraFile' + slot);
            var path = document.getElementById('extraPath' + slot);
            return (file && file.value) || (path && path.value);
        }

        function refreshExtraImgSlots() {
            for (var i = 1; i <= 4; i++) {
                var item = document.getElementById('extraImgItem' + i);
                if (!item) continue;
                var shouldShow = i === 1 || extraImgSlotHasValue(i) || extraImgSlotHasValue(i - 1);
                item.classList.toggle('extra-img-hidden', !shouldShow);
            }
        }

        function previewExtraImg(input, slot) {
            if (!input.files || !input.files[0]) return;
            compressImage(input.files[0], 1200, 0.82, function (dataUrl) {
                var preview = document.getElementById('extraPreview' + slot);
                var icon    = document.getElementById('extraIcon' + slot);
                var clearBtn = document.getElementById('extraClear' + slot);
                if (preview) { preview.src = dataUrl; preview.style.display = 'block'; }
                if (icon)    icon.style.display = 'none';
                if (clearBtn) clearBtn.style.display = 'flex';
                refreshExtraImgSlots();
            });
        }

        function clearExtraImg(slot, e) {
            if (e) e.stopPropagation();
            var preview  = document.getElementById('extraPreview' + slot);
            var icon     = document.getElementById('extraIcon' + slot);
            var clearBtn = document.getElementById('extraClear' + slot);
            var pathInput = document.getElementById('extraPath' + slot);
            var fileInput = document.getElementById('extraFile' + slot);
            if (preview)  { preview.src = ''; preview.style.display = 'none'; }
            if (icon)     icon.style.display = '';
            if (clearBtn) clearBtn.style.display = 'none';
            if (pathInput) pathInput.value = '';
            if (fileInput) fileInput.value = '';
            refreshExtraImgSlots();
        }

        function variantSlotHasValue(slot) {
            var file = document.getElementById('vFile' + slot);
            var path = document.getElementById('vPath' + slot);
            var label = document.getElementById('vLabel' + slot);
            var stock = document.getElementById('vStock' + slot);
            var price = document.getElementById('vPrice' + slot);
            return (file && file.value) ||
                (path && path.value) ||
                (label && label.value.trim()) ||
                (stock && stock.value.trim()) ||
                (price && price.value.trim());
        }

        function refreshVariantSlots() {
            for (var i = 1; i <= 6; i++) {
                var item = document.getElementById('vItem' + i);
                if (!item) continue;
                var shouldShow = i === 1 || variantSlotHasValue(i) || variantSlotHasValue(i - 1);
                item.classList.toggle('variant-hidden', !shouldShow);
                item.classList.toggle('variant-active', variantSlotHasValue(i));
            }
        }

        function updateVariantRemove(slot) {
            var remove = document.getElementById('vRemove' + slot);
            if (!remove) return;
            var hasValue = variantSlotHasValue(slot);
            remove.style.display = hasValue ? 'inline-flex' : 'none';
            refreshVariantSlots();
        }


        function clearVariant(slot) {
            var fileInput = document.getElementById('vFile' + slot);
            document.getElementById('imgPreview' + slot).src = '';
            document.getElementById('imgPreview' + slot).style.display = 'none';
            document.getElementById('imgIcon' + slot).style.display = 'flex';
            document.getElementById('vPath' + slot).value = '';
            document.getElementById('vLabel' + slot).value = '';
            document.getElementById('vStock' + slot).value = '';
            document.getElementById('vPrice' + slot).value = '';
            if (fileInput) fileInput.value = '';
            document.getElementById('vClear' + slot).style.display = 'none';
            document.getElementById('vRemove' + slot).style.display = 'none';
            refreshVariantSlots();
            syncVariantStock();
        }
        function previewVariant(input, slot) {
            if (!input.files || !input.files[0]) return;
            compressImage(input.files[0], 1200, 0.82, function (dataUrl) {
                var preview = document.getElementById("imgPreview" + slot);
                var icon    = document.getElementById("imgIcon"    + slot);
                preview.src = dataUrl;
                preview.style.display = "block";
                if (icon) icon.style.display = "none";
                document.getElementById('vClear' + slot).style.display = 'block';
                updateVariantRemove(slot);
            });
        }


        // ── Variant stock sync: auto-sum variant stocks → general Stock field ──
        function syncVariantStock() {
            var total = 0;
            var hasAny = false;
            for (var i = 1; i <= 6; i++) {
                var el = document.getElementById('vStock' + i);
                if (el) {
                    var val = parseInt(el.value, 10);
                    if (!isNaN(val) && val > 0) {
                        total += val;
                        hasAny = true;
                    }
                }
            }
            var gs = document.getElementById('generalStock');
            if (!gs) return;
            if (hasAny) {
                gs.value = total;
                gs.readOnly = true;
                gs.style.background = 'var(--peach, #f8ede3)';
                gs.style.color = 'var(--text-mid, #888)';
                gs.title = 'Auto-calculated from variant stocks';
            } else {
                gs.readOnly = false;
                gs.style.background = '';
                gs.style.color = '';
                gs.title = '';
            }
        }
        // Run on page load in case of browser back-fill
        document.addEventListener('DOMContentLoaded', function () {
            for (var i = 1; i <= 6; i++) updateVariantRemove(i);
            refreshVariantSlots();
            syncVariantStock();
        });

        function calcDiscount() {
            var price = parseFloat(document.getElementById("f-price").value);
            var orig  = parseFloat(document.getElementById("f-orig").value);
            var preview = document.getElementById("discount-preview");
            var text    = document.getElementById("discount-text");
            if (price > 0 && orig > price) {
                var pct = Math.round((orig - price) / orig * 100);
                preview.style.display = "block";
                text.textContent = " " + pct + "% OFF \u2014 SALE badge will appear on product";
            } else {
                preview.style.display = "none";
            }
        }
    </script>
}
