<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - PawChase Admin</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet" />
    <link href="@Url.Content("~/Content/css/site.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/css/admin.css")" rel="stylesheet" />
    @RenderSection("styles", required: false)
    <style>
        @* Toast auto-dismiss animation *@
        .admin-toast, .admin-toast-error {
            animation: toastIn .3s ease forwards;
        }
        @@keyframes toastIn {
            from { opacity: 0; transform: translateY(-8px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .admin-toast-error {
            background: rgba(224,85,85,.12);
            border-left: 3px solid #e05555;
            color: #c0392b;
        }
        /* Sidebar logo with image */
        .sidebar-logo-img {
            width: 140px;
            height: auto;
            display: block;
            margin: 0 auto .3rem;
            object-fit: contain;
            filter: brightness(0) invert(1);
        }
    </style>
</head>
<body class="admin-body">
    <aside class="admin-sidebar">
        <div class="sidebar-logo">
            <img src="@Url.Content("~/Content/images/Pawchase.png")" alt="PawChase" class="sidebar-logo-img" />
            <small>Admin Panel</small>
        </div>
        @{
            var action = ViewContext.RouteData.Values["action"].ToString();
        }
        <nav class="sidebar-nav">
            <a href="@Url.Action("Dashboard","Admin")" class="sidebar-link @(action=="Dashboard"?"active":"")">
                <i class="fa-solid fa-gauge-high"></i> Dashboard
            </a>
            <a href="@Url.Action("Products","Admin")" class="sidebar-link @(action=="Products"||action=="AddProduct"||action=="EditProduct"?"active":"")">
                <i class="fa-solid fa-boxes-stacked"></i> Products
                @{
                    var lowStockBadge = Pawchase.Models.MockData.Products.Count(p => !p.IsDeleted && p.Stock == 0);
                    if (lowStockBadge > 0)
                    { <span style="background:#e05555;color:#fff;font-size:9px;font-weight:700;padding:2px 6px;border-radius:50px;margin-left:4px;">@lowStockBadge OOS</span> }
                }
            </a>
            <a href="@Url.Action("Orders","Admin")" class="sidebar-link @(action=="Orders"?"active":"")">
                <i class="fa-solid fa-receipt"></i> Orders
                @{
                    var refundCount = Pawchase.Models.MockData.Orders.Count(o => o.HasRefundRequest);
                    if (refundCount > 0)
                    { <span style="background:#e05555;color:#fff;font-size:9px;font-weight:700;padding:2px 6px;border-radius:50px;margin-left:4px;">@refundCount</span> }
                }
            </a>
            <a href="@Url.Action("FlaggedReviews","Admin")" class="sidebar-link @(action=="FlaggedReviews"?"active":"")">
                <i class="fa-solid fa-flag"></i> Reports
                @{
                    var flaggedCount = Pawchase.Models.MockData.Reviews.Count(r => r.ReportCount > 0);
                    if (flaggedCount > 0)
                    { <span style="background:#e6a520;color:#fff;font-size:9px;font-weight:700;padding:2px 6px;border-radius:50px;margin-left:4px;">@flaggedCount</span> }
                }
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="@Url.Action("Index","Home")" class="sidebar-link" target="_blank">
                <i class="fa-solid fa-store"></i> View Store
            </a>
            <a href="@Url.Action("Login","Admin")" class="sidebar-link">
                <i class="fa-solid fa-shield-halved"></i> Admin Login
            </a>
            <a href="@Url.Action("Logout","Admin")" class="sidebar-link logout">
                <i class="fa-solid fa-right-from-bracket"></i> Logout
            </a>
        </div>
    </aside>

    <div class="admin-main">
        @if (TempData["Success"] != null)
        {
            <div class="admin-toast" id="adminToast">
                <i class="fa-solid fa-circle-check"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="admin-toast admin-toast-error" id="adminToastError">
                <i class="fa-solid fa-triangle-exclamation"></i> @TempData["Error"]
            </div>
        }
        @RenderBody()
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
    <script src="@Url.Content("~/Scripts/admin.js")"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
