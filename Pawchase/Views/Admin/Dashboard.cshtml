@* Dashboard *@
@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    var recentOrders = ViewBag.RecentOrders as List<Pawchase.Models.Order>;
    int lowStockCount   = ViewBag.LowStockCount   != null ? (int)ViewBag.LowStockCount   : 0;
    int outOfStockCount = ViewBag.OutOfStockCount != null ? (int)ViewBag.OutOfStockCount : 0;
}

<style>
    .dash-title { font-size: 1.9rem; font-weight: 900; color: var(--text); }
    .dash-sub   { font-size: 13px; color: var(--text-light); margin-top: 2px; }
    .dash-sub strong { color: var(--text-mid); }

    /* ── STAT CARDS: icon top-center → label → big number ── */
    .stat-cards {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1rem;
        margin: 1.5rem 0;
    }
    .stat-card {
        background: var(--white);
        border-radius: var(--radius-lg);
        padding: 1.6rem 1rem 1.3rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .65rem;
        border: 1.5px solid rgba(255,255,255,.9);
        box-shadow: var(--shadow-card);
        transition: all .2s;
        text-align: center;
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-hover); }
    .sc-icon {
        width: 52px; height: 52px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.35rem;
        flex-shrink: 0;
    }
    .sc-info { display: flex; flex-direction: column; align-items: center; gap: 3px; }
    .sc-info span   { font-size: 11px; color: var(--text-light); white-space: nowrap; }
    .sc-info strong { font-size: 1.55rem; font-weight: 800; color: var(--text); line-height: 1.1; }

    /* ── ALERT BANNERS ── */
    .dash-alert {
        display: flex; align-items: center; gap: 10px;
        padding: 12px 16px; border-radius: var(--radius-sm);
        font-size: 13px; margin-bottom: .75rem;
    }
    .dash-alert.danger  { background:rgba(224,85,85,.08); border:1px solid rgba(224,85,85,.25); color:#c0392b; }
    .dash-alert.warning { background:rgba(230,130,20,.08); border:1px solid rgba(230,130,20,.3); color:#b8610a; }
    .dash-alert a { font-weight:700; text-decoration:underline; margin-left:4px; color:inherit; }

    /* ── RECENT ORDERS ── */
    .recent-card {
        background: var(--white);
        border-radius: var(--radius-lg);
        border: 1.5px solid var(--border);
        overflow: hidden;
        box-shadow: var(--shadow-card);
        margin-top: 1.5rem;
    }
    .recent-card-head {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1rem 1.4rem;
        border-bottom: 1px solid var(--border);
    }
    .recent-card-head h3 { font-size: 15px; font-weight: 700; color: var(--text); }
    .recent-card-head a  { font-size: 12px; color: var(--blue-dark); font-weight: 600; }
</style>

<div>
    <h1 class="dash-title">Dashboard</h1>
    <p class="dash-sub">Welcome back, <strong>@Session["AdminName"]</strong></p>
</div>

<div class="stat-cards">
    <div class="stat-card">
        <div class="sc-icon" style="background:rgba(129,166,198,.15);color:var(--blue);"><i class="fa-solid fa-boxes-stacked"></i></div>
        <div class="sc-info"><span>Total Products</span><strong>@ViewBag.TotalProducts</strong></div>
    </div>
    <div class="stat-card">
        <div class="sc-icon" style="background:rgba(52,152,219,.15);color:#2471a3;"><i class="fa-solid fa-receipt"></i></div>
        <div class="sc-info"><span>Total Orders</span><strong>@ViewBag.TotalOrders</strong></div>
    </div>
    <div class="stat-card">
        <div class="sc-icon" style="background:rgba(224,85,85,.15);color:#e05555;"><i class="fa-regular fa-clock"></i></div>
        <div class="sc-info"><span>Pending (To Ship)</span><strong>@ViewBag.PendingOrders</strong></div>
    </div>
    <div class="stat-card">
        <div class="sc-icon" style="background:rgba(46,204,113,.15);color:#1e8449;"><i class="fa-solid fa-peso-sign"></i></div>
        <div class="sc-info"><span>Total Revenue</span><strong>&#8369;@((ViewBag.TotalRevenue as decimal? ?? 0).ToString("N2"))</strong></div>
    </div>
    <div class="stat-card">
        <div class="sc-icon" style="background:rgba(155,89,182,.15);color:#8e44ad;"><i class="fa-solid fa-users"></i></div>
        <div class="sc-info"><span>Registered Users</span><strong>@ViewBag.TotalUsers</strong></div>
    </div>
</div>

@* Alerts *@
@if (outOfStockCount > 0)
{
    <div class="dash-alert danger">
        <i class="fa-solid fa-circle-xmark" style="flex-shrink:0;"></i>
        <span><strong>@outOfStockCount</strong> product@(outOfStockCount != 1 ? "s are" : " is") <strong>out of stock</strong>.
        <a href="@Url.Action("Products","Admin")">Manage stock &rarr;</a></span>
    </div>
}
@if (lowStockCount > 0)
{
    <div class="dash-alert warning">
        <i class="fa-solid fa-triangle-exclamation" style="flex-shrink:0;"></i>
        <span><strong>@lowStockCount</strong> product@(lowStockCount != 1 ? "s are" : " is") <strong>running low</strong> (5 or fewer left).
        <a href="@Url.Action("Products","Admin")">View products &rarr;</a></span>
    </div>
}
@if ((int)ViewBag.RefundCount > 0)
{
    <div class="dash-alert danger" style="margin-bottom:1.5rem;">
        <i class="fa-solid fa-triangle-exclamation" style="flex-shrink:0;"></i>
        <span>You have <strong>@ViewBag.RefundCount</strong> pending refund request(s).
        <a href="@Url.Action("Orders","Admin")">Review now &rarr;</a></span>
    </div>
}

<div class="recent-card">
    <div class="recent-card-head">
        <h3>Recent Orders</h3>
        <a href="@Url.Action("Orders","Admin")">View All</a>
    </div>
    <table class="admin-table">
        <thead>
            <tr>
                <th>Reference</th>
                <th>Customer</th>
                <th>Date</th>
                <th>Total</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @if (recentOrders != null && recentOrders.Any())
            {
                foreach (var o in recentOrders)
                {
                    <tr>
                        <td>
                            <strong>@o.ReferenceNumber</strong>
                            @if (o.HasRefundRequest)
                            {<text> <span class="flag-badge"><i class="fa-solid fa-circle-exclamation"></i> REFUND</span></text>}
                        </td>
                        <td>@o.CustomerName</td>
                        <td>@o.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td>&#8369;@o.Total.ToString("N2")</td>
                        <td><span class="status-pill status-@o.Status.ToLower().Replace(" ","-")">@o.Status</span></td>
                        <td><a href="@Url.Action("Orders","Admin")" class="tbl-link">Manage</a></td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6" class="no-data">No orders yet.</td></tr>
            }
        </tbody>
    </table>
</div>


<script>
    // Ping the server every 5 minutes to keep the admin session alive
    setInterval(function () {
        fetch('@Url.Action("KeepAlive", "Admin")', { credentials: 'same-origin' })
            .catch(function () { /* silently ignore network errors */ });
    }, 5 * 60 * 1000);
</script>
