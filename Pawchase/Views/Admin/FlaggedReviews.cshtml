@model List<Pawchase.Models.Review>
@{
    ViewBag.Title = "Flagged Reviews";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    var flagged = Model.Where(r => r.ReportCount > 0).OrderByDescending(r => r.ReportCount).ToList();
}

<style>
    .report-card {
        background: var(--white);
        border-radius: var(--radius-lg);
        border: 1.5px solid var(--border);
        margin-bottom: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-card);
        transition: box-shadow .2s;
    }
    .report-card:hover { box-shadow: var(--shadow-hover); }
    .report-card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .9rem 1.3rem;
        background: rgba(243,227,208,.35);
        border-bottom: 1px solid var(--border);
        flex-wrap: wrap;
        gap: .5rem;
    }
    .report-flag-count {
        display: inline-flex; align-items: center; gap: 5px;
        background: rgba(224,85,85,.12); color: #c0392b;
        border: 1px solid rgba(224,85,85,.25);
        border-radius: 50px; padding: 3px 10px;
        font-size: 11px; font-weight: 700;
    }
    .report-meta { font-size: 12px; color: var(--text-light); }
    .report-meta strong { color: var(--text-mid); }

    .report-card-body { padding: 1.1rem 1.3rem; display: flex; gap: 1rem; align-items: flex-start; }
    .report-thumb {
        width: 52px; height: 52px; border-radius: 8px; flex-shrink: 0;
        background: linear-gradient(145deg, var(--peach), #eedfd0);
        border: 1px solid var(--border); overflow: hidden;
        display: flex; align-items: center; justify-content: center;
    }
    .report-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .report-thumb i   { font-size: 1.3rem; color: var(--blue); opacity: .4; }

    .report-content { flex: 1; }
    .report-stars { color: #E6A520; font-size: 12px; margin-bottom: 4px; }
    .report-comment {
        font-size: 13px; color: var(--text);
        line-height: 1.65; margin-bottom: .6rem;
        display: -webkit-box; -webkit-line-clamp: 3;
        -webkit-box-orient: vertical; overflow: hidden;
    }
    .report-product-tag {
        display: inline-flex; align-items: center; gap: 5px;
        background: rgba(129,166,198,.1); color: var(--blue-dark);
        border-radius: 50px; padding: 3px 10px; font-size: 11px; font-weight: 600;
    }

    .report-actions { display: flex; gap: .5rem; align-items: center; flex-shrink: 0; }
    .btn-dismiss {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 7px 16px; border-radius: 50px;
        background: rgba(129,166,198,.12); color: var(--blue-dark);
        border: 1.5px solid rgba(129,166,198,.3);
        font-size: 12px; font-weight: 700; cursor: pointer;
        font-family: 'Poppins', sans-serif; transition: all .2s;
    }
    .btn-dismiss:hover { background: var(--blue); color: #fff; border-color: var(--blue); }
    .btn-delete-review {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 7px 16px; border-radius: 50px;
        background: rgba(224,85,85,.08); color: #c0392b;
        border: 1.5px solid rgba(224,85,85,.25);
        font-size: 12px; font-weight: 700; cursor: pointer;
        font-family: 'Poppins', sans-serif; transition: all .2s;
    }
    .btn-delete-review:hover { background: #e05555; color: #fff; border-color: #e05555; }

    .reports-empty {
        text-align: center; padding: 4rem; color: var(--text-light);
        display: flex; flex-direction: column; align-items: center; gap: .75rem;
    }
    .reports-empty i { font-size: 2.5rem; color: #2ecc71; opacity: .6; }
    .reports-empty p { font-size: 14px; font-weight: 500; }

    /* ── SHARED MODAL BASE ── */
    .pc-modal-overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(0,0,0,0.45); z-index: 1000;
        align-items: center; justify-content: center;
    }
    .pc-modal-box {
        background: var(--white); border-radius: var(--radius-lg);
        padding: 2rem; max-width: 420px; width: 90%;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2); text-align: center;
    }
    .pc-modal-icon {
        width: 58px; height: 58px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1rem; font-size: 1.5rem;
    }
    .pc-modal-title { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: .5rem; }
    .pc-modal-body  { font-size: 13px; color: var(--text-mid); margin-bottom: 1.5rem; line-height: 1.6; }
    .pc-modal-btns  { display: flex; gap: 10px; justify-content: center; }
    .pc-modal-cancel {
        padding: 9px 22px; border-radius: 50px; font-size: 13px; font-weight: 600;
        border: 1.5px solid var(--border); background: var(--white); color: var(--text-mid);
        cursor: pointer; font-family: 'Poppins', sans-serif; transition: all .2s;
    }
    .pc-modal-cancel:hover { background: var(--border); }
    .pc-modal-confirm-danger {
        padding: 9px 22px; border-radius: 50px; font-size: 13px; font-weight: 700;
        background: linear-gradient(135deg,#e85d5d,#c94040); color: #fff; border: none;
        cursor: pointer; font-family: 'Poppins', sans-serif; transition: all .2s;
        display: inline-flex; align-items: center; gap: 6px; text-decoration: none;
    }
    .pc-modal-confirm-danger:hover { opacity: .9; transform: translateY(-1px); }
    .pc-modal-confirm-blue {
        padding: 9px 22px; border-radius: 50px; font-size: 13px; font-weight: 700;
        background: linear-gradient(135deg, var(--blue), var(--blue-dark)); color: #fff; border: none;
        cursor: pointer; font-family: 'Poppins', sans-serif; transition: all .2s;
        display: inline-flex; align-items: center; gap: 6px; text-decoration: none;
    }
    .pc-modal-confirm-blue:hover { opacity: .9; transform: translateY(-1px); }
</style>

<div class="admin-page-header" style="margin-bottom:1.4rem;">
    <div>
        <h1 style="font-size:1.75rem;font-weight:900;color:var(--text);text-transform:uppercase;letter-spacing:.5px;">Reports</h1>
        <p style="font-size:13px;color:var(--text-light);margin-top:2px;">Flagged reviews requiring moderation</p>
    </div>
    <span style="font-size:12px;color:var(--text-light);font-weight:600;">
        @flagged.Count flagged review@(flagged.Count != 1 ? "s" : "")
    </span>
</div>

@if (!flagged.Any())
{
    <div class="admin-table-card">
        <div class="reports-empty">
            <i class="fa-solid fa-shield-check"></i>
            <p>No flagged reviews at this time.</p>
            <small>Reviews reported by users will appear here for your review.</small>
        </div>
    </div>
}
else
{
    foreach (var r in flagged)
    {
        var product = Pawchase.Models.MockData.Products.FirstOrDefault(p => p.Id == r.ProductId);
        <div class="report-card">
            <div class="report-card-head">
                <div style="display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;">
                    <span class="report-flag-count">
                        <i class="fa-solid fa-flag"></i> @r.ReportCount report@(r.ReportCount != 1 ? "s" : "")
                    </span>
                    <span class="report-meta">
                        by <strong>@r.CustomerName</strong> &bull; @r.DatePosted.ToString("MMM dd, yyyy")
                        @if (r.IsEdited) { <text> &bull; <em>edited</em></text> }
                    </span>
                </div>
                <div class="report-actions">
                    <button type="button" class="btn-dismiss"
                            onclick="openDismissModal(@r.Id, '@Html.Raw(r.CustomerName.Replace("'", "\\'"))')">
                        <i class="fa-solid fa-check"></i> Dismiss
                    </button>
                    <button type="button" class="btn-delete-review"
                            onclick="openDeleteModal(@r.Id, '@Html.Raw(r.CustomerName.Replace("'", "\\'"))')">
                        <i class="fa-regular fa-trash-can"></i> Delete Review
                    </button>
                </div>
            </div>
            <div class="report-card-body">
                @if (!string.IsNullOrEmpty(r.PhotoUrl))
                {
                    <div class="report-thumb">
                        <img src="@r.PhotoUrl" alt="Review photo"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"/>
                        <i class="fa-solid fa-image" style="display:none;"></i>
                    </div>
                }
                else
                {
                    <div class="report-thumb" style="display:flex;"><i class="fa-solid fa-comment"></i></div>
                }
                <div class="report-content">
                    <div class="report-stars">
                        @for (int i = 1; i <= 5; i++)
                        { <i class="fa-@(i <= r.Stars ? "solid" : "regular") fa-star"></i> }
                        <span style="color:var(--text-light);font-size:11px;margin-left:4px;">@r.Stars / 5</span>
                        @if (r.IsVerifiedPurchase)
                        {
                            <span style="margin-left:8px;background:rgba(46,204,113,.12);color:#1e8449;border:1px solid rgba(46,204,113,.3);font-size:9px;font-weight:700;padding:2px 8px;border-radius:50px;vertical-align:middle;">
                                <i class="fa-solid fa-circle-check"></i> Verified Purchase
                            </span>
                        }
                    </div>
                    <div class="report-comment">@r.Comment</div>
                    @if (product != null)
                    {
                        <span class="report-product-tag"><i class="fa-solid fa-tag"></i> @product.Name</span>
                    }
                    <span style="margin-left:.4rem;" class="report-product-tag">
                        <i class="fa-solid fa-folder"></i> @r.Category
                    </span>

                    @* Existing seller reply display *@
                    @if (!string.IsNullOrWhiteSpace(r.SellerReply))
                    {
                        <div style="margin-top:10px;background:rgba(129,166,198,.1);border-left:3px solid var(--blue);border-radius:0 6px 6px 0;padding:10px 14px;">
                            <div style="font-size:10px;font-weight:700;color:var(--blue-dark);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;">
                                <i class="fa-solid fa-store"></i> Seller Reply &bull; @(r.SellerReplyDate?.ToString("MMM dd, yyyy") ?? "")
                            </div>
                            <div style="font-size:13px;color:var(--text);line-height:1.55;">@r.SellerReply</div>
                        </div>
                    }

                    @* Reply form *@
                    @using (Html.BeginForm("ReplyToReview", "Admin", FormMethod.Post, new { style = "margin-top:10px;" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="reviewId" value="@r.Id" />
                        <div style="display:flex;gap:8px;align-items:flex-start;">
                            <textarea name="replyText" rows="2" placeholder="@(string.IsNullOrWhiteSpace(r.SellerReply) ? "Write a seller reply…" : "Edit or clear reply…")"
                                      style="flex:1;padding:9px 12px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:12px;font-family:'Poppins',sans-serif;resize:vertical;outline:none;">@r.SellerReply</textarea>
                            <button type="submit" style="padding:9px 16px;border-radius:50px;font-size:12px;font-weight:700;background:linear-gradient(135deg,var(--blue),var(--blue-dark));color:#fff;border:none;cursor:pointer;font-family:'Poppins',sans-serif;white-space:nowrap;flex-shrink:0;">
                                <i class="fa-solid fa-reply"></i> @(string.IsNullOrWhiteSpace(r.SellerReply) ? "Reply" : "Update")
                            </button>
                        </div>
                        if (!string.IsNullOrWhiteSpace(r.SellerReply))
                        {
                            <button type="submit" name="replyText" value=""
                                    style="margin-top:5px;font-size:11px;background:none;border:none;color:#e05555;cursor:pointer;font-family:'Poppins',sans-serif;padding:0;">
                                <i class="fa-solid fa-xmark"></i> Remove reply
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
    }
}

<!-- ── DISMISS MODAL ── -->
<div id="dismissModal" class="pc-modal-overlay">
    <div class="pc-modal-box">
        <div class="pc-modal-icon" style="background:rgba(129,166,198,.12);">
            <i class="fa-solid fa-check" style="color:var(--blue);"></i>
        </div>
        <div class="pc-modal-title">Dismiss Reports?</div>
        <div class="pc-modal-body" id="dismissModalText"></div>
        <div class="pc-modal-btns">
            <button class="pc-modal-cancel" onclick="closeDismissModal()">Cancel</button>
            <a id="dismissConfirmLink" href="#" class="pc-modal-confirm-blue">
                <i class="fa-solid fa-check"></i> Dismiss
            </a>
        </div>
    </div>
</div>

<!-- ── DELETE REVIEW MODAL ── -->
<div id="deleteReviewModal" class="pc-modal-overlay">
    <div class="pc-modal-box">
        <div class="pc-modal-icon" style="background:rgba(224,85,85,.1);">
            <i class="fa-regular fa-trash-can" style="color:#e05555;"></i>
        </div>
        <div class="pc-modal-title">Delete Review?</div>
        <div class="pc-modal-body" id="deleteReviewModalText"></div>
        <div class="pc-modal-btns">
            <button class="pc-modal-cancel" onclick="closeDeleteModal()">Cancel</button>
            <a id="deleteReviewConfirmLink" href="#" class="pc-modal-confirm-danger">
                <i class="fa-regular fa-trash-can"></i> Delete Review
            </a>
        </div>
    </div>
</div>

@section scripts {
    <script>
        // ── Dismiss modal ──
        function openDismissModal(id, name) {
            document.getElementById('dismissModalText').textContent =
                'This will clear all reports on ' + name + '\'s review. The review will remain visible.';
            document.getElementById('dismissConfirmLink').href = '@Url.Action("DismissReport","Admin")?id=' + id;
            document.getElementById('dismissModal').style.display = 'flex';
        }
        function closeDismissModal() {
            document.getElementById('dismissModal').style.display = 'none';
        }
        document.getElementById('dismissModal').addEventListener('click', function(e) {
            if (e.target === this) closeDismissModal();
        });

        // ── Delete review modal ──
        function openDeleteModal(id, name) {
            document.getElementById('deleteReviewModalText').textContent =
                'Are you sure you want to permanently delete ' + name + '\'s review? This cannot be undone.';
            document.getElementById('deleteReviewConfirmLink').href = '@Url.Action("DeleteReview","Admin")?id=' + id;
            document.getElementById('deleteReviewModal').style.display = 'flex';
        }
        function closeDeleteModal() {
            document.getElementById('deleteReviewModal').style.display = 'none';
        }
        document.getElementById('deleteReviewModal').addEventListener('click', function(e) {
            if (e.target === this) closeDeleteModal();
        });
    </script>
}
