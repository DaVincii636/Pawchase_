@model List<Pawchase.Models.Product>
@{
    ViewBag.Title = "Manage Products";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

@if (TempData["Error"] != null)
{
    <div style="background:rgba(224,85,85,.1);border:1px solid rgba(224,85,85,.3);border-radius:var(--radius-sm);padding:12px 16px;margin-bottom:1rem;font-size:13px;color:#c94040;display:flex;align-items:center;gap:8px;">
        <i class="fa-solid fa-triangle-exclamation"></i> @TempData["Error"]
    </div>
}

<style>
    .products-page-title {
        font-size: 1.75rem;
        font-weight: 900;
        color: var(--text);
        letter-spacing: .5px;
        text-transform: uppercase;
    }

    /* ── FILTER BAR ──────────────────────────────── */
    .filter-bar {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1.2rem;
        flex-wrap: wrap;
    }
    .filter-search-wrap {
        display: flex;
        align-items: center;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        overflow: hidden;
        background: var(--white);
        width: 280px;
        flex-shrink: 0;
    }
    .filter-search-wrap input {
        flex: 1;
        padding: 10px 14px;
        border: none;
        outline: none;
        font-size: 13px;
        font-family: 'Poppins', sans-serif;
        background: transparent;
        color: var(--text);
    }
    .filter-search-wrap span {
        padding: 0 14px;
        display: flex;
        align-items: center;
        color: var(--text-light);
        font-size: 13px;
    }
    .filter-select-wrap {
        position: relative;
        flex-shrink: 0;
    }
    .filter-select-wrap select {
        appearance: none;
        -webkit-appearance: none;
        padding: 10px 38px 10px 14px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: 13px;
        font-family: 'Poppins', sans-serif;
        background: var(--white);
        color: var(--text);
        cursor: pointer;
        outline: none;
        min-width: 140px;
        transition: border-color .2s;
    }
    .filter-select-wrap select:focus { border-color: var(--blue); }
    .filter-select-wrap .select-chevron {
        position: absolute;
        right: 12px; top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        color: var(--text-light);
        font-size: 11px;
    }
    .filter-count {
        font-size: 12px;
        color: var(--text-light);
        margin-left: auto;
    }

    /* ── TABLE ───────────────────────────────────── */
    .admin-table-card {
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1.5px solid var(--border);
        box-shadow: var(--shadow-card);
    }
    .admin-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }
    .admin-table thead tr {
        background: linear-gradient(90deg, #c8dcea, #d6e8f4);
    }
    .admin-table thead th {
        padding: 13px 14px;
        font-size: 11px;
        font-weight: 700;
        color: var(--text);
        text-align: left;
        text-transform: uppercase;
        letter-spacing: .4px;
        border-bottom: 1.5px solid rgba(129,166,198,.3);
        white-space: nowrap;
    }
    .admin-table tbody tr {
        background: var(--white);
        border-bottom: 1px solid var(--border);
        transition: background .15s;
    }
    .admin-table tbody tr:last-child { border-bottom: none; }
    .admin-table tbody tr:hover { background: #f7f9fb; }

    /* ── LOW STOCK ROW HIGHLIGHT ─────────────────── */
    .admin-table tbody tr.row-low-stock { background: rgba(255,170,0,0.13) !important; }
    .admin-table tbody tr.row-low-stock:hover { background: rgba(255,170,0,0.22) !important; }

    .admin-table td {
        padding: 10px 14px;
        color: var(--text);
        vertical-align: middle;
    }

    /* stock badge */
    .stock-badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 700;
        border: 1.5px solid var(--border);
        background: var(--white);
        min-width: 38px;
        text-align: center;
    }
    .stock-zero { border-color: #e05555 !important; color: #e05555; }
    .stock-low  { border-color: #e6a520 !important; color: #e6a520; }
    .stock-ok   { color: var(--text); }

    /* sale pill */
    .sale-pill {
        display: inline-flex;
        align-items: center;
        padding: 3px 10px;
        background: rgba(224,85,85,.12);
        color: #c94040;
        border-radius: 50px;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: .5px;
    }

    /* ── ACTION COLUMN ────────────────────────────── */
    .action-col {
        text-align: center;
        vertical-align: middle;
        white-space: nowrap;
    }
    .action-col-inner {
        display: inline-flex;
        gap: 6px;
        align-items: center;
        justify-content: center;
    }
    .tbl-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        border-radius: var(--radius-sm);
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        font-family: 'Poppins', sans-serif;
        text-decoration: none;
        transition: opacity .2s, transform .15s;
    }
    .tbl-btn:hover { opacity: .85; transform: translateY(-1px); }
    .tbl-btn.edit   { background: rgba(129,166,198,.15); color: var(--blue-dark); }
    .tbl-btn.edit:hover { background: var(--blue); color: #fff; }
    .tbl-btn.delete { background: rgba(224,85,85,.1); color: #c94040; }
    .tbl-btn.delete:hover { background: #e05555; color: #fff; }
</style>

<!-- Header -->
<div class="admin-page-header" style="margin-bottom:1.4rem;">
    <h1 class="products-page-title">Products</h1>
    <a href="@Url.Action("AddProduct","Admin")" class="btn-primary" style="padding:10px 20px;font-size:13px;display:inline-flex;align-items:center;gap:6px;border-radius:50px;">
        <i class="fa-solid fa-plus"></i> Add Product
    </a>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <div class="filter-search-wrap">
        <input type="text" id="adminProductSearch"
               placeholder="Search products&hellip;"
               oninput="applyFilters()" />
        <span><i class="fa-solid fa-magnifying-glass"></i></span>
    </div>

    <div class="filter-select-wrap">
        <select id="filterSize" onchange="applyFilters()">
            <option value="">Breed Size</option>
            <option value="small">Small</option>
            <option value="medium">Medium</option>
            <option value="large">Large</option>
            <option value="all">All</option>
        </select>
        <span class="select-chevron"><i class="fa-solid fa-chevron-down"></i></span>
    </div>

    <div class="filter-select-wrap">
        <select id="filterCategory" onchange="applyFilters()">
            <option value="">Categories</option>
            <option value="treats">Treats</option>
            <option value="toys">Toys</option>
            <option value="accessories">Accessories</option>
            <option value="health">Health</option>
            <option value="others">Others</option>
        </select>
        <span class="select-chevron"><i class="fa-solid fa-chevron-down"></i></span>
    </div>

    <span id="adminProductCount" class="filter-count">@Model.Count products</span>
</div>

<!-- Table -->
<div class="admin-table-card">
    <table class="admin-table" id="adminProductTable">
        <thead>
            <tr>
                <th style="width:56px;">Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Size</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Sale?</th>
                <th style="text-align:center;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr data-name="@p.Name.ToLower()"
                    data-category="@p.Category.ToLower()"
                    data-size="@p.BreedSize.ToLower()"
                    data-stock="@p.Stock"
                    class="@(p.Stock <= 5 ? "row-low-stock" : "")">
                    <td>
                        <div style="width:44px;height:44px;border-radius:8px;overflow:hidden;background:linear-gradient(145deg,var(--peach),#eedfd0);flex-shrink:0;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;">
                            <img src="@p.ImageUrl" alt="@p.Name"
                                 style="width:100%;height:100%;object-fit:cover;"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                            <i class="fa-solid fa-bone" style="display:none;color:var(--blue);opacity:.4;font-size:16px;"></i>
                        </div>
                    </td>
                    <td><strong>@p.Name</strong></td>
                    <td>@p.Category</td>
                    <td>@p.BreedSize</td>
                    <td>&#8369;@p.Price.ToString("N2")</td>
                    <td>
                        <span class="stock-badge @(p.Stock==0?"stock-zero":p.Stock<=5?"stock-low":"stock-ok")">
                            @p.Stock
                        </span>
                    </td>
                    <td>
                        @if (p.IsOnSale)
                        {<span class="sale-pill">SALE</span>}
                        else
                        {<span style="color:#aaa;">&mdash;</span>}
                    </td>
                    <td class="action-col">
                        <div class="action-col-inner">
                            <a href="@Url.Action("EditProduct","Admin",new{id=p.Id})" class="tbl-btn edit">
                                <i class="fa-solid fa-pen"></i> Edit
                            </a>
                            <button type="button" class="tbl-btn delete"
                                    onclick="confirmDelete(@p.Id, '@Html.Raw(p.Name.Replace("'","\'"))')">
                                <i class="fa-regular fa-trash-can"></i> Delete
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Delete confirmation modal -->
<div id="deleteModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:1000;align-items:center;justify-content:center;">
    <div style="background:var(--white);border-radius:var(--radius-lg);padding:2rem;max-width:400px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.2);text-align:center;">
        <div style="width:56px;height:56px;border-radius:50%;background:rgba(224,85,85,.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
            <i class="fa-regular fa-trash-can" style="font-size:1.5rem;color:#e05555;"></i>
        </div>
        <h3 style="font-size:1.1rem;font-weight:700;color:var(--text);margin-bottom:.5rem;">Delete Product?</h3>
        <p id="deleteModalText" style="font-size:13px;color:var(--text-mid);margin-bottom:1.5rem;line-height:1.6;"></p>
        <div style="display:flex;gap:10px;justify-content:center;">
            <button onclick="closeDeleteModal()" class="btn-outline" style="padding:9px 22px;font-size:13px;">Cancel</button>
            <a id="deleteConfirmLink" href="#" class="btn-primary"
               style="padding:9px 22px;font-size:13px;background:linear-gradient(135deg,#e85d5d,#c94040);border-color:#c94040;">
                <i class="fa-regular fa-trash-can"></i> Delete
            </a>
        </div>
    </div>
</div>

@section scripts {
    <script>
        function applyFilters() {
            var query    = (document.getElementById('adminProductSearch').value || '').toLowerCase().trim();
            var size     = (document.getElementById('filterSize').value         || '').toLowerCase();
            var category = (document.getElementById('filterCategory').value     || '').toLowerCase();
            var rows     = document.querySelectorAll('#adminProductTable tbody tr');
            var visible  = 0;
            rows.forEach(function (row) {
                var rName = row.getAttribute('data-name')     || '';
                var rCat  = row.getAttribute('data-category') || '';
                var rSize = row.getAttribute('data-size')     || '';
                var matchSearch   = query    === '' || rName.indexOf(query) !== -1 || rCat.indexOf(query) !== -1;
                var matchSize     = size     === '' || rSize === size;
                var matchCategory = category === '' || rCat  === category;
                var show = matchSearch && matchSize && matchCategory;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            var countEl = document.getElementById('adminProductCount');
            if (countEl) countEl.textContent = visible + ' product' + (visible !== 1 ? 's' : '');
        }

        function confirmDelete(id, name) {
            document.getElementById('deleteModalText').textContent =
                'Are you sure you want to delete "' + name + '"? This action cannot be undone.';
            document.getElementById('deleteConfirmLink').href = '@Url.Action("DeleteProduct","Admin")?id=' + id;
            document.getElementById('deleteModal').style.display = 'flex';
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').style.display = 'none';
        }

        document.getElementById('deleteModal').addEventListener('click', function (e) {
            if (e.target === this) closeDeleteModal();
        });
    </script>
}
