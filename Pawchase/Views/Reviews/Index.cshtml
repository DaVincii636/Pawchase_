@using Pawchase.Models
@model List<Pawchase.Models.Review>
@{
    ViewBag.Title = "Community Reviews";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var dogIcons = new[]{"fa-dog","fa-paw","fa-bone","fa-dog","fa-paw","fa-bone"};
    var colors = new[]{"#ffe8d6","#ddeaf3","#f3e3d0","#d4eadd","#ecddd0","#d4e4f0"};
    var rnd = new System.Random(42);
}
@section styles {
<style>
.reviews-hero { background:linear-gradient(135deg,var(--blue-deeper),var(--blue),var(--lblue)); color:#fff; text-align:center; padding:3rem 2rem; }
.reviews-hero h1 { font-size:2rem; font-weight:800; }
.reviews-hero h1 span { color:#FFD77A; }
.reviews-hero p { opacity:.8; margin-top:.5rem; }
.hero-stats { display:flex; justify-content:center; gap:2rem; margin-top:1.5rem; }
.hero-stats .stat strong { display:block; font-size:1.4rem; font-weight:800; }
.hero-stats .stat span   { font-size:11px; opacity:.6; }
.reviews-toolbar { display:flex; align-items:center; justify-content:space-between; padding:1rem 5%; background:var(--white); border-bottom:1px solid var(--border); flex-wrap:wrap; gap:.75rem; position:sticky; top:66px; z-index:100; }
.filter-chips { display:flex; gap:6px; flex-wrap:wrap; }
.chip { padding:5px 14px; border-radius:50px; border:1.5px solid rgba(129,166,198,.3); font-size:12px; font-weight:600; color:var(--blue-dark); background:#fff; cursor:pointer; transition:all .2s; text-decoration:none; display:inline-block; }
.chip:hover,.chip.active { background:var(--blue); border-color:var(--blue-dark); color:#fff; }
.write-review-btn { display:inline-flex; align-items:center; gap:7px; padding:9px 20px; background:linear-gradient(135deg,var(--blue),var(--blue-dark)); color:#fff; font-size:13px; font-weight:700; border-radius:50px; border:none; cursor:pointer; box-shadow:0 4px 14px rgba(129,166,198,.35); font-family:'Poppins',sans-serif; }
.write-review-btn:hover { background:linear-gradient(135deg,var(--blue-dark),var(--blue-deeper)); }
.reviews-section { padding:2rem 5%; background:var(--bg); }
.masonry-grid { columns:4; column-gap:16px; }
.masonry-card { break-inside:avoid; margin-bottom:16px; background:var(--white); border-radius:16px; border:1px solid rgba(129,166,198,.15); overflow:hidden; box-shadow:var(--shadow-card); cursor:pointer; transition:transform .25s,box-shadow .25s; }
.masonry-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-hover); }
.card-photo { width:100%; aspect-ratio:1; display:flex; align-items:center; justify-content:center; overflow:hidden; }
.card-photo.tall  { aspect-ratio:3/4; }
.card-photo.short { aspect-ratio:4/3; }
.card-body { padding:12px 14px 14px; }
.card-header { display:flex; align-items:center; gap:8px; margin-bottom:8px; }
.card-avatar { width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg,var(--blue),var(--blue-dark)); display:flex; align-items:center; justify-content:center; color:#fff; font-size:13px; font-weight:700; flex-shrink:0; }
.card-username { font-size:13px; font-weight:700; color:var(--text); }
.card-time { font-size:10px; color:var(--text-light); }
.card-stars { display:flex; gap:2px; color:#E6A520; font-size:11px; margin-bottom:6px; }
.card-caption { font-size:12px; color:var(--text-mid); line-height:1.5; margin-bottom:8px; }
.card-product-tag { display:inline-flex; align-items:center; gap:4px; font-size:10px; font-weight:700; color:var(--blue-dark); background:rgba(129,166,198,.1); padding:3px 8px; border-radius:50px; margin-bottom:10px; }
.card-actions { display:flex; align-items:center; gap:12px; padding-top:8px; border-top:1px solid rgba(129,166,198,.1); }
.card-action-btn { display:flex; align-items:center; gap:5px; font-size:12px; font-weight:600; color:var(--text-light); background:none; border:none; cursor:pointer; font-family:'Poppins',sans-serif; transition:color .2s; }
.card-action-btn:hover { color:var(--blue); }
.card-action-btn.liked { color:#e85d5d; }
.view-product-link { margin-left:auto; font-size:10px; font-weight:700; color:var(--blue-dark); background:rgba(129,166,198,.1); border:none; cursor:pointer; padding:4px 10px; border-radius:50px; font-family:'Poppins',sans-serif; text-decoration:none; }
.view-product-link:hover { background:var(--blue); color:#fff; }
.review-modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.7); z-index:9999; align-items:center; justify-content:center; padding:1rem; }
.review-modal-overlay.open { display:flex; }
.review-modal { background:#fff; border-radius:20px; max-width:820px; width:100%; max-height:90vh; overflow:hidden; display:grid; grid-template-columns:1fr 1fr; box-shadow:0 30px 80px rgba(0,0,0,.4); animation:modalIn .25s ease; }
@@keyframes modalIn { from{opacity:0;transform:scale(.94)} to{opacity:1;transform:scale(1)} }
.modal-photo { display:flex; align-items:center; justify-content:center; min-height:350px; }
.modal-info { display:flex; flex-direction:column; overflow-y:auto; }
.modal-info-header { display:flex; align-items:center; gap:10px; padding:16px 20px; border-bottom:1px solid var(--border); }
.modal-avatar { width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg,var(--blue),var(--blue-dark)); display:flex; align-items:center; justify-content:center; color:#fff; font-size:15px; font-weight:700; }
.modal-close { margin-left:auto; background:none; border:none; cursor:pointer; font-size:18px; color:var(--text-light); }
.modal-body { padding:20px; flex:1; }
.modal-stars { display:flex; gap:3px; color:#E6A520; font-size:14px; margin-bottom:10px; }
.modal-caption { font-size:14px; color:var(--text); line-height:1.7; margin-bottom:14px; }
.modal-product-tag { display:flex; align-items:center; gap:10px; background:var(--peach); border-radius:10px; padding:10px 14px; border:1px solid var(--border); margin-bottom:14px; }
.modal-footer { padding:14px 20px; border-top:1px solid var(--border); display:flex; align-items:center; gap:14px; }
.write-modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.65); z-index:9999; align-items:center; justify-content:center; padding:1rem; }
.write-modal-overlay.open { display:flex; }
.write-modal { background:#fff; border-radius:20px; width:100%; max-width:480px; padding:2rem; position:relative; animation:modalIn .25s ease; box-shadow:0 30px 80px rgba(0,0,0,.4); max-height:88vh; overflow-y:auto; }
.write-modal h2 { font-size:1.2rem; font-weight:800; color:var(--text); margin-bottom:1.5rem; }
.stars-select { display:flex; gap:6px; margin:4px 0; }
.stars-select i { font-size:1.6rem; color:#E6A520; cursor:pointer; transition:transform .15s; }
.stars-select i:hover { transform:scale(1.2); }
.modal-close-btn { position:absolute; top:1rem; right:1rem; background:none; border:none; cursor:pointer; font-size:18px; color:var(--text-light); }
@@media(max-width:768px) { .masonry-grid{columns:2} .review-modal{grid-template-columns:1fr} .modal-photo{min-height:200px} }
@@media(max-width:480px) { .masonry-grid{columns:1} }
</style>
}

<div class="reviews-hero">
    <h1>From Our <span>Pack</span> <i class="fa-solid fa-paw" style="font-size:1.6rem;vertical-align:middle"></i></h1>
    <p>Real reviews from verified PawChase buyers</p>
    <div class="hero-stats">
        <div class="stat"><strong>@Model.Count</strong><span>Reviews</span></div>
        <div class="stat"><strong>4.8</strong><span>Avg Rating</span></div>
        <div class="stat"><strong>96%</strong><span>Recommend</span></div>
    </div>
</div>

@if (TempData["ReviewPosted"] != null)
{
    <div class="toast show" style="position:relative;transform:none;opacity:1;margin:1rem 5%;display:flex">
        <i class="fa-solid fa-circle-check"></i> Review posted! Thank you!
    </div>
}

<div class="reviews-toolbar">
    <div class="filter-chips">
        <a href="@Url.Action("Index","Reviews")" class="chip @(ViewBag.Filter==null?"active":"")">All</a>
        <a href="@Url.Action("Index","Reviews",new{filter=5})" class="chip @(ViewBag.Filter?.ToString()=="5"?"active":"")"><i class="fa-solid fa-star" style="font-size:10px"></i> 5 Stars</a>
        <a href="@Url.Action("Index","Reviews",new{filter=4})" class="chip @(ViewBag.Filter?.ToString()=="4"?"active":"")"><i class="fa-solid fa-star" style="font-size:10px"></i> 4 Stars</a>
    </div>
    <button class="write-review-btn" onclick="document.getElementById('write-modal').classList.add('open');document.body.style.overflow='hidden'">
        <i class="fa-solid fa-pen-to-square"></i> Write a Review
    </button>
</div>

<section class="reviews-section">
    @if (!Model.Any())
    {
        <div style="text-align:center;padding:4rem;color:var(--text-light)">
            <i class="fa-solid fa-paw" style="font-size:3rem;margin-bottom:1rem;display:block;color:var(--blue);opacity:.4"></i>
            <p>No reviews yet. Be the first to share your experience!</p>
        </div>
    }
    else
    {
        var heightClasses = new[]{"","tall","short","","short","tall"};
        <div class="masonry-grid">
            @for (int i = 0; i < Model.Count; i++)
            {
                var r     = Model[i];
                var color = colors[i % colors.Length];
                var icon  = dogIcons[i % dogIcons.Length];
                var hc    = heightClasses[i % heightClasses.Length];
                var prod  = MockData.Products.FirstOrDefault(p => p.Id == r.ProductId);
                <div class="masonry-card" onclick="openModal(@i)">
                    <div class="card-photo @hc" style="background:@color">
                        <i class="fa-solid @icon" style="font-size:3rem;color:rgba(0,0,0,0.15)"></i>
                    </div>
                    <div class="card-body">
                        <div class="card-header">
                            <div class="card-avatar">@r.CustomerName[0]</div>
                            <div>
                                <div class="card-username">@r.CustomerName</div>
                                <div class="card-time">@r.DatePosted.ToString("MMM dd, yyyy") &middot; Verified Buyer</div>
                            </div>
                        </div>
                        <div class="card-stars">
                            @for (int s = 1; s <= 5; s++) { <i class="@(s<=r.Stars?"fa-solid":"fa-regular") fa-star"></i> }
                        </div>
                        <p class="card-caption">"@r.Comment"</p>
                        @if (prod != null) {
                            <div class="card-product-tag"><i class="fa-solid fa-bone"></i> @prod.Name</div>
                        }
                        <div class="card-actions">
                            <button class="card-action-btn" id="like-@i" onclick="event.stopPropagation();toggleLike(@i,this)">
                                <i class="fa-regular fa-heart"></i> <span>@(rnd.Next(2,30))</span>
                            </button>
                            <a href="@(prod!=null?Url.Action("Details","Product",new{id=prod.Id}):"#")" class="view-product-link" onclick="event.stopPropagation()">View Product</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

@Html.Partial("_Footer")

<!-- DETAIL MODAL -->
<div class="review-modal-overlay" id="detail-modal" onclick="if(event.target===this)closeModal()">
    <div class="review-modal">
        <div class="modal-photo" id="modal-photo"></div>
        <div class="modal-info">
            <div class="modal-info-header">
                <div class="modal-avatar" id="modal-av"></div>
                <div>
                    <div style="font-size:14px;font-weight:700" id="modal-name"></div>
                    <div style="font-size:11px;color:var(--text-light)" id="modal-date"></div>
                </div>
                <button class="modal-close" onclick="closeModal()"><i class="fa-solid fa-times"></i></button>
            </div>
            <div class="modal-body">
                <div class="modal-stars" id="modal-stars"></div>
                <p class="modal-caption" id="modal-caption"></p>
                <div class="modal-product-tag">
                    <i class="fa-solid fa-bone" style="color:var(--blue)"></i>
                    <span id="modal-product"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button class="card-action-btn" onclick="toggleModalLike(this)">
                    <i class="fa-regular fa-heart"></i> <span id="modal-likes"></span>
                </button>
                <a id="modal-product-link" href="#" class="view-product-link">View Product</a>
            </div>
        </div>
    </div>
</div>

<!-- WRITE MODAL -->
<div class="write-modal-overlay" id="write-modal" onclick="if(event.target===this){this.classList.remove('open');document.body.style.overflow=''}">
    <div class="write-modal">
        <button class="modal-close-btn" onclick="document.getElementById('write-modal').classList.remove('open');document.body.style.overflow=''">
            <i class="fa-solid fa-times"></i>
        </button>
        <h2><i class="fa-solid fa-pen-to-square" style="color:var(--blue)"></i> Share Your Experience</h2>
        @using (Html.BeginForm("Submit","Reviews", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="stars" id="stars-val" value="5"/>
            <div class="form-group" style="margin-bottom:1rem">
                <label>Your Name</label>
                @if (Session["UserName"] != null) {
                    <input type="text" name="customerName" value="@Session["UserName"]" class="readonly-input" readonly/>
                } else {
                    <input type="text" name="customerName" placeholder="Juan dela Cruz" required/>
                }
            </div>
            <div class="form-group" style="margin-bottom:1rem">
                <label>Product</label>
                <select name="productId" required>
                    <option value="">-- Select product --</option>
                    @foreach (var p in MockData.Products)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>
            </div>
            <div class="form-group" style="margin-bottom:1rem">
                <label>Rating</label>
                <div class="stars-select" id="write-stars">
                    <i class="fa-solid fa-star" onclick="setWriteStar(1)"></i>
                    <i class="fa-solid fa-star" onclick="setWriteStar(2)"></i>
                    <i class="fa-solid fa-star" onclick="setWriteStar(3)"></i>
                    <i class="fa-solid fa-star" onclick="setWriteStar(4)"></i>
                    <i class="fa-solid fa-star" onclick="setWriteStar(5)"></i>
                </div>
            </div>
            <div class="form-group" style="margin-bottom:1.5rem">
                <label>Your Review</label>
                <textarea name="comment" rows="4" placeholder="Tell us about your dog's experience..." required
                          style="border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:12px;font-size:13px;width:100%;outline:none;font-family:'Poppins',sans-serif"></textarea>
            </div>
            <button type="submit" class="btn-primary" style="width:100%;justify-content:center">
                <i class="fa-solid fa-paper-plane"></i> Post Review
            </button>
        }
    </div>
</div>

@section scripts {
<script>
var reviews = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Select((r,i) => new {
    name      = r.CustomerName,
    stars     = r.Stars,
    comment   = r.Comment,
    date      = r.DatePosted.ToString("MMM dd, yyyy"),
    product   = MockData.Products.FirstOrDefault(p=>p.Id==r.ProductId)?.Name ?? "",
    productId = r.ProductId,
    color     = new[]{"#ffe8d6","#ddeaf3","#f3e3d0","#d4eadd","#ecddd0","#d4e4f0"}[i%6],
    icon      = new[]{"fa-dog","fa-paw","fa-bone","fa-dog","fa-paw","fa-bone"}[i%6],
    likes     = new System.Random(i+1).Next(2,30)
})));

function openModal(i) {
    var r = reviews[i];
    document.getElementById('modal-photo').style.background = r.color;
    document.getElementById('modal-photo').innerHTML = '<i class="fa-solid ' + r.icon + '" style="font-size:5rem;color:rgba(0,0,0,0.15)"></i>';
    document.getElementById('modal-photo').style.display = 'flex';
    document.getElementById('modal-photo').style.alignItems = 'center';
    document.getElementById('modal-photo').style.justifyContent = 'center';
    document.getElementById('modal-photo').style.minHeight = '350px';
    document.getElementById('modal-av').textContent = r.name[0];
    document.getElementById('modal-name').textContent = r.name;
    document.getElementById('modal-date').textContent = r.date + ' - Verified Buyer';
    var stars = '';
    for (var s = 1; s <= 5; s++) stars += '<i class="' + (s <= r.stars ? 'fa-solid' : 'fa-regular') + ' fa-star"></i>';
    document.getElementById('modal-stars').innerHTML = stars;
    document.getElementById('modal-caption').textContent = '"' + r.comment + '"';
    document.getElementById('modal-product').textContent = r.product;
    document.getElementById('modal-likes').textContent = r.likes;
    document.getElementById('modal-product-link').href = '/Product/Details/' + r.productId;
    document.getElementById('detail-modal').classList.add('open');
    document.body.style.overflow = 'hidden';
}
function closeModal() {
    document.getElementById('detail-modal').classList.remove('open');
    document.body.style.overflow = '';
}
function toggleLike(i, btn) {
    var liked = btn.classList.toggle('liked');
    var count = parseInt(btn.querySelector('span').textContent);
    btn.querySelector('span').textContent = liked ? count + 1 : count - 1;
    btn.querySelector('i').className = liked ? 'fa-solid fa-heart' : 'fa-regular fa-heart';
}
function toggleModalLike(btn) {
    var liked = btn.classList.toggle('liked');
    var count = parseInt(document.getElementById('modal-likes').textContent);
    document.getElementById('modal-likes').textContent = liked ? count + 1 : count - 1;
    btn.querySelector('i').className = liked ? 'fa-solid fa-heart' : 'fa-regular fa-heart';
}
function setWriteStar(val) {
    document.getElementById('stars-val').value = val;
    document.querySelectorAll('#write-stars i').forEach(function(s, i) {
        s.className = i < val ? 'fa-solid fa-star' : 'fa-regular fa-star';
    });
}
</script>
}
