@using Pawchase.Models
@model List<Pawchase.Models.Review>
@{
    ViewBag.Title = "Community Reviews";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var colors = new[] { "#ffe8d6", "#ddeaf3", "#f3e3d0", "#d4eadd", "#ecddd0", "#d4e4f0" };
    var icons = new[] { "fa-dog", "fa-paw", "fa-bone", "fa-dog", "fa-paw", "fa-bone" };
    var likedIds = ViewBag.LikedReviewIds as List<int> ?? new List<int>();
    var reportedIds = ViewBag.ReportedReviewIds as List<int> ?? new List<int>();
    var hasSortSelection = !string.IsNullOrWhiteSpace(Request.QueryString["sortBy"]);
    var hasCategorySelection = !string.IsNullOrWhiteSpace(Request.QueryString["category"]);
    var hasPhotoSelection = !string.IsNullOrWhiteSpace(Request.QueryString["photoFilter"]);
}

@section styles {
    <link rel="stylesheet" href="~/Content/reviews.css" />
}

<div class="reviews-hero">
    <h1>From Our <span>Pack</span> <i class="fa-solid fa-paw" style="font-size:1.6rem;vertical-align:middle"></i></h1>
    <p>Real reviews from verified PawChase buyers</p>
    <div class="hero-stats">
        <div class="stat"><strong>@Model.Count</strong><span>Reviews</span></div>
        <div class="stat"><strong>@(Model.Any() ? Model.Average(r => r.Stars).ToString("0.0") : "0.0")</strong><span>Avg Rating</span></div>
        <div class="stat"><strong>@(Model.Any() ? ((int)System.Math.Round((double)Model.Count(r => r.Stars >= 4) * 100 / Model.Count)).ToString() : "0")%</strong><span>Recommend</span></div>
    </div>
</div>

@if (TempData["ReviewPosted"] != null)
{
    <div class="toast-small" id="posted-toast">
        <i class="fa-solid fa-circle-check"></i> Review posted! Thank you!
    </div>
}

<div class="reviews-toolbar">
    <div class="filter-row">
        <select class="review-filter-select @(hasSortSelection ? "active" : "")" onchange="applyFilter({ sortBy: this.value })">
            <option value="" @(!hasSortSelection ? "selected" : "")>Filter</option>
            <option value="recent" @(ViewBag.SortBy == "recent" && hasSortSelection ? "selected" : "")>Recent</option>
            <option value="likes" @(ViewBag.SortBy == "likes" && hasSortSelection ? "selected" : "")>Most Liked</option>
            <option value="rating" @(ViewBag.SortBy == "rating" && hasSortSelection ? "selected" : "")>Highest Rated</option>
        </select>

        <select class="review-filter-select @(hasCategorySelection ? "active" : "")" onchange="applyFilter({ category: this.value })">
            <option value="" @(!hasCategorySelection ? "selected" : "")>Categories</option>
            <option value="All" @(ViewBag.Category == "All" && hasCategorySelection ? "selected" : "")>All</option>
            <option value="Food & Treats" @(ViewBag.Category == "Food & Treats" && hasCategorySelection ? "selected" : "")>Food &amp; Treats</option>
            <option value="Accessories & Apparel" @(ViewBag.Category == "Accessories & Apparel" && hasCategorySelection ? "selected" : "")>Accessories &amp; Apparel</option>
            <option value="Care & Hygiene" @(ViewBag.Category == "Care & Hygiene" && hasCategorySelection ? "selected" : "")>Care &amp; Hygiene</option>
            <option value="Toys" @(ViewBag.Category == "Toys" && hasCategorySelection ? "selected" : "")>Toys</option>
            <option value="Health" @(ViewBag.Category == "Health" && hasCategorySelection ? "selected" : "")>Health</option>
            <option value="Others" @(ViewBag.Category == "Others" && hasCategorySelection ? "selected" : "")>Others</option>
        </select>

        <select class="review-filter-select @(ViewBag.PhotoFilter != "all" ? "active" : "")" onchange="applyFilter({ photoFilter: this.value })">
            <option value="all" @((ViewBag.PhotoFilter == "all" || !hasPhotoSelection) ? "selected" : "")>All Reviews</option>
            <option value="with" @(ViewBag.PhotoFilter == "with" && hasPhotoSelection ? "selected" : "")>With Photos</option>
            <option value="without" @(ViewBag.PhotoFilter == "without" && hasPhotoSelection ? "selected" : "")>Without Photos</option>
        </select>
    </div>

    @* eunice modified: removed Write a Review button from toolbar — reviews page is read-only like Shopee/Lazada *@
</div>

<section class="reviews-section @(ViewBag.PhotoFilter == "without" ? "without-photos-view" : "")">
    @if (!Model.Any())
    {
        <div class="reviews-empty">
            <i class="fa-solid fa-paw"></i>
            <p>No reviews found for selected filters.</p>
        </div>
    }
    else
    {
        <div class="reviews-grid">
            @for (int i = 0; i < Model.Count; i++)
            {
                var r = Model[i];
                var prod = MockData.Products.FirstOrDefault(p => p.Id == r.ProductId);
                var color = colors[i % colors.Length];
                var icon = icons[i % icons.Length];
                var isLiked = likedIds.Contains(r.Id);
                var isReported = reportedIds.Contains(r.Id);
                <div class="review-card @(r.IsTextOnly ? "without-photo" : "with-photo") @(isReported ? "reported-by-me" : "")" id="review-@r.Id" onclick="openModal(@i)">
                    @if (!r.IsTextOnly)
                    {
                        <div class="review-card-photo" style="background:@color;">
                            @if (!string.IsNullOrWhiteSpace(r.PhotoUrl))
                            {
                                <img src="@Url.Content(r.PhotoUrl)" alt="Review photo" onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex';" />
                            }
                            <i class="fa-solid @icon" style="font-size:3rem;color:rgba(0,0,0,.12);display:@(string.IsNullOrWhiteSpace(r.PhotoUrl) ? "inline-flex" : "none")"></i>
                        </div>
                    }
                    <div class="review-card-body">
                        <div class="review-card-header">
                            <div class="review-avatar">@((r.CustomerName ?? "A")[0])</div>
                            <div>
                                <div class="review-name">@r.CustomerName</div>
                                <div class="review-meta">
                                    @r.DatePosted.ToString("MMM dd, yyyy") · Verified Buyer
                                    @if (r.IsEdited)
                                    {
                                        <span class="review-edited" data-edited-at="@r.LastEditedAt.Value.ToString("o")">Edited</span>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="review-stars">
                            @for (int s = 1; s <= 5; s++)
                            {
                                <i class="@(s <= r.Stars ? "fa-solid" : "fa-regular") fa-star"></i>
                            }
                        </div>
                        <p class="review-caption">"@r.Comment"</p>
                        @if (prod != null)
                        {
                            <span class="review-product"><i class="fa-solid fa-bone"></i> @prod.Name</span>
                        }
                        <div class="review-actions">
                            <button class="review-action @(isLiked ? "liked" : "")" data-review-id="@r.Id" onclick="event.stopPropagation();toggleLike(@r.Id,this)">
                                <i class="@(isLiked ? "fa-solid" : "fa-regular") fa-heart"></i>
                                <span>@r.Likes</span>
                            </button>
                            <button class="review-action" data-comment-review-id="@r.Id" onclick="event.stopPropagation();openModalComments(@i)">
                                <i class="fa-regular fa-comment"></i>
                                <span>@(r.Comments?.Count ?? 0)</span>
                            </button>
                            <button class="review-action @(isReported ? "reported" : "")" data-report-review-id="@r.Id" onclick="event.stopPropagation();openReportModal(@r.Id)">
                                <i class="@(isReported ? "fa-solid" : "fa-regular") fa-flag"></i>
                                <span>@r.ReportCount</span>
                            </button>
                            <a class="view-product-link" href="@(prod != null ? Url.Action("Details", "Product", new { id = prod.Id }) : "#")" onclick="event.stopPropagation()">View Product</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

<div class="review-modal-overlay" id="review-modal-overlay" onclick="if(event.target===this)closeModal()">
    <div class="review-modal" id="review-modal">
        <div class="modal-photo-wrap">
            <div class="modal-photo" id="modal-photo"></div>
        </div>
        <div class="modal-info">
            <div class="modal-header">
                <div class="modal-avatar" id="modal-avatar"></div>
                <div>
                    <div class="modal-name-text" id="modal-name"></div>
                    <div class="modal-date-text" id="modal-date"></div>
                    <div id="modal-edited" class="modal-edited" style="display:none;"></div>
                </div>
                <button class="modal-close" onclick="closeModal()"><i class="fa-solid fa-times"></i></button>
            </div>
            <div class="modal-body">
                <div class="modal-stars" id="modal-stars"></div>
                <p class="modal-caption" id="modal-caption"></p>
                <div class="modal-product" id="modal-product"></div>
            </div>
            <div class="modal-actions">
                <button class="review-action" id="modal-like-btn" data-review-id="0" onclick="toggleLike(activeReview.id,this)">
                    <i class="fa-regular fa-heart"></i>
                    <span id="modal-likes"></span>
                </button>
                <button class="review-action" onclick="toggleCommentPanel()">
                    <i class="fa-regular fa-comment"></i>
                    <span id="modal-comment-count"></span>
                </button>
                <button class="review-action" id="modal-report-btn" data-report-review-id="0" onclick="openReportModal(activeReview.id)">
                    <i class="fa-regular fa-flag"></i>
                    <span id="modal-reports"></span>
                </button>
                <a class="view-product-link" id="modal-product-link" href="#">View Product</a>
            </div>

            <div class="modal-comments" id="modal-comments-panel">
                <div class="modal-comments-head">
                    <strong class="modal-comments-title">Comments</strong>
                </div>
                <div class="modal-comments-list" id="modal-comments-list"></div>
                @using (Html.BeginForm("AddComment", "Reviews", FormMethod.Post, new { @class = "comment-form", id = "modal-comment-form" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="reviewId" id="comment-review-id" />
                    <input type="hidden" name="returnUrl" id="comment-return-url" value="@Request.RawUrl" />
                    <input type="text" class="comment-input" name="commentText" maxlength="180" placeholder="Write a comment..." required />
                    <button type="submit" class="comment-submit">Send</button>
                }
            </div>
        </div>
    </div>
</div>

<div class="report-modal-overlay" id="report-modal-overlay" onclick="if(event.target===this)closeReportModal()">
    <div class="report-modal">
        <h3>Help us understand the issue with this review.</h3>
        <div class="report-options" id="report-options">
            <label class="report-option"><input type="radio" name="report-reason" value="Inappropriate content" onchange="toggleOtherInput(this)" /> Inappropriate content</label>
            <label class="report-option"><input type="radio" name="report-reason" value="Spam" onchange="toggleOtherInput(this)" /> Spam</label>
            <label class="report-option"><input type="radio" name="report-reason" value="Misleading or inaccurate information" onchange="toggleOtherInput(this)" /> Misleading or inaccurate information</label>
            <label class="report-option"><input type="radio" name="report-reason" value="Offensive or abusive language" onchange="toggleOtherInput(this)" /> Offensive or abusive language</label>
            <label class="report-option"><input type="radio" name="report-reason" value="Irrelevant content" onchange="toggleOtherInput(this)" /> Irrelevant content</label>
            <label class="report-option"><input type="radio" name="report-reason" value="Other" onchange="toggleOtherInput(this)" /> Other</label>
        </div>
        @* eunice modified: input field shown when "Other" is selected *@
        <input type="text" id="report-other-input" maxlength="150" placeholder="Please describe the issue..."
               style="display:none;width:100%;margin-top:8px;padding:8px 10px;border:1.5px solid var(--border);border-radius:8px;font-family:'Poppins',sans-serif;font-size:12px;box-sizing:border-box;" />
        <div class="report-error" id="report-error"></div>
        <div class="report-actions">
            <button type="button" class="report-cancel" onclick="closeReportModal()">Cancel</button>
            <button type="button" class="report-submit" onclick="submitReport()">Submit</button>
        </div>
    </div>
</div>

<div class="write-modal-overlay" id="write-modal" onclick="if(event.target===this)closeWriteModal()">
    <div class="write-modal">
        <button class="modal-close-btn" onclick="closeWriteModal()"><i class="fa-solid fa-times"></i></button>
        <h2><i class="fa-solid fa-pen-to-square" style="color:var(--blue)"></i> Share Your Experience</h2>

        @using (Html.BeginForm("Submit", "Reviews", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="stars" id="stars-val" value="5" />

            <div class="form-group" style="margin-bottom:1rem;">
                <label>Your Name</label>
                <input type="text" name="customerName" value="@(Session["UserName"] ?? "alex")" class="readonly-input" readonly />
            </div>

            <div class="form-group" style="margin-bottom:1rem;">
                <label>Product</label>
                <select name="productId" required>
                    <option value="">-- Select product --</option>
                    @foreach (var p in MockData.Products)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>
            </div>

            <div class="form-group" style="margin-bottom:1rem;">
                <label>Rating</label>
                <div class="stars-select" id="write-stars">
                    <i class="fa-solid fa-star" onclick="setWriteStar(1)"></i>
                    <i class="fa-solid fa-star" onclick="setWriteStar(2)"></i>
                    <i class="fa-solid fa-star" onclick="setWriteStar(3)"></i>
                    <i class="fa-solid fa-star" onclick="setWriteStar(4)"></i>
                    <i class="fa-solid fa-star" onclick="setWriteStar(5)"></i>
                </div>
            </div>

            <div class="form-group" style="margin-bottom:1rem;">
                <label>Your Review</label>
                <textarea id="write-review-comment" name="comment" rows="4" maxlength="200" required style="width:100%;border:1.5px solid var(--border);border-radius:8px;padding:10px;font-family:'Poppins',sans-serif;"></textarea>
                <div id="write-review-counter" style="margin-top:6px;font-size:11px;color:var(--text-light);text-align:right;">0 / 200 characters</div>
            </div>

            <div class="form-group" style="margin-bottom:1.3rem;">
                <label>Upload Photo (optional)</label>
                <input type="file" name="photo" accept="image/*" style="width:100%;border:1.5px solid var(--border);border-radius:8px;padding:8px;" />
            </div>

            <button type="submit" id="write-review-submit" class="write-review-btn" style="width:100%;justify-content:center;">
                <i class="fa-solid fa-paper-plane"></i> Post Review
            </button>
        }
    </div>
</div>

@section scripts {
    <script>
window.reviewsData = {
    // eunice modified: pass login state from server so JS can gate like/comment/report/write
    isLoggedIn: @(Session["UserId"] != null ? "true" : "false"),
    currentFilters: {
        sortBy: '@(hasSortSelection ? (string)ViewBag.SortBy : "")',
        category: '@(hasCategorySelection ? (string)ViewBag.Category : "")',
        photoFilter: '@(hasPhotoSelection ? (string)ViewBag.PhotoFilter : "")'
    },
    urls: {
        index: '@Url.Action("Index", "Reviews")',
        like: '@Url.Action("Like", "Reviews")',
        report: '@Url.Action("Report", "Reviews")'
    },
    openReviewId: @(ViewBag.OpenReviewId ?? 0),
    reviews: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
        Model.Select((r, i) => new {
            id = r.Id,
            name = r.CustomerName,
            stars = r.Stars,
            comment = r.Comment,
            date = r.DatePosted.ToString("MMM dd, yyyy"),
            productName = MockData.Products.FirstOrDefault(p => p.Id == r.ProductId)?.Name ?? "",
            productId = r.ProductId,
            likes = r.Likes,
            reportCount = r.ReportCount,
            isReported = reportedIds.Contains(r.Id),
            isTextOnly = r.IsTextOnly,
            isEdited = r.IsEdited,
            editedAt = r.LastEditedAt.HasValue ? r.LastEditedAt.Value.ToString("o") : null,
            photoUrl = r.PhotoUrl,
            resolvedPhotoUrl = string.IsNullOrWhiteSpace(r.PhotoUrl) ? "" : Url.Content(r.PhotoUrl),
            color = colors[i % colors.Length],
            icon = icons[i % icons.Length],
            comments = (r.Comments ?? new List<Pawchase.Models.ReviewComment>()).Select(c => new {
                userName = c.UserName,
                text = c.Text,
                date = c.DatePosted.ToString("MMM dd, yyyy hh:mm tt")
            }).ToList()
        }).ToList()
    ))
};
    </script>
    <script src="~/Scripts/reviews.js"></script>
}
