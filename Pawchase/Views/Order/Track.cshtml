@using Pawchase.Models
@model List<Pawchase.Models.Order>
@{
    ViewBag.Title = "My Orders";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var tab = ViewBag.Tab as string ?? "All";
    var tabs = new[] { "All", "To Ship", "In Transit", "Out for Delivery", "Completed", "Cancelled", "Return/Refund" };
    var tabIcons = new Dictionary<string, string> {
        {"All","fa-solid fa-list-check"},
        {"To Ship","fa-solid fa-box"},
        {"In Transit","fa-solid fa-truck"},
        {"Out for Delivery","fa-solid fa-location-dot"},
        {"Completed","fa-solid fa-circle-check"},
        {"Cancelled","fa-solid fa-ban"},
        {"Return/Refund","fa-solid fa-rotate-left"}
    };
    var filtered = tab == "All" ? Model : Model.Where(o => o.Status == tab).ToList();
}
@section styles {
    <link href="@Url.Content("~/Content/css/account.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/css/order.css")" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}

<div class="page-hero"><h1>My Orders</h1><p>Track and manage your orders</p></div>

<section class="account-section">
    <div class="account-inner">
        <aside class="account-aside">
            <div class="acct-header">
                <div class="acct-avatar"><i class="fa-solid fa-box"></i></div>
                <div class="acct-name">@Session["UserName"]</div>
                <div class="acct-email">@Session["UserEmail"]</div>
            </div>
            <nav class="acct-nav">
                @foreach (var t in tabs)
                {
                    <a href="@Url.Action("Track","Order",new{tab=t})" class='acct-tab @(tab==t?"active":"")'>
                        <i class="@tabIcons[t]"></i> @t
                    </a>
                }
            </nav>
        </aside>

        <div>
            @if (TempData["Success"] != null)
            {
                <div style="background:rgba(46,204,113,0.1);border:1px solid rgba(46,204,113,0.3);color:#1e8449;border-radius:var(--radius-sm);padding:12px 16px;font-size:13px;margin-bottom:1rem;display:flex;align-items:center;gap:8px;">
                    <i class="fa-solid fa-circle-check"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div style="background:rgba(224,85,85,0.08);border:1px solid rgba(224,85,85,0.25);color:#c0392b;border-radius:var(--radius-sm);padding:12px 16px;font-size:13px;margin-bottom:1rem;display:flex;align-items:center;gap:8px;">
                    <i class="fa-solid fa-triangle-exclamation"></i> @TempData["Error"]
                </div>
            }

            @if (!filtered.Any())
            {
                var emptyIcon = tabIcons.ContainsKey(tab) ? tabIcons[tab] : "fa-solid fa-list-check";
                <div style="text-align:center;padding:4rem 2rem;color:var(--text-light)">
                    <i class="@emptyIcon" style="font-size:3rem;margin-bottom:1rem;display:block;color:var(--blue);opacity:.5"></i>
                    <p>No orders @(tab != "All" ? "in this category" : "yet").</p>
                    <a href="@Url.Action("Index","Product")" class="btn-primary" style="margin-top:1rem;display:inline-flex">Start Shopping</a>
                </div>
            }

            @foreach (var order in filtered.OrderByDescending(o => o.OrderDate))
            {
                string pillClass = order.Status == "To Ship" ? "sp-ship"
                                 : order.Status == "In Transit" ? "sp-transit"
                                 : order.Status == "Out for Delivery" ? "sp-delivery"
                                 : order.Status == "Completed" ? "sp-done"
                                 : order.Status == "Cancelled" ? "sp-cancel"
                                 : order.Status == "Return/Refund" ? "sp-refund"
                                 : "sp-ship";

                var snapList = order.Snapshots != null && order.Snapshots.Any()
                    ? order.Snapshots
                    : (order.Items != null
                        ? order.Items.Select(i => new Pawchase.Models.OrderItemSnapshot
                        {
                            ProductId = i.Product.Id,
                            ProductName = i.Product.Name,
                            ProductImageUrl = i.Product.ImageUrl,
                            VariantImageUrl = i.SelectedVariant?.ImageUrl,
                            Quantity = i.Quantity,
                            UnitPrice = i.Product.Price
                        }).ToList()
                        : new List<Pawchase.Models.OrderItemSnapshot>());

                var firstProductId = snapList.Any() ? snapList.First().ProductId : 0;
                var firstProductName = snapList.Any() ? snapList.First().ProductName : "";

                <div class="order-card">
                    <div class="order-card-head">
                        <div>
                            <strong>@order.ReferenceNumber</strong>
                            <small>@order.OrderDate.ToString("MMMM dd, yyyy")</small>
                        </div>
                        <span class="status-pill @pillClass">@order.Status</span>
                    </div>

                    <!-- Thumbnails -->
                    <div class="order-items-row">
                        @foreach (var snap in snapList.Take(3))
                        {
                            var thumbImg = !string.IsNullOrEmpty(snap.VariantImageUrl) ? snap.VariantImageUrl : snap.ProductImageUrl;
                            <div class="order-item-thumb" style="overflow:hidden;border-radius:6px;">
                                @if (!string.IsNullOrEmpty(thumbImg))
                                {
                                    <img src="@thumbImg" alt="@snap.ProductName"
                                         style="width:100%;height:100%;object-fit:cover;border-radius:6px;"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                    <i class="fa-solid fa-bone" style="display:none;margin:auto;"></i>
                                }
                                else
                                {
                                    <i class="fa-solid fa-bone" style="margin:auto;"></i>
                                }
                            </div>
                        }
                        @if (snapList.Count > 3)
                        {
                            <span style="font-size:11px;color:var(--text-light);align-self:center">+@(snapList.Count - 3) more</span>
                        }
                    </div>

                    <!-- Footer -->
                    <div class="order-card-foot">
                        <span class="order-total">Total: &#8369;@order.Total.ToString("N2")</span>
                        <div class="order-actions">

                            <!-- Always: See Details -->
                            <button class="btn-sm outline" onclick="openDetails('@order.ReferenceNumber')">
                                <i class="fa-solid fa-receipt"></i> See Details
                            </button>

                            @* ── TO SHIP: Cancel button (15-min window) ── *@
                            @if (order.Status == "To Ship")
                            {
                                var minutesElapsed = (DateTime.Now - order.OrderDate).TotalMinutes;
                                if (minutesElapsed < 15)
                                {
                                    <button class="btn-sm danger"
                                            onclick="openCancelModal('@order.ReferenceNumber')">
                                        <i class="fa-solid fa-ban"></i> Cancel Order
                                    </button>
                                }
                            }

                            @* ── OUT FOR DELIVERY: Received + Return/Refund ── *@
                            @if (order.Status == "Out for Delivery")
                            {
                                <button class="btn-sm primary"
                                        onclick="openReceivedModal('@order.ReferenceNumber')">
                                    <i class="fa-solid fa-check"></i> Received
                                </button>
                                if (!order.HasRefundRequest)
                                {
                                    <button class="btn-sm danger"
                                            onclick="openReturnRefundModal('@order.ReferenceNumber','@order.Total.ToString("N2")')">
                                        <i class="fa-solid fa-rotate-left"></i> Return/Refund
                                    </button>
                                }
                            }

                            @* ── COMPLETED: Rate + Return/Refund ── *@
                            @if (order.Status == "Completed")
                            {
                                if (!order.IsReviewed)
                                {
                                    <button class="btn-sm primary"
                                            onclick="openReviewModal('@order.ReferenceNumber','@firstProductId','@Html.Raw(firstProductName.Replace("'","\\'"))')">
                                        <i class="fa-regular fa-star"></i> Rate
                                    </button>
                                }
                                if (!order.HasRefundRequest)
                                {
                                    <button class="btn-sm danger"
                                            onclick="openReturnRefundModal('@order.ReferenceNumber','@order.Total.ToString("N2")')">
                                        <i class="fa-solid fa-rotate-left"></i> Return/Refund
                                    </button>
                                }
                                <button type="button" class="btn-sm outline"
                                        onclick="openReorderModal('@order.ReferenceNumber')">
                                    <i class="fa-solid fa-rotate-right"></i> Re-order
                                </button>
                            }

                            @* ── CANCELLED: Re-order ── *@
                            @if (order.Status == "Cancelled")
                            {
                                <button type="button" class="btn-sm outline"
                                        onclick="openReorderModal('@order.ReferenceNumber')">
                                    <i class="fa-solid fa-rotate-right"></i> Re-order
                                </button>
                            }

                        </div>
                    </div>

                    <!-- Hidden data block for See Details modal -->
                    <div id="details-@order.ReferenceNumber" class="order-detail-data" style="display:none"
                         data-ref="@order.ReferenceNumber"
                         data-date="@order.OrderDate.ToString("MMMM dd, yyyy")"
                         data-customer="@order.CustomerName"
                         data-address="@order.Address"
                         data-notes="@order.OrderNotes"
                         data-total="&#8369;@order.Total.ToString("N2")">
                        <div class="detail-items">
                            @foreach (var snap in snapList)
                            {
                                <div class="detail-item"
                                     data-name="@snap.ProductName"
                                     data-qty="@snap.Quantity"
                                     data-subtotal="&#8369;@((snap.UnitPrice * snap.Quantity).ToString("N2"))">
                                </div>
                            }
                        </div>
                    </div>

                    @* ── CANCEL hidden POST form ── *@
                    @if (order.Status == "To Ship")
                    {
                        using (Html.BeginForm("CancelOrder", "Order", FormMethod.Post, new { id = "cancel-form-" + order.ReferenceNumber, style = "display:none" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="referenceNumber" value="@order.ReferenceNumber" />
                            <input type="hidden" name="cancelReason" id="cancel-reason-val-@order.ReferenceNumber" />
                        }
                    }

                    @* ── RECEIVED hidden GET link ── *@
                    @if (order.Status == "Out for Delivery")
                    {
                        <a id="received-link-@order.ReferenceNumber"
                           href="@Url.Action("MarkReceived","Order",new{referenceNumber=order.ReferenceNumber})"
                           style="display:none"></a>
                    }

                    @* ── REFUND hidden POST form ── *@
                    @if (order.Status == "Out for Delivery" || order.Status == "Completed")
                    {
                        using (Html.BeginForm("RequestRefund", "Order", FormMethod.Post, new { id = "refund-form-" + order.ReferenceNumber, style = "display:none" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="referenceNumber" value="@order.ReferenceNumber" />
                            <input type="hidden" name="refundReason" id="refund-reason-val-@order.ReferenceNumber" />
                            <input type="hidden" name="gcashNumber" id="refund-gcash-val-@order.ReferenceNumber" />
                            <input type="hidden" name="refundEvidenceUrl" id="refund-evidence-val-@order.ReferenceNumber" />
                        }
                    }

                    @* ── REVIEW hidden POST form ── *@
                    @if (order.Status == "Completed")
                    {
                        using (Html.BeginForm("SubmitReview", "Order", FormMethod.Post, new { id = "review-form-" + order.ReferenceNumber, style = "display:none" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" id="review-productId-@order.ReferenceNumber" value="@firstProductId" />
                            <input type="hidden" name="referenceNumber" value="@order.ReferenceNumber" />
                            <input type="hidden" name="stars" id="review-stars-@order.ReferenceNumber" value="5" />
                            <input type="hidden" name="comment" id="review-comment-@order.ReferenceNumber" />
                            <input type="hidden" name="photoUrl" id="review-photo-@order.ReferenceNumber" />
                        }
                    }

                </div>
            }
        </div>
    </div>
</section>


<!-- ═══════════════════════════════════════════ -->
<!-- SEE DETAILS MODAL                           -->
<!-- ═══════════════════════════════════════════ -->
<div id="order-detail-modal" style="display:none;position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center;background:rgba(30,24,18,0.55);padding:1rem;" onclick="if(event.target===this)closeDetails()">
    <div style="background:#fff;border-radius:14px;width:100%;max-width:520px;box-shadow:0 20px 60px rgba(0,0,0,0.2);overflow:hidden;animation:modalIn .2s ease;">
        <div style="background:linear-gradient(135deg,#6b93b8,#4a7399);padding:1.2rem 1.5rem;display:flex;align-items:center;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:10px;">
                <i class="fa-solid fa-receipt" style="color:#fff;font-size:16px;"></i>
                <span style="color:#fff;font-weight:700;font-size:15px;">Order Details</span>
            </div>
            <button onclick="closeDetails()" style="background:rgba(255,255,255,0.2);border:none;color:#fff;width:30px;height:30px;border-radius:50%;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div style="padding:1.5rem;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;padding-bottom:1.2rem;border-bottom:1px solid rgba(210,196,180,0.4);margin-bottom:1.2rem;">
                <div>
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#a89880;margin-bottom:3px;">Reference Number</div>
                    <div id="modal-ref" style="font-size:13px;font-weight:700;color:#3a3226;"></div>
                </div>
                <div>
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#a89880;margin-bottom:3px;">Order Date</div>
                    <div id="modal-date" style="font-size:13px;font-weight:700;color:#3a3226;"></div>
                </div>
                <div>
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#a89880;margin-bottom:3px;">Customer</div>
                    <div id="modal-customer" style="font-size:13px;font-weight:700;color:#3a3226;"></div>
                </div>
                <div>
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#a89880;margin-bottom:3px;">Delivery Address</div>
                    <div id="modal-address" style="font-size:13px;font-weight:700;color:#3a3226;"></div>
                </div>
            </div>
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#a89880;margin-bottom:.6rem;">Items Ordered</div>
            <div id="modal-items" style="margin-bottom:1rem;"></div>
            <div id="modal-notes-wrap" style="display:none;background:rgba(129,166,198,.08);border-radius:6px;padding:9px 12px;margin-bottom:1rem;">
                <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#a89880;margin-bottom:3px;"><i class="fa-regular fa-note-sticky"></i> Order Notes</div>
                <div id="modal-notes" style="font-size:13px;color:#3a3226;line-height:1.5;"></div>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;padding-top:.75rem;border-top:2px solid rgba(210,196,180,0.5);">
                <span style="font-size:13px;font-weight:700;color:#3a3226;">Total Paid</span>
                <span id="modal-total" style="font-size:16px;font-weight:800;color:#4a7399;"></span>
            </div>
        </div>
    </div>
</div>


<!-- ═══════════════════════════════════════════ -->
<!-- CANCEL ORDER MODAL                          -->
<!-- ═══════════════════════════════════════════ -->
<div id="cancel-modal" onclick="if(event.target===this)closeCancelModal()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;padding:1rem;">
    <div style="background:#fff;border-radius:20px;width:90%;max-width:460px;box-shadow:0 24px 70px rgba(0,0,0,0.2);overflow:hidden;animation:modalIn .2s ease;">
        <!-- Header -->
        <div style="display:flex;align-items:center;padding:14px 18px;border-bottom:1px solid var(--border);">
            <div style="display:flex;align-items:center;gap:10px;">
                <div style="width:36px;height:36px;border-radius:50%;background:rgba(224,85,85,0.1);display:flex;align-items:center;justify-content:center;border:1.5px solid rgba(224,85,85,0.2);">
                    <i class="fa-solid fa-ban" style="font-size:13px;color:#e05555;"></i>
                </div>
                <div>
                    <strong style="font-size:14px;color:var(--text);">Cancel Order</strong>
                    <div id="cancel-ref-label" style="font-size:11px;color:var(--text-light);"></div>
                </div>
            </div>
            <button onclick="closeCancelModal()" style="margin-left:auto;background:none;border:none;color:var(--text-light);font-size:18px;cursor:pointer;"><i class="fa-solid fa-times"></i></button>
        </div>
        <!-- Body -->
        <div style="padding:18px;display:flex;flex-direction:column;gap:1rem;">
            <div class="form-group">
                <label style="font-size:13px;font-weight:600;color:var(--text-mid);display:flex;align-items:center;gap:6px;">
                    <i class="fa-solid fa-circle-question" style="color:var(--blue);"></i>
                    Reason for Cancellation <span style="color:#e05555;">*</span>
                </label>
                <select id="cancel-reason-select" style="padding:11px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:'Poppins',sans-serif;color:var(--text);outline:none;width:100%;background:#fff;appearance:none;">
                    <option value="">&mdash; Select a reason &mdash;</option>
                    <option value="Changed my mind">Changed my mind</option>
                    <option value="Ordered by mistake">Ordered by mistake</option>
                    <option value="Found a better price">Found a better price</option>
                    <option value="Delivery too slow">Delivery too slow</option>
                    <option value="Other">Other</option>
                </select>
                <div id="cancel-reason-error" style="font-size:11px;color:#e05555;display:none;margin-top:3px;">
                    <i class="fa-solid fa-triangle-exclamation"></i> Please select a reason.
                </div>
            </div>
            <div style="background:rgba(224,85,85,0.06);border:1px solid rgba(224,85,85,0.15);border-radius:var(--radius-sm);padding:10px 14px;font-size:12px;color:var(--text-mid);line-height:1.65;">
                <i class="fa-solid fa-circle-info" style="color:#e05555;margin-right:4px;"></i>
                Orders can only be cancelled within <strong>15 minutes</strong> of placing them and while in <strong>To Ship</strong> status. After the window closes, please use Return/Refund instead.
            </div>
        </div>
        <!-- Footer -->
        <div style="padding:12px 18px;border-top:1px solid var(--border);display:flex;gap:10px;justify-content:flex-end;background:#fdfcfb;">
            <button onclick="closeCancelModal()" style="padding:10px 22px;border-radius:50px;font-size:13px;font-weight:600;border:1.5px solid var(--border);background:#fff;color:var(--text-mid);cursor:pointer;font-family:'Poppins',sans-serif;">Keep Order</button>
            <button onclick="confirmCancel()" style="padding:10px 22px;border-radius:50px;font-size:13px;font-weight:700;background:linear-gradient(135deg,#e05555,#c0392b);color:#fff;border:none;cursor:pointer;font-family:'Poppins',sans-serif;display:inline-flex;align-items:center;gap:7px;box-shadow:0 4px 14px rgba(224,85,85,0.3);">
                <i class="fa-solid fa-ban"></i> Confirm Cancellation
            </button>
        </div>
    </div>
</div>


<!-- ═══════════════════════════════════════════ -->
<!-- RECEIVED CONFIRMATION MODAL                 -->
<!-- ═══════════════════════════════════════════ -->
<div id="received-modal" onclick="if(event.target===this)closeReceivedModal()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;padding:1rem;">
    <div style="background:#fff;border-radius:20px;padding:2rem;max-width:420px;width:90%;box-shadow:0 24px 70px rgba(61,107,140,0.2);text-align:center;animation:modalIn .2s ease;">
        <div style="width:62px;height:62px;border-radius:50%;background:linear-gradient(135deg,rgba(46,204,113,0.15),rgba(46,204,113,0.05));display:flex;align-items:center;justify-content:center;margin:0 auto 1.1rem;border:2px solid rgba(46,204,113,0.2);">
            <i class="fa-solid fa-box-open" style="font-size:1.5rem;color:#1e8449;"></i>
        </div>
        <div style="font-size:1.1rem;font-weight:800;color:var(--text);margin-bottom:.4rem;">Item Received?</div>
        <div style="font-size:13px;color:var(--text-mid);margin-bottom:1.5rem;line-height:1.65;">
            Confirm that you've received your order. It will be moved to <strong>Completed</strong>.
        </div>
        <div style="display:flex;gap:10px;justify-content:center;">
            <button onclick="closeReceivedModal()" style="padding:10px 24px;border-radius:50px;font-size:13px;font-weight:600;border:1.5px solid var(--border);background:#fff;color:var(--text-mid);cursor:pointer;font-family:'Poppins',sans-serif;">Not Yet</button>
            <button onclick="confirmReceived()" style="padding:10px 24px;border-radius:50px;font-size:13px;font-weight:700;background:linear-gradient(135deg,#2ecc71,#1e8449);color:#fff;border:none;cursor:pointer;font-family:'Poppins',sans-serif;display:inline-flex;align-items:center;gap:7px;box-shadow:0 4px 14px rgba(46,204,113,0.35);">
                <i class="fa-solid fa-check"></i> Yes, Received!
            </button>
        </div>
    </div>
</div>


<!-- ═══════════════════════════════════════════ -->
<!-- RETURN / REFUND MODAL                       -->
<!-- ═══════════════════════════════════════════ -->
<div id="return-refund-modal" onclick="if(event.target===this)closeReturnRefundModal()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:9999;align-items:center;justify-content:center;padding:1rem;">
    <div style="max-width:520px;width:90%;background:#fff;border-radius:20px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,0.35);display:flex;flex-direction:column;animation:modalIn .2s ease;">
        <!-- Header -->
        <div style="display:flex;align-items:center;padding:14px 18px;border-bottom:1px solid var(--border);flex-shrink:0;">
            <div style="display:flex;align-items:center;gap:10px;">
                <div style="width:36px;height:36px;border-radius:50%;background:rgba(224,85,85,0.1);display:flex;align-items:center;justify-content:center;border:1.5px solid rgba(224,85,85,0.2);">
                    <i class="fa-solid fa-rotate-left" style="font-size:13px;color:#e05555;"></i>
                </div>
                <div>
                    <strong style="font-size:14px;color:var(--text);">Return / Refund Request</strong>
                    <div id="rr-order-ref-label" style="font-size:11px;color:var(--text-light);"></div>
                </div>
            </div>
            <button onclick="closeReturnRefundModal()" style="margin-left:auto;background:none;border:none;color:var(--text-light);font-size:18px;cursor:pointer;"><i class="fa-solid fa-times"></i></button>
        </div>
        <!-- Body -->
        <div style="padding:18px;overflow-y:auto;display:flex;flex-direction:column;gap:1rem;">

            <!-- Reason -->
            <div class="form-group">
                <label style="font-size:13px;font-weight:600;color:var(--text-mid);display:flex;align-items:center;gap:6px;">
                    <i class="fa-solid fa-circle-question" style="color:var(--blue);"></i>
                    Reason for Return / Refund <span style="color:#e05555;">*</span>
                </label>
                <select id="rr-reason" style="padding:11px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:'Poppins',sans-serif;color:var(--text);outline:none;width:100%;background:#fff;appearance:none;" onchange="handleReasonChange(this.value)">
                    <option value="">&mdash; Select a reason &mdash;</option>
                    <option value="Wrong item delivered">Wrong item delivered</option>
                    <option value="Item damaged or defective">Item damaged or defective</option>
                    <option value="Item not as described">Item not as described</option>
                    <option value="Missing items in order">Missing items in order</option>
                    <option value="Changed my mind">Changed my mind</option>
                    <option value="Other">Other (please specify)</option>
                </select>
                <div id="rr-reason-error" style="font-size:11px;color:#e05555;display:none;margin-top:3px;"><i class="fa-solid fa-triangle-exclamation"></i> Please select a reason.</div>
