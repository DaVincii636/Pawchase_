                    </span>
                    <button id="rr-remove-btn" onclick="removeRRImage()" type="button"
                            style="display:none;background:none;border:none;font-size:11px;font-weight:700;color:#e05555;cursor:pointer;font-family:'Poppins',sans-serif;padding:0;display:none;align-items:center;gap:4px;">
