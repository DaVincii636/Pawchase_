@section scripts {
    <script src="@Url.Content("~/Scripts/account.js")"></script>
    <script>

        function openDetails(ref) {
            var data = document.getElementById('details-' + ref);
            if (!data) return;
            var itemsHtml = '';
            data.querySelectorAll('.detail-item').forEach(function (item) {
                itemsHtml += '<div style="display:flex;justify-content:space-between;font-size:13px;padding:6px 0;border-bottom:1px dashed rgba(210,196,180,0.35);">' +
                    '<span style="color:#3a3226;">' + item.dataset.name + ' <span style="color:#a89880;">x' + item.dataset.qty + '</span></span>' +
                    '<span style="font-weight:600;color:#3a3226;">' + item.dataset.subtotal + '</span></div>';
            });
            document.getElementById('modal-ref').textContent = data.dataset.ref;
            document.getElementById('modal-date').textContent = data.dataset.date;
            document.getElementById('modal-customer').textContent = data.dataset.customer;
            document.getElementById('modal-address').textContent = data.dataset.address;
            document.getElementById('modal-items').innerHTML = itemsHtml;
            document.getElementById('modal-total').textContent = data.dataset.total;
            var notes = data.dataset.notes;
            var notesWrap = document.getElementById('modal-notes-wrap');
            if (notes && notes.trim()) {
                document.getElementById('modal-notes').textContent = notes;
                notesWrap.style.display = 'block';
            } else {
                notesWrap.style.display = 'none';
            }
            document.getElementById('order-detail-modal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
        function closeDetails() {
            document.getElementById('order-detail-modal').style.display = 'none';
            document.body.style.overflow = '';
        }

        /* ─────────────────────────────────────────────
           CANCEL ORDER
        ───────────────────────────────────────────── */
        var _cancelRef = null;
        function openCancelModal(ref) {
            _cancelRef = ref;
            document.getElementById('cancel-ref-label').textContent = 'Order: ' + ref;
            document.getElementById('cancel-reason-select').value = '';
            document.getElementById('cancel-reason-error').style.display = 'none';
            document.getElementById('cancel-modal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
        function closeCancelModal() {
            document.getElementById('cancel-modal').style.display = 'none';
            document.body.style.overflow = '';
            _cancelRef = null;
        }
        function confirmCancel() {
            var reason = document.getElementById('cancel-reason-select').value;
            if (!reason) {
                document.getElementById('cancel-reason-error').style.display = 'block';
                return;
            }
            var reasonInput = document.getElementById('cancel-reason-val-' + _cancelRef);
            var form = document.getElementById('cancel-form-' + _cancelRef);
            if (!reasonInput || !form) return;
            reasonInput.value = reason;
            form.submit();
        }

        /* ─────────────────────────────────────────────
           RECEIVED
        ───────────────────────────────────────────── */
        var _receivedRef = null;
        function openReceivedModal(ref) {
            _receivedRef = ref;
            document.getElementById('received-modal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
        function closeReceivedModal() {
            document.getElementById('received-modal').style.display = 'none';
            document.body.style.overflow = '';
            _receivedRef = null;
        }
        function confirmReceived() {
            if (!_receivedRef) return;
            var link = document.getElementById('received-link-' + _receivedRef);
            if (link) window.location.href = link.href;
        }

        /* ─────────────────────────────────────────────
           RETURN / REFUND
        ───────────────────────────────────────────── */
        var _refundRef = null;
        function openReturnRefundModal(ref, amount) {
            _refundRef = ref;
            document.getElementById('rr-order-ref-label').textContent = 'Order: ' + ref;
            document.getElementById('rr-amount-display').textContent = '\u20B1' + amount;
            document.getElementById('rr-reason').value = '';
            document.getElementById('rr-gcash').value = '';
            document.getElementById('rr-other-text').value = '';
            document.getElementById('rr-other-wrap').style.display = 'none';
            document.getElementById('rr-reason-error').style.display = 'none';
            document.getElementById('rr-gcash-error').style.display = 'none';
            removeRRImage();
            document.getElementById('return-refund-modal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
        function closeReturnRefundModal() {
            document.getElementById('return-refund-modal').style.display = 'none';
            document.body.style.overflow = '';
        }
        function handleReasonChange(val) {
            document.getElementById('rr-other-wrap').style.display = val === 'Other' ? 'block' : 'none';
            if (val) document.getElementById('rr-reason-error').style.display = 'none';
        }
        function rrImgBoxClick() {
            // If a photo is already loaded, clicking the box does nothing (use Remove button)
            if (document.getElementById('rr-img-preview').style.display === 'block') return;
            document.getElementById('rr-img-input').click();
        }
        function previewRRImage(input) {
            if (!input.files || !input.files[0]) return;
            var reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('rr-img-preview').src = e.target.result;
                document.getElementById('rr-img-preview').style.display = 'block';
                document.getElementById('rr-img-placeholder').style.display = 'none';
                document.getElementById('rr-img-box').style.cursor = 'default';
                document.getElementById('rr-img-box').style.borderStyle = 'solid';
                document.getElementById('rr-img-box').style.borderColor = 'rgba(129,166,198,0.5)';
                document.getElementById('rr-remove-btn').style.display = 'inline-flex';
            };
            reader.readAsDataURL(input.files[0]);
        }
        function removeRRImage() {
            document.getElementById('rr-img-preview').src = '';
            document.getElementById('rr-img-preview').style.display = 'none';
            document.getElementById('rr-img-placeholder').style.display = 'flex';
            document.getElementById('rr-img-box').style.cursor = 'pointer';
            document.getElementById('rr-img-box').style.borderStyle = 'dashed';
            document.getElementById('rr-img-box').style.borderColor = 'rgba(129,166,198,0.4)';
            document.getElementById('rr-remove-btn').style.display = 'none';
            document.getElementById('rr-img-input').value = '';
        }
        function submitReturnRefund() {
            var reason = document.getElementById('rr-reason').value;
            var gcash = document.getElementById('rr-gcash').value.trim();
            var imgInput = document.getElementById('rr-img-input');

            var valid = true;

            // Reason validation
            if (!reason) {
                document.getElementById('rr-reason-error').style.display = 'block';
                valid = false;
            }

            // GCash validation
            if (gcash.length !== 11 || !/^\d{11}$/.test(gcash)) {
                document.getElementById('rr-gcash-error').style.display = 'block';
                valid = false;
            }

            // 🚨 IMAGE VALIDATION (THIS WAS MISSING)
            var imgInput = document.getElementById('rr-img-input');
            var imgError = document.getElementById('rr-img-error');

            if (!imgInput.files || imgInput.files.length === 0) {
                imgError.style.display = 'block';
                valid = false;
            } else {
                imgError.style.display = 'none';
            }

            // STOP EVERYTHING if invalid
            if (!valid) return;

            // Show confirmation modal
            document.getElementById('refund-confirm-modal').style.display = 'flex';
        }
        function closeRefundConfirmModal() {
            document.getElementById('refund-confirm-modal').style.display = 'none';
        }
        function doSubmitRefund() {
            var reason = document.getElementById('rr-reason').value;
            var gcash = document.getElementById('rr-gcash').value.trim();

            var finalReason = reason === 'Other'
                ? (document.getElementById('rr-other-text').value.trim() || 'Other')
                : reason;

            var reasonInput = document.getElementById('refund-reason-val-' + _refundRef);
            var gcashInput = document.getElementById('refund-gcash-val-' + _refundRef);
            var form = document.getElementById('refund-form-' + _refundRef);

            if (!form) return;

            reasonInput.value = finalReason;
            gcashInput.value = gcash;

            // Pass evidence image (base64) into the hidden form field
            var evidenceInput = document.getElementById('refund-evidence-val-' + _refundRef);
            if (evidenceInput) {
                var preview = document.getElementById('rr-img-preview');
                evidenceInput.value = (preview && preview.src && preview.style.display !== 'none') ? preview.src : '';
            }

            form.submit(); // ✅ only reaches here if EVERYTHING is valid
        }

        /* ─────────────────────────────────────────────
           WRITE REVIEW
        ───────────────────────────────────────────── */
        var _reviewRef = null;
        var _reviewStars = 5;
        var _starLabels = ['', '1 star \u2014 Poor', '2 stars \u2014 Fair', '3 stars \u2014 Good', '4 stars \u2014 Very Good', '5 stars \u2014 Excellent'];

        function openReviewModal(ref, productId, productName) {
            _reviewRef = ref;
            _reviewStars = 5;
            document.getElementById('review-modal-product-name').textContent = productName;
            document.getElementById('review-modal-comment').value = '';
            document.getElementById('review-stars-error').style.display = 'none';
            document.getElementById('review-comment-error').style.display = 'none';
            document.getElementById('review-img-preview').style.display = 'none';
            document.getElementById('review-img-preview').src = '';
            document.getElementById('review-img-placeholder').style.display = 'flex';
            document.getElementById('review-img-input').value = '';
            updateReviewStarUI(5);
            document.getElementById('review-modal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
        function closeReviewModal() {
            document.getElementById('review-modal').style.display = 'none';
            document.body.style.overflow = '';
        }
        function setReviewModalStar(val) { _reviewStars = val; updateReviewStarUI(val); document.getElementById('review-stars-error').style.display = 'none'; }
        function hoverReviewStar(val) { updateReviewStarUI(val, true); }
        function resetReviewStarHover() { updateReviewStarUI(_reviewStars); }
        function updateReviewStarUI(val, isHover) {
            document.getElementById('review-modal-stars-ui').querySelectorAll('i').forEach(function (s, i) {
                s.className = i < val ? 'fa-solid fa-star' : 'fa-regular fa-star';
                s.style.color = '#E6A520';
                s.style.opacity = i < val ? '1' : '0.4';
                s.style.transform = (i < val && !isHover) ? 'scale(1.1)' : '';
            });
            document.getElementById('review-modal-star-label').textContent = _starLabels[val] || '';
        }
        function previewReviewImage(input) {
            if (!input.files || !input.files[0]) return;
            var reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('review-img-preview').src = e.target.result;
                document.getElementById('review-img-preview').style.display = 'block';
                document.getElementById('review-img-placeholder').style.display = 'none';
            };
            reader.readAsDataURL(input.files[0]);
        }
        function submitReviewModal() {
            var comment = document.getElementById('review-modal-comment').value.trim();
            var valid = true;
            if (_reviewStars < 1) { document.getElementById('review-stars-error').style.display = 'block'; valid = false; }
            if (!comment) { document.getElementById('review-comment-error').style.display = 'block'; valid = false; }
            if (!valid) return;
            // Show confirmation modal
            document.getElementById('review-confirm-modal').style.display = 'flex';
        }
        function closeReviewConfirmModal() {
            document.getElementById('review-confirm-modal').style.display = 'none';
        }
        function doSubmitReview() {
            var comment = document.getElementById('review-modal-comment').value.trim();
            var form = document.getElementById('review-form-' + _reviewRef);
            if (!form) return;
            document.getElementById('review-stars-' + _reviewRef).value = _reviewStars;
            document.getElementById('review-comment-' + _reviewRef).value = comment;
            var photoInput = document.getElementById('review-photo-' + _reviewRef);
            if (photoInput) {
                var preview = document.getElementById('review-img-preview');
                photoInput.value = (preview && preview.src && preview.style.display !== 'none') ? preview.src : '';
            }
            form.submit();
        }

        /* ── ESC to close any modal ── */
        document.addEventListener('keydown', function (e) {
            if (e.key !== 'Escape') return;
            closeDetails(); closeCancelModal(); closeReceivedModal();
            closeReturnRefundModal(); closeReviewModal();
            closeReviewConfirmModal(); closeRefundConfirmModal();
        });


        // ── Re-order Confirmation Modal ──────────────────────────────
        function openReorderModal(refNum) {
            // Gather items from the hidden detail-data block
            var dataBlock = document.getElementById('details-' + refNum);
            var items = dataBlock ? dataBlock.querySelectorAll('.detail-item') : [];

            var itemsHtml = '';
            items.forEach(function(el) {
                var name = el.getAttribute('data-name') || '';
                var qty  = el.getAttribute('data-qty') || '1';
                var sub  = el.getAttribute('data-subtotal') || '';
                itemsHtml += '<div style="display:flex;align-items:center;justify-content:space-between;padding:7px 10px;background:rgba(129,166,198,.06);border-radius:8px;">'
                           + '<div style="display:flex;align-items:center;gap:8px;">'
                           + '<div style="width:26px;height:26px;border-radius:6px;background:rgba(129,166,198,.18);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><i class="fa-solid fa-bone" style="font-size:11px;color:var(--blue);"></i></div>'
                           + '<span style="font-size:13px;font-weight:600;color:var(--text);">' + name + '</span>'
                           + '</div>'
                           + '<div style="display:flex;align-items:center;gap:10px;flex-shrink:0;">'
                           + '<span style="font-size:11px;color:var(--text-light);">x' + qty + '</span>'
                           + '<span style="font-size:12px;font-weight:700;color:var(--blue-dark);">' + sub + '</span>'
                           + '</div>'
                           + '</div>';
            });

            if (!itemsHtml) {
                itemsHtml = '<p style="font-size:12px;color:var(--text-light);text-align:center;">No item details available.</p>';
            }

            document.getElementById('reorder-modal-ref').textContent = refNum;
            document.getElementById('reorder-modal-items').innerHTML = itemsHtml;
            document.getElementById('reorder-modal-confirm-btn').href = '/Cart/Reorder?referenceNumber=' + refNum;

            var modal = document.getElementById('reorder-modal');
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function closeReorderModal() {
            document.getElementById('reorder-modal').style.display = 'none';
            document.body.style.overflow = '';
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeReorderModal();
        });

    </script>

    <style>
        @@keyframes modalIn {
            from {
                opacity: 0;
                transform: scale(.95) translateY(10px);
            }

            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }
        /* force flex when inline style sets it */
        #cancel-modal[style*="flex"],
        #received-modal[style*="flex"],
        #return-refund-modal[style*="flex"],
        #review-modal[style*="flex"],
        #order-detail-modal[style*="flex"],
        #review-confirm-modal[style*="flex"],
        #refund-confirm-modal[style*="flex"] {
            display: flex !important;
        }

        #review-modal-stars-ui i:hover {
            transform: scale(1.2) translateY(-2px) !important;
        }

        #rr-img-box:hover {
            border-color: #4da6ff !important;
            background: #f5faff !important;
        }

        /* Cancelled pill &mdash; add to your order.css if not already there */
        .sp-cancel {
            background: rgba(100,100,100,0.1);
            color: #555;
            border: 1px solid rgba(100,100,100,0.2);
        }
    </style>
}
