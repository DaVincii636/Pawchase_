@model Pawchase.Models.Product
@{
    ViewBag.Title = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var related = ViewBag.RelatedProducts as List<Pawchase.Models.Product>;
    var reviews = ViewBag.Reviews as List<Pawchase.Models.Review>;
    var recentlyViewed = ViewBag.RecentlyViewed as List<Pawchase.Models.Product>;
    var disc = Model.IsOnSale ? (int)(((Model.OriginalPrice.Value - Model.Price) / Model.OriginalPrice.Value) * 100) : 0;
    var hasVariants = Model.Variants != null && Model.Variants.Any();
    double avgRating = ViewBag.AvgRating != null ? (double)ViewBag.AvgRating : 0;
    int reviewCount = ViewBag.ReviewCount != null ? (int)ViewBag.ReviewCount : 0;
}
@section styles {
    <link href="@Url.Content("~/Content/css/product.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/reviews.css")" rel="stylesheet" />
}

<section class="product-detail-section">
    <nav class="breadcrumb">
        <a href="@Url.Action("Index","Home")">Home</a>
        <i class="fa-solid fa-chevron-right"></i>
        <a href="@Url.Action("Index","Product")">Products</a>
        <i class="fa-solid fa-chevron-right"></i>
        <a href="@Url.Action("Index","Product",new{category=Model.Category})">@Model.Category</a>
        <i class="fa-solid fa-chevron-right"></i>
        <span>@Model.Name</span>
    </nav>

    <div class="product-detail-inner">
        <div class="detail-image">
            <img id="mainProductImg" src="@Model.ImageUrl" alt="@Model.Name"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
            <div class="img-fallback-lg" style="display:none;"><i class="fa-solid fa-bone"></i></div>
            @if (Model.IsOnSale && disc > 0)
            {<span class="discount-badge" style="position:absolute;top:12px;right:12px;">-@disc%</span>}
            @if (hasVariants)
            {
                <button class="img-nav-btn img-nav-left" id="imgNavLeft" onclick="navigateImage(-1)" title="Previous image">&lt;</button>
                <button class="img-nav-btn img-nav-right" id="imgNavRight" onclick="navigateImage(1)" title="Next image">&gt;</button>
            }
        </div>

        <div class="detail-info">
            <span class="detail-category">
                <i class="fa-solid fa-tag"></i> @Model.Category
                &nbsp;&middot;&nbsp;
                <i class="fa-solid fa-dog"></i> @Model.BreedSize
            </span>
            <h1>@Model.Name</h1>

            @* Average star rating *@
            @if (reviewCount > 0)
            {
                <div style="display:flex;align-items:center;gap:6px;">
                    <div style="display:flex;gap:2px;color:#E6A520;font-size:14px;">
                        @for (int s = 1; s <= 5; s++)
                        {
                            if (s <= Math.Floor(avgRating))
                            {<i class="fa-solid fa-star"></i> }
                            else if (s - avgRating < 1 && s - avgRating > 0)
                            { <i class="fa-solid fa-star-half-stroke"></i> }
                            else
                            { <i class="fa-regular fa-star"></i>}
                        }
                    </div>
                    <span style="font-size:13px;color:var(--text-mid);">@avgRating.ToString("F1") <span style="color:var(--text-light);">(@reviewCount review@(reviewCount != 1 ? "s" : ""))</span></span>
                </div>
            }

            <div class="detail-price">
                <span class="price-lg">&#8369;@Model.Price.ToString("N2")</span>
                @if (Model.IsOnSale)
                {
                    <span class="original-price-lg">&#8369;@Model.OriginalPrice.Value.ToString("N2")</span>
                    <span class="discount-badge">-@disc%</span>
                }
            </div>

            <p class="detail-description">@Model.Description</p>

            @if (hasVariants)
            {
                <div class="variant-section">
                    <span class="variant-label-title">Color / Style</span>
                    <div class="variant-thumbs" id="variantThumbs">
                        @{ int _pageThumbIdx = 0; }
                        @foreach (var v in Model.Variants)
                        {
                            <div class="variant-thumb"
                                 title="@v.Label"
                                 data-img="@v.ImageUrl"
                                 data-label="@v.Label"
                                 data-stock="@v.Stock"
                                 data-variant-index="@_pageThumbIdx"
                                 onclick="selectVariant(this, '@v.ImageUrl', '@v.Label', @v.Stock)">
                            @{ _pageThumbIdx++; }
                                @if (!string.IsNullOrEmpty(v.ImageUrl))
                                {
                                    <img src="@v.ImageUrl" alt="@(string.IsNullOrEmpty(v.Label) ? "Variant" : v.Label)"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                    <div class="variant-thumb-placeholder" style="display:none;"><i class="fa-solid fa-palette"></i></div>
                                }
                                else
                                {
                                    <div class="variant-thumb-placeholder"><i class="fa-solid fa-palette"></i></div>
                                }
                                @if (!string.IsNullOrEmpty(v.Label))
                                {<span>@v.Label</span>}
                            </div>
                        }
                    </div>

                </div>
            }

            @{
                // If the product has variants, total stock = sum of all variant stocks.
                var effectiveStock = hasVariants
                    ? Model.Variants.Sum(v => v.Stock)
                    : Model.Stock;
            }
            <div class="detail-meta">
                <div class="meta-item">
                    <i class="fa-solid fa-boxes-stacked"></i>
                    @if (hasVariants)
                    {<span id="stockDisplaySpan"><strong style="color:var(--text-mid);">Select a variant</strong> to see stock</span>}
                    else if (effectiveStock > 10)
                    {<span id="stockDisplaySpan"><strong style="color:#1e8449;">In Stock</strong> (@effectiveStock available)</span>}
                    else if (effectiveStock > 0)
                    {<span id="stockDisplaySpan"><strong style="color:#d4a017;">Low Stock</strong> (Only @effectiveStock left!)</span>}
                    else
                    {<span id="stockDisplaySpan"><strong style="color:#e05555;">Out of Stock</strong></span>}
                </div>
                <div class="meta-item">
                    <i class="fa-solid fa-truck"></i>
                    <span>Free shipping on orders over &#8369;500</span>
                </div>
            </div>

            @if (effectiveStock > 0)
            {
                <div class="detail-actions">
                    <button type="button" class="btn-primary btn-lg" onclick="openCartModal('addtocart')">
                        Add to Cart
                    </button>
                    <button type="button" class="btn-outline btn-lg" onclick="openCartModal('buynow')">
                        Buy Now
                    </button>
                </div>
            }
            else
            {
                <button class="btn-disabled btn-lg" disabled><i class="fa-solid fa-ban"></i> Out of Stock</button>
            }
        </div>
    </div>


    <!-- UNIFIED ADD-TO-CART / BUY NOW MODAL -->
    <div id="cartModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:1000;align-items:center;justify-content:center;">
        <div style="background:var(--white);border-radius:var(--radius-lg);padding:2rem;max-width:420px;width:93%;box-shadow:0 20px 60px rgba(0,0,0,0.2);max-height:90vh;overflow-y:auto;">

            <!-- Header -->
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.4rem;">
                <h3 id="cartModalTitle" style="font-size:1.05rem;font-weight:700;color:var(--text);margin:0;"></h3>
                <button onclick="closeCartModal()" style="background:none;border:none;font-size:1.3rem;color:var(--text-light);cursor:pointer;padding:2px 6px;line-height:1;">&times;</button>
            </div>

            <!-- Product preview -->
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:1.4rem;padding:12px;background:var(--peach);border-radius:var(--radius-sm);">
                <img id="cartModalImg" src="@Model.ImageUrl" alt="@Model.Name"
                     style="width:56px;height:56px;object-fit:cover;border-radius:8px;border:1px solid var(--border);"
                     onerror="this.style.display='none'" />
                <div>
                    <div style="font-weight:700;font-size:13px;color:var(--text);">@Model.Name</div>
                    <div style="font-size:14px;font-weight:700;color:var(--blue-dark);margin-top:3px;">&#8369;@Model.Price.ToString("N2")</div>
                </div>
            </div>

            @if (hasVariants)
            {
                <!-- Variant picker inside modal -->
                <div class="modal-variant-section" style="margin-bottom:1.4rem;">
                    <div style="font-size:11px;font-weight:700;color:var(--text-mid);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;">
                        Color / Style &nbsp;<span id="modalVariantSelected" style="color:var(--blue-dark);font-weight:700;"></span>
                    </div>
                    <div class="variant-thumbs" id="modalVariantThumbs">
                        @{ int _modalThumbIdx = 0; }
                        @foreach (var v in Model.Variants)
                        {
                            <div class="variant-thumb"
                                 title="@v.Label"
                                 data-img="@v.ImageUrl"
                                 data-label="@v.Label"
                                 data-stock="@v.Stock"
                                 data-variant-index="@_modalThumbIdx"
                                 onclick="selectModalVariant(this)">
                            @{ _modalThumbIdx++; }
                                @if (!string.IsNullOrEmpty(v.ImageUrl))
                                {
                                    <img src="@v.ImageUrl" alt="@(string.IsNullOrEmpty(v.Label) ? "Variant" : v.Label)"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                    <div class="variant-thumb-placeholder" style="display:none;"><i class="fa-solid fa-palette"></i></div>
                                }
                                else
                                {
                                    <div class="variant-thumb-placeholder"><i class="fa-solid fa-palette"></i></div>
                                }
                                @if (!string.IsNullOrEmpty(v.Label))
                                {<span>@v.Label</span>}
                            </div>
                        }
                    </div>
                    <div id="modalVariantAlert" style="display:none;margin-top:.6rem;padding:8px 12px;background:rgba(224,85,85,.1);border:1px solid rgba(224,85,85,.3);border-radius:8px;font-size:12px;color:#c94040;font-weight:600;">
                        <i class="fa-solid fa-triangle-exclamation"></i> Please select a variant to continue.
                    </div>
                </div>
            }

            <!-- Quantity stepper -->
            <div style="margin-bottom:1.5rem;">
                <div style="font-size:11px;font-weight:700;color:var(--text-mid);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px;">Quantity</div>
                <div class="qty-controls">
                    <button type="button" onclick="modalChangeQty(-1)">-</button>
                    <span id="modalQtyDisplay" style="min-width:32px;text-align:center;font-size:16px;font-weight:700;color:var(--text);">1</span>
                    <button type="button" onclick="modalChangeQty(1)">+</button>
                    <span id="modalStockAvail" style="font-size:12px;color:var(--text-light);margin-left:4px;">@(hasVariants ? "Select a variant" : "/ " + (Model.Stock) + " available")</span>
                </div>
            </div>

            <!-- Action buttons -->
            <div style="display:flex;gap:10px;">
                <button onclick="closeCartModal()" class="btn-outline" style="flex:1;padding:11px 0;font-size:13px;text-align:center;justify-content:center;display:flex;align-items:center;">Cancel</button>
                <button id="cartModalConfirmBtn" onclick="confirmCartModal()" class="btn-primary" style="flex:2;padding:11px 0;font-size:13px;text-align:center;justify-content:center;display:flex;align-items:center;gap:6px;"></button>
            </div>
        </div>
    </div>

    <!-- ADD TO CART SUCCESS TOAST -->
    <div id="cartToast" style="display:none;position:fixed;top:90px;right:16px;z-index:9999;background:#4caf50;border-radius:8px;padding:8px 12px;box-shadow:0 6px 18px rgba(0,0,0,.15);align-items:center;gap:6px;min-width:0;max-width:320px;">
        <i class="fa-solid fa-circle-check" style="color:#fff;font-size:14px;flex-shrink:0;"></i>
        <span id="cartToastMsg" style="font-size:12px;font-weight:600;color:#fff;">Added to cart!</span>
    </div>

    <!-- REVIEWS -->
    <div class="related-section" style="border-top:1px solid var(--border);padding-top:2rem;">
        <h2>
            <i class="fa-regular fa-star" style="color:#E6A520;"></i> Customer Reviews
            @if (reviewCount > 0)
            {<span style="font-size:14px;font-weight:400;color:var(--text-light);margin-left:8px;">(@reviewCount review@(reviewCount != 1 ? "s" : ""))</span>}
        </h2>
        @if (reviews != null && reviews.Any())
        {
            <div class="products-grid" style="margin-top:1rem;">
                @{
                    var revColors = new[] { "#ffe8d6", "#ddeaf3", "#f3e3d0", "#d4eadd", "#ecddd0", "#d4e4f0" };
                    var revIcons = new[] { "fa-dog", "fa-paw", "fa-bone", "fa-dog", "fa-paw", "fa-bone" };
                }
                @for (int ri = 0; ri < reviews.Count; ri++)
                {
                    var r = reviews[ri];
                    var rColor = revColors[ri % revColors.Length];
                    var rIcon = revIcons[ri % revIcons.Length];
                    <div class="review-card @(r.IsTextOnly ? "without-photo" : "with-photo")" id="review-@r.Id" onclick="openModal(@ri)" style="cursor:pointer;">
                        @if (!r.IsTextOnly)
                        {
                            <div class="review-card-photo" style="background:@rColor;">
                                @if (!string.IsNullOrWhiteSpace(r.PhotoUrl))
                                {
                                    <img src="@Url.Content(r.PhotoUrl)" alt="Review photo" onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex';" />
                                }
                                <i class="fa-solid @rIcon" style="font-size:3rem;color:rgba(0,0,0,.12);display:@(string.IsNullOrWhiteSpace(r.PhotoUrl) ? "inline-flex" : "none")"></i>
                            </div>
                        }
                        <div class="review-card-body">
                            <div class="review-card-header">
                                <div class="review-avatar">@((r.CustomerName ?? "A")[0])</div>
                                <div>
                                    <div class="review-name">@r.CustomerName</div>
                                    <div class="review-meta">@r.DatePosted.ToString("MMM dd, yyyy") · Verified Buyer</div>
                                </div>
                            </div>
                            <div class="review-stars">
                                @for (int s = 1; s <= 5; s++)
                                {<i class="@(s <= r.Stars ? "fa-solid" : "fa-regular") fa-star"></i>}
                            </div>
                            <p class="review-caption">"@r.Comment"</p>
                            <div class="review-actions">
                                <button class="review-action" data-review-id="@r.Id" onclick="event.stopPropagation();toggleLike(@r.Id,this)">
                                    <i class="fa-regular fa-heart"></i>
                                    <span>@r.Likes</span>
                                </button>
                                <button class="review-action" data-comment-review-id="@r.Id" onclick="event.stopPropagation();openModalComments(@ri)">
                                    <i class="fa-regular fa-comment"></i>
                                    <span>@(r.Comments?.Count ?? 0)</span>
                                </button>
                                <button class="review-action" data-report-review-id="@r.Id" onclick="event.stopPropagation();openReportModal(@r.Id)">
                                    <i class="fa-regular fa-flag"></i>
                                    <span>@r.ReportCount</span>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color:var(--text-light);font-size:13px;margin-top:1rem;">No reviews yet. Be the first to review this product!</p>
        }
    </div>

    <!-- REVIEW MODAL -->
    <div class="review-modal-overlay" id="review-modal-overlay" onclick="if(event.target===this)closeModal()">
        <div class="review-modal" id="review-modal">
            <div class="modal-photo-wrap">
                <div class="modal-photo" id="modal-photo"></div>
            </div>
            <div class="modal-info">
                <div class="modal-header">
                    <div class="modal-avatar" id="modal-avatar"></div>
                    <div>
                        <div class="modal-name-text" id="modal-name"></div>
                        <div class="modal-date-text" id="modal-date"></div>
                        <div id="modal-edited" class="modal-edited" style="display:none;"></div>
                    </div>
                    <button class="modal-close" onclick="closeModal()"><i class="fa-solid fa-times"></i></button>
                </div>
                <div class="modal-body">
                    <div class="modal-stars" id="modal-stars"></div>
                    <p class="modal-caption" id="modal-caption"></p>
                    <div class="modal-product" id="modal-product"></div>
                </div>
                <div class="modal-actions">
                    <button class="review-action" id="modal-like-btn" data-review-id="0" onclick="toggleLike(activeReview.id,this)">
                        <i class="fa-regular fa-heart"></i>
                        <span id="modal-likes"></span>
                    </button>
                    <button class="review-action" onclick="toggleCommentPanel()">
                        <i class="fa-regular fa-comment"></i>
                        <span id="modal-comment-count"></span>
                    </button>
                    <button class="review-action" id="modal-report-btn" data-report-review-id="0" onclick="openReportModal(activeReview.id)">
                        <i class="fa-regular fa-flag"></i>
                        <span id="modal-reports"></span>
                    </button>
                    <a class="view-product-link" id="modal-product-link" href="#">View Product</a>
                </div>
                <div class="modal-comments" id="modal-comments-panel">
                    <div class="modal-comments-head">
                        <strong class="modal-comments-title">Comments</strong>
                    </div>
                    <div class="modal-comments-list" id="modal-comments-list"></div>
                    @using (Html.BeginForm("AddComment", "Reviews", FormMethod.Post, new { @class = "comment-form", id = "modal-comment-form" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="reviewId" id="comment-review-id" />
                        <input type="hidden" name="returnUrl" id="comment-return-url" value="@Request.RawUrl" />
                        <input type="text" class="comment-input" name="commentText" maxlength="180" placeholder="Write a comment..." required />
                        <button type="submit" class="comment-submit">Send</button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- REPORT MODAL -->
    <div class="report-modal-overlay" id="report-modal-overlay" onclick="if(event.target===this)closeReportModal()">
        <div class="report-modal">
            <h3>Help us understand the issue with this review.</h3>
            <div class="report-options" id="report-options">
                <label class="report-option"><input type="radio" name="report-reason" value="Inappropriate content" onchange="toggleOtherInput(this)" /> Inappropriate content</label>
                <label class="report-option"><input type="radio" name="report-reason" value="Spam" onchange="toggleOtherInput(this)" /> Spam</label>
                <label class="report-option"><input type="radio" name="report-reason" value="Misleading or inaccurate information" onchange="toggleOtherInput(this)" /> Misleading or inaccurate information</label>
                <label class="report-option"><input type="radio" name="report-reason" value="Offensive or abusive language" onchange="toggleOtherInput(this)" /> Offensive or abusive language</label>
                <label class="report-option"><input type="radio" name="report-reason" value="Irrelevant content" onchange="toggleOtherInput(this)" /> Irrelevant content</label>
                <label class="report-option"><input type="radio" name="report-reason" value="Other" onchange="toggleOtherInput(this)" /> Other</label>
            </div>
            <input type="text" id="report-other-input" maxlength="150" placeholder="Please describe the issue..."
                   style="display:none;width:100%;margin-top:8px;padding:8px 10px;border:1.5px solid var(--border);border-radius:8px;font-family:'Poppins',sans-serif;font-size:12px;box-sizing:border-box;" />
            <div class="report-error" id="report-error"></div>
            <div class="report-actions">
                <button type="button" class="report-cancel" onclick="closeReportModal()">Cancel</button>
                <button type="button" class="report-submit" onclick="submitReport()">Submit</button>
            </div>
        </div>
    </div>

    <!-- RECENTLY VIEWED -->
    @if (recentlyViewed != null && recentlyViewed.Any())
    {
        <div class="related-section">
            <h2><i class="fa-regular fa-clock" style="color:var(--blue);"></i> Recently Viewed</h2>
            <div class="products-grid">
                @foreach (var p in recentlyViewed)
                {
                    var rDisc = p.IsOnSale ? (int)(((p.OriginalPrice.Value - p.Price) / p.OriginalPrice.Value) * 100) : 0;
                    <div class="product-card" onclick="window.location='@Url.Action("Details","Product",new{id=p.Id})'">
                        @if (p.IsOnSale && rDisc > 0)
                        {<span class="discount-pct-badge">-@rDisc%</span>}
                        @if (p.Stock == 0)
                        {<div class="oos-overlay"><span>Out of Stock</span></div>}
                        <div class="product-img">
                            <img src="@p.ImageUrl" alt="@p.Name" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                            <div class="img-fallback" style="display:none;"><i class="fa-solid fa-bone"></i></div>
                        </div>
                        <div class="product-info">
                            <span class="product-category">@p.Category &middot; @p.BreedSize</span>
                            <h3>@p.Name</h3>
                            <div class="product-price">
                                <span class="price">&#8369;@p.Price.ToString("N2")</span>
                                @if (p.IsOnSale)
                                {<span class="original-price">&#8369;@p.OriginalPrice.Value.ToString("N2")</span>}
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- RELATED -->
    @if (related != null && related.Any())
    {
        <div class="related-section">
            <h2>Related Products</h2>
            <div class="products-grid">
                @foreach (var p in related)
                {
                    var rDisc = p.IsOnSale ? (int)(((p.OriginalPrice.Value - p.Price) / p.OriginalPrice.Value) * 100) : 0;
                    var rLowStock = p.Stock > 0 && p.Stock <= 5;
                    <div class="product-card @(p.Stock==0?"oos-card":"")" onclick="@(p.Stock==0?"":"window.location='"+Url.Action("Details","Product",new{id=p.Id})+"'")">
                        @if (p.IsOnSale && rDisc > 0)
                        {<span class="discount-pct-badge">-@rDisc%</span>}
                        @if (p.Stock == 0)
                        {<div class="oos-overlay"><span>Out of Stock</span></div>}
                        else if (rLowStock)
                        {<span class="low-stock-badge"><i class="fa-solid fa-triangle-exclamation"></i> Only @p.Stock left!</span>}
                        <div class="product-img">
                            <img src="@p.ImageUrl" alt="@p.Name" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                            <div class="img-fallback" style="display:none;"><i class="fa-solid fa-bone"></i></div>
                        </div>
                        <div class="product-info">
                            <span class="product-category">@p.Category &middot; @p.BreedSize</span>
                            <h3>@p.Name</h3>
                            <div class="product-price">
                                <span class="price">&#8369;@p.Price.ToString("N2")</span>
                                @if (p.IsOnSale)
                                {<span class="original-price">&#8369;@p.OriginalPrice.Value.ToString("N2")</span><span class="discount-pct">-@rDisc%</span>}
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</section>

@section scripts {
    <script src="@Url.Content("~/Scripts/product.js")"></script>
    <script>
        // ── Reviews data for the interactive modal (mirrors Reviews/Index pattern) ──
        window.reviewsData = {
            isLoggedIn: @(Session["UserId"] != null ? "true" : "false"),
            currentFilters: { sortBy: '', category: '', photoFilter: '' },
            urls: {
                index: '@Url.Action("Index", "Reviews")',
                like: '@Url.Action("Like", "Reviews")',
                report: '@Url.Action("Report", "Reviews")'
            },
            openReviewId: 0,
            reviews: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
                (reviews ?? new List<Pawchase.Models.Review>()).Select((r, i) => new {
                    id = r.Id,
                    name = r.CustomerName,
                    stars = r.Stars,
                    comment = r.Comment,
                    date = r.DatePosted.ToString("MMM dd, yyyy"),
                    productName = Model.Name,
                    productId = Model.Id,
                    likes = r.Likes,
                    reportCount = r.ReportCount,
                    isReported = false,
                    isTextOnly = r.IsTextOnly,
                    isEdited = r.IsEdited,
                    editedAt = r.LastEditedAt.HasValue ? r.LastEditedAt.Value.ToString("o") : (string)null,
                    photoUrl = r.PhotoUrl,
                    resolvedPhotoUrl = string.IsNullOrWhiteSpace(r.PhotoUrl) ? "" : Url.Content(r.PhotoUrl),
                    color = new[] { "#ffe8d6","#ddeaf3","#f3e3d0","#d4eadd","#ecddd0","#d4e4f0" }[i % 6],
                    icon = new[] { "fa-dog","fa-paw","fa-bone","fa-dog","fa-paw","fa-bone" }[i % 6],
                    comments = (r.Comments ?? new List<Pawchase.Models.ReviewComment>()).Select(c => new {
                        userName = c.UserName,
                        text = c.Text,
                        date = c.DatePosted.ToString("MMM dd, yyyy hh:mm tt")
                    }).ToList()
                }).ToList()
            ))
        };
    </script>
    <script src="@Url.Content("~/Scripts/reviews.js")"></script>
    <script>
        // ── Variant stock map (NEW) ────────────────────────────────────────
        var variantStocks = {
            @if (hasVariants)
            {
                foreach (var v in Model.Variants)
                {
                    @:@Html.Raw("'" + v.Label?.Replace("'", "\\'") + "': " + v.Stock + ",")
                }
            }
        };
        var baseStock = @(hasVariants ? Model.Variants.Sum(v => v.Stock) : Model.Stock);

        // ── State ──────────────────────────────────────────────────────────
        var selectedVariantLabel = null;
        var selectedVariantIndex = null; // tracks which thumb by index (handles duplicate labels)
        var modalVariantLabel    = null;
        var modalQty             = 1;
        var maxStock             = @(hasVariants ? Model.Variants.Sum(v => v.Stock) : Model.Stock);
        var _cartModalMode       = 'addtocart';

        var _defaultImgUrl = '@Model.ImageUrl';
        var availEl = document.getElementById('modalStockAvail');
        if (availEl) availEl.textContent = _hasVariants ? 'Select a variant' : '/ ' + baseStock + ' available';

        // ── Update stock display (NEW) ─────────────────────────────────────
        var _hasVariants = @(hasVariants ? "true" : "false");

        function updateStockDisplay(label, explicitStock) {
            var stockEl = document.getElementById('stockDisplaySpan') || document.querySelector('.detail-meta .meta-item:first-child span');
            var actionDiv = document.querySelector('.detail-actions');
            var outOfStockBtn = document.querySelector('.btn-disabled');

            // When variants exist and none is selected, always show the prompt.
            if (_hasVariants && !label) {
                if (stockEl) stockEl.innerHTML = '<strong style="color:var(--text-mid);">Select a variant</strong> to see stock';
                maxStock = baseStock;
                var availEl = document.getElementById('modalStockAvail');
                if (availEl) availEl.textContent = 'Select a variant';
                if (baseStock > 0) {
                    if (outOfStockBtn) outOfStockBtn.style.display = 'none';
                    if (actionDiv) actionDiv.style.display = '';
                } else {
                    if (actionDiv) actionDiv.style.display = 'none';
                    if (outOfStockBtn) outOfStockBtn.style.display = '';
                }
                return;
            }

            // Use explicit stock if passed (avoids duplicate-label lookup bug),
            // otherwise fall back to variantStocks map or baseStock.
            var stock;
            if (explicitStock !== undefined && explicitStock !== null && !isNaN(explicitStock)) {
                stock = explicitStock;
            } else {
                var activeThumb = document.querySelector('#variantThumbs .variant-thumb.variant-active');
                stock = (activeThumb && activeThumb.getAttribute('data-stock') !== null)
                    ? parseInt(activeThumb.getAttribute('data-stock'), 10)
                    : (variantStocks[label] !== undefined ? variantStocks[label] : baseStock);
            }
            if (isNaN(stock)) stock = baseStock;

            maxStock = stock;
            if (modalQty > maxStock) {
                modalQty = Math.max(1, maxStock);
                var disp = document.getElementById('modalQtyDisplay');
                if (disp) disp.textContent = modalQty;
            }

            if (stockEl) {
                if (stock > 10) {
                    stockEl.innerHTML = '<strong style="color:#1e8449;">In Stock</strong> (' + stock + ' available)';
                } else if (stock > 0) {
                    stockEl.innerHTML = '<strong style="color:#d4a017;">Low Stock</strong> (Only ' + stock + ' left!)';
                } else {
                    stockEl.innerHTML = '<strong style="color:#e05555;">Out of Stock</strong>';
                }
            }

            var availEl = document.getElementById('modalStockAvail');
            if (availEl) availEl.textContent = '/ ' + stock + ' available';

            if (stock > 0) {
                if (outOfStockBtn) outOfStockBtn.style.display = 'none';
                if (actionDiv) actionDiv.style.display = '';
            } else {
                if (actionDiv) actionDiv.style.display = 'none';
                if (outOfStockBtn) outOfStockBtn.style.display = '';
            }
        }

        // ── Variant selector (main page thumbs) ───────────────────────────
        function selectVariant(el, imgUrl, label, stock) {
            var mainImg = document.getElementById('mainProductImg');
            var alreadyActive = el.classList.contains('variant-active');

            document.querySelectorAll('#variantThumbs .variant-thumb').forEach(function (t) {
                t.classList.remove('variant-active');
            });

            if (alreadyActive) {
                selectedVariantLabel = null;
                selectedVariantIndex = null;
                if (mainImg) {
                    mainImg.style.opacity = '0';
                    mainImg.style.transition = 'opacity .18s';
                    setTimeout(function () { mainImg.src = _defaultImgUrl; mainImg.style.opacity = '1'; }, 120);
                }
                updateStockDisplay(null);
            } else {
                el.classList.add('variant-active');
                selectedVariantLabel = label || null;
                selectedVariantIndex = el.getAttribute('data-variant-index');
                if (mainImg && imgUrl) {
                    mainImg.style.opacity = '0';
                    mainImg.style.transition = 'opacity .18s';
                    setTimeout(function () { mainImg.src = imgUrl; mainImg.style.opacity = '1'; }, 120);
                }
                // Pass stock directly so duplicate labels never cause wrong lookup
                updateStockDisplay(label, stock !== undefined ? stock : null);
            }

            var url = new URL(window.location.href);
            if (selectedVariantLabel) {
                url.searchParams.set('variant', selectedVariantLabel);
                var elIdx = el.getAttribute('data-variant-index');
                if (elIdx !== null) url.searchParams.set('variantIdx', elIdx);
                else url.searchParams.delete('variantIdx');
            } else {
                url.searchParams.delete('variant');
                url.searchParams.delete('variantIdx');
            }
            history.replaceState(null, '', url.toString());
        }

        // ── Modal variant selector ─────────────────────────────────────────
        function selectModalVariant(el) {
            var alreadyActive = el.classList.contains('variant-active');

            document.querySelectorAll('#modalVariantThumbs .variant-thumb').forEach(function (t) {
                t.classList.remove('variant-active');
            });

            var selEl = document.getElementById('modalVariantSelected');
            var alert = document.getElementById('modalVariantAlert');
            if (alert) alert.style.display = 'none';

            if (alreadyActive) {
                modalVariantLabel = null;
                if (selEl) selEl.textContent = '';
                var mainImg = document.getElementById('mainProductImg');
                if (mainImg) {
                    mainImg.style.opacity = '0';
                    setTimeout(function () { mainImg.src = _defaultImgUrl; mainImg.style.opacity = '1'; }, 120);
                }
                // Variant deselected — reset and show prompt
                maxStock = baseStock;
                modalQty = 1;
                document.getElementById('modalQtyDisplay').textContent = modalQty;
                var availEl = document.getElementById('modalStockAvail');
                if (availEl) availEl.textContent = _hasVariants ? 'Select a variant' : '/ ' + baseStock + ' available';
                // Sync page badge and page thumb highlights
                selectedVariantLabel = null;
                selectedVariantIndex = null;
                document.querySelectorAll('#variantThumbs .variant-thumb').forEach(function(t) { t.classList.remove('variant-active'); });
                updateStockDisplay(null);
            } else {
                el.classList.add('variant-active');
                modalVariantLabel = el.getAttribute('data-label') || null;
                if (selEl) selEl.textContent = modalVariantLabel ? modalVariantLabel : '';
                var img = el.getAttribute('data-img');
                var mainImg = document.getElementById('mainProductImg');
                if (mainImg && img) {
                    mainImg.style.opacity = '0';
                    setTimeout(function () { mainImg.src = img; mainImg.style.opacity = '1'; }, 120);
                }
                // Read stock directly from the element's data-stock attribute
                var vStock = parseInt(el.getAttribute('data-stock'), 10);
                if (isNaN(vStock)) vStock = baseStock;
                maxStock = vStock;
                modalQty = Math.min(modalQty, Math.max(1, maxStock));
                document.getElementById('modalQtyDisplay').textContent = modalQty;
                var availEl = document.getElementById('modalStockAvail');
                if (availEl) availEl.textContent = '/ ' + vStock + ' available';
                // Sync page badge and page thumb highlight — use index so duplicate labels never mismatch
                selectedVariantLabel = modalVariantLabel;
                var variantIdx = el.getAttribute('data-variant-index');
                selectedVariantIndex = variantIdx;
                document.querySelectorAll('#variantThumbs .variant-thumb').forEach(function(t) {
                    t.classList.toggle('variant-active', t.getAttribute('data-variant-index') === variantIdx);
                });
                updateStockDisplay(modalVariantLabel, vStock);
            }
        }

        // eunice modified: login check
        var _isLoggedIn = @(Session["UserId"] != null ? "true" : "false");
        var _loginUrl = '@Url.Action("Login","Account")';
        function showLoginPopup() {
            window.location.href = _loginUrl + '?returnUrl=' + encodeURIComponent(window.location.pathname + window.location.search);
        }

        // ── Open unified modal ─────────────────────────────────────────────
        function openCartModal(mode) {
            if (!_isLoggedIn) { showLoginPopup(); return; }
            _cartModalMode = mode;

            var title   = document.getElementById('cartModalTitle');
            var confirm = document.getElementById('cartModalConfirmBtn');
            if (mode === 'buynow') {
                title.textContent   = 'Buy Now';
                confirm.textContent = 'Proceed to Checkout';
            } else {
                title.textContent   = 'Add to Cart';
                confirm.textContent = 'Add to Cart';
            }

            var thumbs = document.querySelectorAll('#modalVariantThumbs .variant-thumb');
            if (thumbs.length > 0) {
                var matched = false;
                thumbs.forEach(function (t) {
                    t.classList.remove('variant-active');
                    // Use index-based match so duplicate labels don't select wrong thumb
                    if (selectedVariantIndex !== null && t.getAttribute('data-variant-index') === selectedVariantIndex) {
                        t.classList.add('variant-active');
                        matched = true;
                    }
                });
                var active = matched ? document.querySelector('#modalVariantThumbs .variant-thumb.variant-active') : null;
                modalVariantLabel = active ? active.getAttribute('data-label') : null;
                var selEl = document.getElementById('modalVariantSelected');
                if (selEl) selEl.textContent = modalVariantLabel ? modalVariantLabel : '';
            } else {
                modalVariantLabel = null;
            }

            modalQty = 1;
            document.getElementById('modalQtyDisplay').textContent = modalQty;

            // Set maxStock and avail label based on selected variant (or prompt if none)
            var activeVariantLabel = modalVariantLabel;
            var preActiveThumb = modalVariantLabel
                ? document.querySelector('#modalVariantThumbs .variant-thumb.variant-active')
                : null;
            if (preActiveThumb && preActiveThumb.getAttribute('data-stock') !== null) {
                maxStock = parseInt(preActiveThumb.getAttribute('data-stock'), 10);
                if (isNaN(maxStock)) maxStock = baseStock;
                var availEl = document.getElementById('modalStockAvail');
                if (availEl) availEl.textContent = '/ ' + maxStock + ' available';
            } else if (_hasVariants) {
                maxStock = baseStock;
                var availEl = document.getElementById('modalStockAvail');
                if (availEl) availEl.textContent = 'Select a variant';
            } else {
                maxStock = baseStock;
                var availEl = document.getElementById('modalStockAvail');
                if (availEl) availEl.textContent = '/ ' + maxStock + ' available';
            }
            var va = document.getElementById('modalVariantAlert');
            if (va) va.style.display = 'none';

            document.getElementById('cartModal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function closeCartModal() {
            document.getElementById('cartModal').style.display = 'none';
            document.body.style.overflow = '';
        }

        function modalChangeQty(delta) {
            modalQty = Math.max(1, Math.min(maxStock, modalQty + delta));
            document.getElementById('modalQtyDisplay').textContent = modalQty;
        }

        // ── Confirm: Add to Cart (AJAX) or Buy Now (redirect) ─────────────
        function confirmCartModal() {
            var hasVariants = @(hasVariants ? "true" : "false");
            if (hasVariants && !modalVariantLabel) {
                var va = document.getElementById('modalVariantAlert');
                if (va) va.style.display = 'block';
                return;
            }

            var addUrl    = '@Url.Action("Add","Cart")';
            var buyNowUrl = '@Url.Action("BuyNow","Cart")';
            var productId = @Model.Id;

            if (_cartModalMode === 'buynow') {
                var url = buyNowUrl + '?id=' + productId
                    + '&qty=' + modalQty
                    + (modalVariantLabel ? '&variantLabel=' + encodeURIComponent(modalVariantLabel) : '');
                window.location.href = url;
                return;
            }

            var returnUrl = window.location.pathname + window.location.search;
            var url = addUrl + '?id=' + productId
                + '&qty=' + modalQty
                + (modalVariantLabel ? '&variantLabel=' + encodeURIComponent(modalVariantLabel) : '')
                + '&returnUrl=' + encodeURIComponent(returnUrl);

            closeCartModal();
            fetch(url, { method: 'GET', redirect: 'follow' })
                .then(function (resp) {
                    return fetch(window.location.href);
                })
                .then(function (resp) { return resp.text(); })
                .then(function (html) {
                    var parser = new DOMParser();
                    var doc    = parser.parseFromString(html, 'text/html');
                    var newBadge  = doc.querySelector('.cart-badge');
                    var curBadge  = document.querySelector('.cart-badge');
                    var navCart   = document.querySelector('.nav-cart');
                    if (newBadge) {
                        if (curBadge) {
                            curBadge.textContent = newBadge.textContent;
                        } else if (navCart) {
                            var span = document.createElement('span');
                            span.className   = 'cart-badge';
                            span.textContent = newBadge.textContent;
                            navCart.appendChild(span);
                        }
                    }
                    showCartToast('@Model.Name added to cart!');
                })
                .catch(function () {
                    showCartToast('Added to cart!');
                });
        }

        // ── Toast notification ─────────────────────────────────────────────
        var _toastTimer = null;
        function showCartToast(msg) {
            var toast = document.getElementById('cartToast');
            var msgEl = document.getElementById('cartToastMsg');
            if (!toast) return;
            if (msgEl) msgEl.textContent = msg;
            toast.style.display = 'flex';
            toast.style.opacity = '1';
            clearTimeout(_toastTimer);
            _toastTimer = setTimeout(function () {
                toast.style.opacity = '0';
                setTimeout(function () { toast.style.display = 'none'; toast.style.opacity = '1'; }, 400);
            }, 2800);
        }

        // ── Image navigation arrows ────────────────────────────────────────
        var _allImages    = [];
        var _currentImgIdx = 0;

        document.addEventListener('DOMContentLoaded', function () {
            var mainSrc = document.getElementById('mainProductImg')
                ? document.getElementById('mainProductImg').getAttribute('src') : '';
            _allImages = [mainSrc];
            document.querySelectorAll('#variantThumbs .variant-thumb').forEach(function (t) {
                var img = t.getAttribute('data-img');
                if (img) _allImages.push(img);
            });
            updateNavBtns();

            var urlParams      = new URLSearchParams(window.location.search);
            var variantFromUrl = urlParams.get('variant');
            var variantIdxFromUrl = urlParams.get('variantIdx');
            var thumbs         = document.querySelectorAll('#variantThumbs .variant-thumb');
            if (thumbs.length > 0) {
                var matchedThumb = null;
                if (variantIdxFromUrl !== null) {
                    // Prefer exact index match (set when navigating away from this page)
                    thumbs.forEach(function (t) {
                        if (t.getAttribute('data-variant-index') === variantIdxFromUrl) matchedThumb = t;
                    });
                }
                if (!matchedThumb && variantFromUrl) {
                    // Fall back to first label match
                    thumbs.forEach(function (t) {
                        if (!matchedThumb && t.getAttribute('data-label') === variantFromUrl) matchedThumb = t;
                    });
                }
                if (matchedThumb) {
                    var urlStock = parseInt(matchedThumb.getAttribute('data-stock'), 10);
                    selectVariant(matchedThumb, matchedThumb.getAttribute('data-img'), matchedThumb.getAttribute('data-label'), isNaN(urlStock) ? null : urlStock);
                } else {
                    selectedVariantLabel = null;
                }
            } else {
                selectedVariantLabel = null;
            }

            document.getElementById('cartModal').addEventListener('click', function (e) {
                if (e.target === this) closeCartModal();
            });
        });

        function navigateImage(dir) {
            _currentImgIdx = Math.max(0, Math.min(_allImages.length - 1, _currentImgIdx + dir));
            var mainImg = document.getElementById('mainProductImg');
            if (mainImg && _allImages[_currentImgIdx]) {
                mainImg.style.opacity = '0';
                mainImg.style.transition = 'opacity .18s';
                setTimeout(function () { mainImg.src = _allImages[_currentImgIdx]; mainImg.style.opacity = '1'; }, 120);
            }
            var thumbs = document.querySelectorAll('#variantThumbs .variant-thumb');
            thumbs.forEach(function (t) { t.classList.remove('variant-active'); });
            if (_currentImgIdx > 0 && thumbs[_currentImgIdx - 1]) {
                var activeThumb = thumbs[_currentImgIdx - 1];
                activeThumb.classList.add('variant-active');
                selectedVariantLabel = activeThumb.getAttribute('data-label') || null;
                selectedVariantIndex = activeThumb.getAttribute('data-variant-index');
                var thumbStock = parseInt(activeThumb.getAttribute('data-stock'), 10);
                updateStockDisplay(selectedVariantLabel, isNaN(thumbStock) ? null : thumbStock);
            } else {
                selectedVariantLabel = null;
                selectedVariantIndex = null;
                updateStockDisplay(null);
            }
            updateNavBtns();
        }

        function updateNavBtns() {
            var left  = document.getElementById('imgNavLeft');
            var right = document.getElementById('imgNavRight');
            if (left)  left.style.opacity  = _currentImgIdx === 0 ? '0.35' : '1';
            if (right) right.style.opacity = _currentImgIdx === _allImages.length - 1 ? '0.35' : '1';
        }

        // Sync arrow navigation with variant thumb clicks
        var _origSelectVariant = window.selectVariant;
        window.selectVariant = function (el, imgUrl, label, stock) {
            _origSelectVariant(el, imgUrl, label, stock);
            var thumbs = Array.from(document.querySelectorAll('#variantThumbs .variant-thumb'));
            var idx = thumbs.indexOf(el);
            _currentImgIdx = idx >= 0 ? idx + 1 : 0;
            updateNavBtns();
        };
    </script>
}