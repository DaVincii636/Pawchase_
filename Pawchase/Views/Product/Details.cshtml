@model Pawchase.Models.Product
@{
    ViewBag.Title = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var related = ViewBag.RelatedProducts as List<Pawchase.Models.Product>;
    var reviews = ViewBag.Reviews as List<Pawchase.Models.Review>;
    var disc = Model.IsOnSale ? (int)(((Model.OriginalPrice.Value - Model.Price) / Model.OriginalPrice.Value) * 100) : 0;
    var hasVariants = Model.Variants != null && Model.Variants.Any();
}
@section styles {
    <link href="@Url.Content("~/Content/css/product.css")" rel="stylesheet" />
}

<section class="product-detail-section">
    <nav class="breadcrumb">
        <a href="@Url.Action("Index","Home")">Home</a>
        <i class="fa-solid fa-chevron-right"></i>
        <a href="@Url.Action("Index","Product")">Products</a>
        <i class="fa-solid fa-chevron-right"></i>
        <a href="@Url.Action("Index","Product",new{category=Model.Category})">@Model.Category</a>
        <i class="fa-solid fa-chevron-right"></i>
        <span>@Model.Name</span>
    </nav>

    <div class="product-detail-inner">
        <div class="detail-image">
            <img id="mainProductImg" src="@Model.ImageUrl" alt="@Model.Name"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
            <div class="img-fallback-lg" style="display:none;"><i class="fa-solid fa-bone"></i></div>
            @if (Model.IsOnSale)
            {<span class="sale-badge-lg">SALE</span>}
            @if (Model.IsOnSale && disc > 0)
            {<span class="discount-badge" style="position:absolute;top:12px;right:12px;">-@disc%</span>}
        </div>

        <div class="detail-info">
            <span class="detail-category">
                <i class="fa-solid fa-tag"></i> @Model.Category
                &nbsp;&middot;&nbsp;
                <i class="fa-solid fa-dog"></i> @Model.BreedSize
            </span>
            <h1>@Model.Name</h1>

            <div class="detail-price">
                <span class="price-lg">&#8369;@Model.Price.ToString("N2")</span>
                @if (Model.IsOnSale)
                {
                    <span class="original-price-lg">&#8369;@Model.OriginalPrice.Value.ToString("N2")</span>
                    <span class="discount-badge">-@disc%</span>
                }
            </div>

            <p class="detail-description">@Model.Description</p>

            @if (hasVariants)
            {
                <div class="variant-section">
                    <span class="variant-label-title">Color / Style</span>
                    <div class="variant-thumbs" id="variantThumbs">
                        @{ int vIdx = 0; }
                        @foreach (var v in Model.Variants)
                        {
                            <div class="variant-thumb @(vIdx == 0 ? "variant-active" : "")"
                                 title="@v.Label"
                                 data-img="@v.ImageUrl"
                                 data-label="@v.Label"
                                 onclick="selectVariant(this, '@v.ImageUrl', '@v.Label')">
                                @if (!string.IsNullOrEmpty(v.ImageUrl))
                                {
                                    <img src="@v.ImageUrl" alt="@(string.IsNullOrEmpty(v.Label) ? "Variant" : v.Label)"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                    <div class="variant-thumb-placeholder" style="display:none;"><i class="fa-solid fa-palette"></i></div>
                                }
                                else
                                {
                                    <div class="variant-thumb-placeholder"><i class="fa-solid fa-palette"></i></div>
                                }
                                @if (!string.IsNullOrEmpty(v.Label))
                                {
                                    <span>@v.Label</span>
                                }
                            </div>
                            vIdx++;
                        }
                    </div>
                    @* Alert shown when user tries to add to cart without selecting a variant *@
                    <div id="variantAlert" style="display:none;margin-top:.6rem;padding:8px 12px;background:rgba(224,85,85,.1);border:1px solid rgba(224,85,85,.3);border-radius:8px;font-size:12px;color:#c94040;font-weight:600;">
                        <i class="fa-solid fa-triangle-exclamation"></i> Please select a variant before adding to cart.
                    </div>
                </div>
            }

            <div class="detail-meta">
                <div class="meta-item">
                    <i class="fa-solid fa-boxes-stacked"></i>
                    @if (Model.Stock > 10)
                    {<span><strong style="color:#1e8449;">In Stock</strong> (@Model.Stock available)</span>}
                else if (Model.Stock > 0)
                {<span><strong style="color:#d4a017;">Low Stock</strong> (Only @Model.Stock left!)</span>}
            else
            {<span><strong style="color:#e05555;">Out of Stock</strong></span>}
                </div>
                <div class="meta-item">
                    <i class="fa-solid fa-truck"></i>
                    <span>Free shipping on orders over &#8369;500</span>
                </div>
            </div>

            @if (Model.Stock > 0)
            {
                <div class="detail-actions">
                    @if (hasVariants)
                    {
                        @* When the product has variants, buttons pass the selected variant label via JS *@
                        <button type="button" class="btn-primary btn-lg" onclick="addToCartWithVariant('@Url.Action("Add","Cart")', @Model.Id, '@Url.Action("Index","Cart")')">
                            <i class="fa-solid fa-cart-plus"></i> Add to Cart
                        </button>
                        <button type="button" class="btn-outline btn-lg" onclick="addToCartWithVariant('@Url.Action("Add","Cart")', @Model.Id, '@Url.Action("Checkout","Cart")')">
                            <i class="fa-solid fa-bolt"></i> Buy Now
                        </button>
                    }
                    else
                    {
                        <a href="@Url.Action("Add","Cart",new{id=Model.Id,returnUrl=Request.Url.PathAndQuery})" class="btn-primary btn-lg">
                            <i class="fa-solid fa-cart-plus"></i> Add to Cart
                        </a>
                        <a href="@Url.Action("Add","Cart",new{id=Model.Id,returnUrl=Url.Action("Checkout","Cart")})" class="btn-outline btn-lg">
                            <i class="fa-solid fa-bolt"></i> Buy Now
                        </a>
                    }
                </div>
            }
            else
            {
                <button class="btn-disabled btn-lg" disabled><i class="fa-solid fa-ban"></i> Out of Stock</button>
            }
        </div>
    </div>

    <!-- REVIEWS -->
    <div class="related-section" style="border-top:1px solid var(--border);padding-top:2rem;">
        <h2><i class="fa-regular fa-star" style="color:#E6A520;"></i> Customer Reviews</h2>
        @if (reviews != null && reviews.Any())
        {
            <div class="products-grid" style="margin-top:1rem;">
                @foreach (var r in reviews)
                {
                    <div style="background:var(--white);border-radius:var(--radius);border:1.5px solid var(--border);padding:1.2rem;box-shadow:var(--shadow-card);">
                        <div style="display:flex;gap:3px;color:#E6A520;margin-bottom:.5rem;">
                            @for (int i = 1; i <= 5; i++)
                            {<i class="@(i<=r.Stars?"fa-solid":"fa-regular") fa-star" style="font-size:13px;"></i>}
                        </div>
                        <p style="font-size:13px;color:var(--text-mid);line-height:1.6;">"@r.Comment"</p>
                        <small style="font-size:11px;color:var(--text-light);margin-top:.4rem;display:block;">&mdash; @r.CustomerName &middot; Verified Buyer</small>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color:var(--text-light);font-size:13px;margin-top:1rem;">No reviews yet. Be the first to review this product!</p>
        }
    </div>

    <!-- RELATED -->
    @if (related != null && related.Any())
    {
        <div class="related-section">
            <h2>Related Products</h2>
            <div class="products-grid">
                @foreach (var p in related)
                {
                    var rDisc = p.IsOnSale ? (int)(((p.OriginalPrice.Value - p.Price) / p.OriginalPrice.Value) * 100) : 0;
                    var rLowStock = p.Stock > 0 && p.Stock <= 5;
                    <div class="product-card" onclick="window.location='@Url.Action("Details","Product",new{id=p.Id})'">
                        @if (p.IsOnSale)
                        {<span class="sale-badge">SALE</span>}
                        @if (p.IsOnSale && rDisc > 0)
                        {<span class="discount-pct-badge">-@rDisc%</span>}
                        @if (rLowStock)
                        {<span class="low-stock-badge"><i class="fa-solid fa-triangle-exclamation"></i> Only @p.Stock left!</span>}
                        <div class="product-img">
                            <img src="@p.ImageUrl" alt="@p.Name" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                            <div class="img-fallback" style="display:none;"><i class="fa-solid fa-bone"></i></div>
                        </div>
                        <div class="product-info">
                            <span class="product-category">@p.Category &middot; @p.BreedSize</span>
                            <h3>@p.Name</h3>
                            <div class="product-price">
                                <span class="price">&#8369;@p.Price.ToString("N2")</span>
                                @if (p.IsOnSale)
                                {
                                    <span class="original-price">&#8369;@p.OriginalPrice.Value.ToString("N2")</span>
                                    <span class="discount-pct">-@rDisc%</span>
                                }
                            </div>
                            <div class="product-actions">
                                <a href="@Url.Action("Details","Product",new{id=p.Id})" class="btn-outline-sm" onclick="event.stopPropagation()"><i class="fa-regular fa-eye"></i> View</a>
                                <a href="@Url.Action("Add","Cart",new{id=p.Id})" class="btn-primary-sm" onclick="event.stopPropagation()"><i class="fa-solid fa-cart-plus"></i> Add</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</section>

@section scripts {
    <script src="@Url.Content("~/Scripts/product.js")"></script>
    <script>
        // Tracks the currently selected variant label
        var selectedVariantLabel = null;

        function selectVariant(el, imgUrl, label) {
            // Swap main product image
            var mainImg = document.getElementById('mainProductImg');
            if (mainImg && imgUrl) {
                mainImg.style.opacity = '0';
                mainImg.style.transition = 'opacity .18s';
                setTimeout(function () {
                    mainImg.src = imgUrl;
                    mainImg.style.opacity = '1';
                }, 120);
            }
            // Update active state on thumbs
            var thumbs = document.querySelectorAll('#variantThumbs .variant-thumb');
            thumbs.forEach(function (t) { t.classList.remove('variant-active'); });
            el.classList.add('variant-active');

            // Store selected label and hide the alert
            selectedVariantLabel = label || null;
            var alert = document.getElementById('variantAlert');
            if (alert) alert.style.display = 'none';
        }

        function addToCartWithVariant(baseUrl, productId, returnUrl) {
            if (!selectedVariantLabel) {
                var alert = document.getElementById('variantAlert');
                if (alert) alert.style.display = 'block';
                return;
            }
            var url = baseUrl + '?id=' + productId +
                '&variantLabel=' + encodeURIComponent(selectedVariantLabel) +
                '&returnUrl=' + encodeURIComponent(returnUrl);
            window.location.href = url;
        }

        // Auto-select the first variant on page load
        document.addEventListener('DOMContentLoaded', function () {
            var firstThumb = document.querySelector('#variantThumbs .variant-thumb');
            if (firstThumb) {
                var img = firstThumb.getAttribute('data-img') || '';
                var label = firstThumb.getAttribute('data-label') || '';
                selectedVariantLabel = label || null;
            }

            // If the page was redirected back with ?variantRequired=1, flash the selector
            if (window.location.search.indexOf('variantRequired=1') !== -1) {
                var alert = document.getElementById('variantAlert');
                if (alert) alert.style.display = 'block';
                var section = document.querySelector('.variant-section');
                if (section) section.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    </script>
}
