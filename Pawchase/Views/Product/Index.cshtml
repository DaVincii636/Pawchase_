@model List<Pawchase.Models.Product>
@{
    ViewBag.Title = "Products";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var ratings = ViewBag.Ratings as System.Collections.Generic.Dictionary<int, dynamic>;
    var globalMin = (int)(ViewBag.GlobalMin ?? 0);
    var globalMax = (int)(ViewBag.GlobalMax ?? 2000);
    var curMin = ViewBag.MinPrice != null ? (int)ViewBag.MinPrice : globalMin;
    var curMax = ViewBag.MaxPrice != null ? (int)ViewBag.MaxPrice : globalMax;
    bool onSale = ViewBag.OnSale == true;
    bool fromHome = Request.QueryString["fromHome"] == "1";
    bool hasFilters = !fromHome && (ViewBag.Category != null || ViewBag.Size != null ||
                      ViewBag.Search != null || onSale ||
                      ViewBag.MinPrice != null || ViewBag.MaxPrice != null);
}
@section styles {
    <link href="@Url.Content("~/Content/css/product.css")" rel="stylesheet" />
}

<div class="page-hero"><h1>Our Products</h1><p>Everything your dog needs, all in one place</p></div>

<div class="filter-overlay" id="filterOverlay" onclick="toggleFilter()"></div>

<div class="product-toolbar-top">
    <button class="filter-toggle-btn" id="filterToggleBtn" onclick="toggleFilter()">
        <i class="fa-solid fa-sliders"></i> Filters
        @if (hasFilters)
        {
            <span id="filter-dot" style="background:#e05555;width:8px;height:8px;border-radius:50%;display:inline-block;margin-left:2px;vertical-align:middle;"></span>
        }
    </button>
    <div class="toolbar-search">
        <form method="get" action="@Url.Action("Index","Product")" class="toolbar-search-form" id="toolbarSearchForm">
            <input type="hidden" name="sort" value="@ViewBag.Sort" />
            <input type="hidden" name="category" value="@ViewBag.Category" />
            <input type="hidden" name="size" value="@ViewBag.Size" />
            <input type="hidden" name="onSale" value="@(onSale ? "true" : "")" />
            <input type="hidden" name="minPrice" value="@(ViewBag.MinPrice != null ? ViewBag.MinPrice.ToString() : "")" />
            <input type="hidden" name="maxPrice" value="@(ViewBag.MaxPrice != null ? ViewBag.MaxPrice.ToString() : "")" />
            <div class="search-input-wrap">
                <input type="text" name="search" id="toolbarSearchInput" placeholder="Search products..."
                       value="@ViewBag.Search" autocomplete="off" />
                <button type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
            </div>
        </form>
    </div>
    <div class="toolbar-right">
        <span id="resultCount">
            <strong id="resultNum">@Model.Count</strong> product@(Model.Count != 1 ? "s" : "") found
            @if (ViewBag.Category != null)
            {<text> in <strong>@ViewBag.Category</strong></text>}
            @if (ViewBag.Size != null)
            {<text> &middot; <strong>@ViewBag.Size</strong></text>}
            @if (onSale)
            {<text> &middot; <strong>On Sale</strong></text>}
        </span>

        @* Sort dropdown *@
        <select id="sortSelect" onchange="applySort(this.value)">
            <option value="default" @(ViewBag.Sort == "default" || ViewBag.Sort == null ? "selected" : "")>Default</option>
            <option value="price_asc" @(ViewBag.Sort == "price_asc" ? "selected" : "")>Price: Low to High</option>
            <option value="price_desc" @(ViewBag.Sort == "price_desc" ? "selected" : "")>Price: High to Low</option>
            <option value="sale" @(ViewBag.Sort == "sale" ? "selected" : "")>On Sale First</option>
            <option value="name" @(ViewBag.Sort == "name" ? "selected" : "")>Name A&ndash;Z</option>
        </select>
        @* Always rendered — JS shows/hides it so applySort can toggle it without a reload *@
        <a href="javascript:void(0)" id="sortClearLink" onclick="applySort('default')" class="clear-filters"
           style="@(ViewBag.Sort != null && ViewBag.Sort != "default" ? "" : "display:none;")">
            <i class="fa-solid fa-times"></i> Clear
        </a>
    </div>
</div>

<div class="products-wrapper">
    <aside class="filters" id="filterPanel">
        <h3><i class="fa-solid fa-sliders"></i> Filters</h3>
        <form method="get" action="@Url.Action("Index","Product")" class="filter-form" id="filterForm">
            <input type="hidden" name="sort" id="hSort" value="@ViewBag.Sort" />
            <input type="hidden" name="category" id="hCategory" value="@ViewBag.Category" />
            <input type="hidden" name="size" id="hSize" value="@ViewBag.Size" />
            <input type="hidden" name="onSale" id="hOnSale" value="@(onSale ? "true" : "")" />

            <div class="filter-group">
                <label>On Sale</label>
                <button type="button"
                        onclick="setFilter('onSale', @(onSale ? "''" : "'true'"))"
                        class="filter-btn @(onSale ? "active" : "")"
                        data-filter-key="onSale"
                        data-filter-val="@(onSale ? "" : "true")"
                        style="width:100%;text-align:center;border-radius:var(--radius-sm);">
                    <i class="fa-solid fa-tag"></i> @(onSale ? "Showing Sale Items" : "Show Sale Items Only")
                </button>
            </div>

            <div class="filter-group">
                <label>Breed Size</label>
                <div class="filter-options">
                    <button type="button" onclick="setFilter('size', '')" class="filter-btn @(ViewBag.Size==null?"active":"")" data-filter-key="size" data-filter-val="">All</button>
                    <button type="button" onclick="setFilter('size', 'Small')" class="filter-btn @(ViewBag.Size=="Small" ?"active":"")" data-filter-key="size" data-filter-val="Small">Small</button>
                    <button type="button" onclick="setFilter('size', 'Medium')" class="filter-btn @(ViewBag.Size=="Medium"?"active":"")" data-filter-key="size" data-filter-val="Medium">Medium</button>
                    <button type="button" onclick="setFilter('size', 'Large')" class="filter-btn @(ViewBag.Size=="Large" ?"active":"")" data-filter-key="size" data-filter-val="Large">Large</button>
                </div>
            </div>

            <div class="filter-group">
                <label>Category</label>
                <div class="filter-options vertical">
                    @foreach (var cat in new[] { "Food & Treats", "Accessories & Apparel", "Care & Hygiene", "Toys", "Health", "Others" })
                    {
                        <button type="button" onclick="setFilter('category', '@cat')" class="filter-btn @(ViewBag.Category==cat?"active":"")" data-filter-key="category" data-filter-val="@cat">@cat</button>
                    }
                    <button type="button" onclick="setFilter('category', '')" class="filter-btn @(ViewBag.Category==null?"active":"")" data-filter-key="category" data-filter-val="">All Categories</button>
                </div>
            </div>

            <div class="filter-group">
                <label>Price Range &nbsp;<span id="priceRangeLabel" style="font-weight:700;color:var(--blue-dark);">&#8369;@curMin &ndash; &#8369;@curMax</span></label>
                <div style="padding:0 4px;">
                    <input type="hidden" name="minPrice" id="minPriceInput" value="@(ViewBag.MinPrice != null ? ViewBag.MinPrice.ToString() : "")" />
                    <input type="hidden" name="maxPrice" id="maxPriceInput" value="@(ViewBag.MaxPrice != null ? ViewBag.MaxPrice.ToString() : "")" />
                    <div style="position:relative;height:28px;margin:8px 0;">
                        <input type="range" id="rangeMin" min="@globalMin" max="@globalMax" value="@curMin" step="50"
                               style="position:absolute;width:100%;pointer-events:none;" />
                        <input type="range" id="rangeMax" min="@globalMin" max="@globalMax" value="@curMax" step="50"
                               style="position:absolute;width:100%;pointer-events:none;" />
                    </div>
                    <button type="button" class="filter-btn" onclick="applyPriceFilter()"
                            style="width:100%;text-align:center;border-radius:var(--radius-sm);margin-top:6px;">
                        Apply Price Filter
                    </button>
                </div>
            </div>

            <div class="filter-group" style="margin-top:.5rem;border-top:1px solid var(--border);padding-top:1rem;">
                <button type="button" class="filter-btn"
                        onclick="resetAllFilters()"
                        style="display:flex;align-items:center;justify-content:center;gap:6px;width:100%;text-align:center;border-radius:var(--radius-sm);">
                    <i class="fa-solid fa-rotate-left"></i> Reset All Filters
                </button>
            </div>
        </form>
    </aside>

    <div class="product-main">
        <div class="no-products" id="noProducts" style="display:none;">
            <i class="fa-solid fa-magnifying-glass"></i>
            <h3>No products found</h3>
            <p>Try adjusting your search or filters.</p>
            <a href="@Url.Action("Index","Product")" class="btn-primary" style="margin-top:.5rem">View All</a>
        </div>

        @if (!Model.Any())
        {
            <div class="no-products">
                <i class="fa-solid fa-magnifying-glass"></i>
                <h3>No products found</h3>
                <p>Try adjusting your filters.</p>
                <a href="@Url.Action("Index","Product")" class="btn-primary" style="margin-top:.5rem">View All</a>
            </div>
        }
        else
        {
            <div class="products-grid" id="productsGrid">
                @foreach (var p in Model)
                {
                    var isOnSale = p.IsOnSale;
                    var disc = isOnSale ? (int)(((p.OriginalPrice.Value - p.Price) / p.OriginalPrice.Value) * 100) : 0;
                    var isLowStock = p.Stock > 0 && p.Stock <= 5;
                    var isOOS = p.Stock == 0;
                    var searchText = (p.Name + " " + p.Description + " " + p.Category + " " + p.BreedSize).ToLower();

                    double avgStars = 0;
                    int reviewCount = 0;
                    if (ratings != null && ratings.ContainsKey(p.Id))
                    {
                        avgStars = (double)ratings[p.Id].Avg;
                        reviewCount = (int)ratings[p.Id].Count;
                    }

                    <div class="product-card @(isOOS ? "oos-card" : "")"
                         data-search="@searchText"
                         onclick="@(isOOS ? "" : "window.location='" + Url.Action("Details","Product",new{id=p.Id}) + "'")">

                        @if (isOnSale && disc > 0)
                        {<span class="discount-pct-badge">-@disc%</span>}
                        @if (isOOS)
                        {
                            <div class="oos-overlay"><span>Out of Stock</span></div>
                        }
                        else if (isLowStock)
                        {
                            <span class="low-stock-badge"><i class="fa-solid fa-triangle-exclamation"></i> Only @p.Stock left!</span>
                        }

                        <div class="product-img">
                            <img src="@p.ImageUrl" alt="@p.Name" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                            <div class="img-fallback" style="display:none;"><i class="fa-solid fa-bone"></i></div>
                        </div>
                        <div class="product-info">
                            <span class="product-category">@p.Category &middot; @p.BreedSize</span>
                            <h3>@p.Name</h3>

                            @* Average rating display *@
                            @if (reviewCount > 0)
                            {
                                <div class="card-rating">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        if (s <= Math.Floor(avgStars))
                                        {
                                            <i class="fa-solid fa-star"></i>
                                        }
                                        else if (s - avgStars < 1 && s - avgStars > 0)
                                        {
                                            <i class="fa-solid fa-star-half-stroke"></i>
                                        }
                                        else
                                        {
                                            <i class="fa-regular fa-star"></i>
                                        }
                                    }
                                    <span>(@reviewCount)</span>
                                </div>
                            }

                            <div class="product-price">
                                <span class="price">&#8369;@p.Price.ToString("N2")</span>
                                @if (isOnSale)
                                {
                                    <span class="original-price">&#8369;@p.OriginalPrice.Value.ToString("N2")</span>
                                    <span class="discount-pct">-@disc%</span>
                                }
                            </div>

                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>


@section scripts {
    <script src="@Url.Content("~/Scripts/product.js")"></script>
    <script>
        // ── setFilter ────────────────────────────────────────────────────────────
        // Patches ONE filter param in the URL. Clicking an already-active non-All
        // button deselects it (reverts to "All" / no filter for that key).
        // Never touches the sort param — sort and filters are fully independent.
        function setFilter(key, value) {
            var url = new URL(window.location.href);

            // Toggle: if the button being clicked is already active, deselect it
            var currentVal = url.searchParams.get(key) || '';
            var clickedVal = (value === '' || value === null || value === undefined) ? '' : value;
            if (clickedVal !== '' && currentVal === clickedVal) {
                clickedVal = ''; // same active button clicked — deselect back to All
            }

            if (clickedVal === '') {
                url.searchParams.delete(key);
            } else {
                url.searchParams.set(key, clickedVal);
            }
            url.searchParams.set('panelOpen', '1');

            // Update button active states immediately (no flash)
            document.querySelectorAll('.filter-btn[data-filter-key="' + key + '"]').forEach(function(b) {
                b.classList.remove('active');
            });
            var activeBtn = document.querySelector('.filter-btn[data-filter-key="' + key + '"][data-filter-val="' + clickedVal + '"]');
            if (activeBtn) activeBtn.classList.add('active');

            // Update the filter dot
            syncFilterDot(url);

            // AJAX grid update
            fetchAndUpdate(url, function(url) {
                var hCat    = document.getElementById('hCategory');
                var hSize   = document.getElementById('hSize');
                var hOnSale = document.getElementById('hOnSale');
                if (hCat)    hCat.value    = url.searchParams.get('category') || '';
                if (hSize)   hSize.value   = url.searchParams.get('size')     || '';
                if (hOnSale) hOnSale.value = url.searchParams.get('onSale')   || '';
            });
        }

        // ── applySort ────────────────────────────────────────────────────────────
        function applySort(val) {
            var url = new URL(window.location.href);
            if (val === 'default' || val === '' || val === null) {
                url.searchParams.delete('sort');
            } else {
                url.searchParams.set('sort', val);
            }
            var sel = document.getElementById('sortSelect');
            if (sel) sel.value = (val && val !== 'default') ? val : 'default';
            var clearLink = document.getElementById('sortClearLink');
            if (clearLink) clearLink.style.display = (val && val !== 'default') ? '' : 'none';
            fetchAndUpdate(url);
        }

        // ── fetchAndUpdate ───────────────────────────────────────────────────────
        // Shared AJAX helper. Fetches the full page, splices grid + count into DOM.
        // Optional afterUpdate(url) callback runs after DOM is updated.
        function fetchAndUpdate(url, afterUpdate) {
            window.history.replaceState(null, '', url.toString());

            fetch(url.toString(), { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(function(r) {
                    if (!r.ok) throw new Error('bad response');
                    return r.text();
                })
                .then(function(html) {
                    var parser  = new DOMParser();
                    var doc     = parser.parseFromString(html, 'text/html');
                    var mainEl  = document.querySelector('.product-main');
                    var curGrid = document.getElementById('productsGrid');
                    var newGrid = doc.getElementById('productsGrid');
                    var curStaticNoP = document.querySelector('.no-products:not(#noProducts)');
                    var newStaticNoP = doc.querySelector('.no-products:not(#noProducts)');

                    if (newGrid) {
                        // Server returned products
                        if (curGrid) {
                            curGrid.innerHTML = newGrid.innerHTML;
                        } else {
                            if (curStaticNoP) curStaticNoP.remove();
                            if (mainEl) mainEl.appendChild(newGrid.cloneNode(true));
                        }
                        var jsNoP = document.getElementById('noProducts');
                        if (jsNoP) jsNoP.style.display = 'none';
                        var g = document.getElementById('productsGrid');
                        if (g) g.style.display = '';
                    } else {
                        // Server returned 0 products — show empty state
                        if (curGrid) curGrid.remove();
                        var jsNoP = document.getElementById('noProducts');
                        if (jsNoP) {
                            jsNoP.style.display = 'flex';
                        } else if (newStaticNoP && !curStaticNoP && mainEl) {
                            mainEl.appendChild(newStaticNoP.cloneNode(true));
                        }
                    }

                    // Update result count
                    var newCount = doc.getElementById('resultCount');
                    var curCount = document.getElementById('resultCount');
                    if (newCount && curCount) curCount.innerHTML = newCount.innerHTML;

                    // Keep sort UI in sync
                    var sortVal   = url.searchParams.get('sort');
                    var sel       = document.getElementById('sortSelect');
                    if (sel) sel.value = sortVal || 'default';
                    var clearLink = document.getElementById('sortClearLink');
                    if (clearLink) clearLink.style.display = (sortVal && sortVal !== 'default') ? '' : 'none';

                    if (typeof afterUpdate === 'function') afterUpdate(url);

                    animateCards();
                })
                .catch(function() { window.location.href = url.toString(); });
        }

        // ── syncFilterDot ────────────────────────────────────────────────────────
        function syncFilterDot(url) {
            var anyActive = ['category','size','onSale','minPrice','maxPrice','search']
                .some(function(k) { return !!url.searchParams.get(k); });
            var dot = document.getElementById('filter-dot');
            if (dot) dot.style.display = anyActive ? 'inline-block' : 'none';
        }

        // ── applyPriceFilter ─────────────────────────────────────────────────────
        function applyPriceFilter() {
            var rMin = document.getElementById('rangeMin');
            var rMax = document.getElementById('rangeMax');
            if (!rMin || !rMax) return;
            var lo = parseInt(rMin.value);
            var hi = parseInt(rMax.value);
            if (lo > hi) { var tmp = lo; lo = hi; hi = tmp; }
            var url  = new URL(window.location.href);
            var gMin = @globalMin;
            var gMax = @globalMax;
            if (lo <= gMin) { url.searchParams.delete('minPrice'); } else { url.searchParams.set('minPrice', lo); }
            if (hi >= gMax) { url.searchParams.delete('maxPrice'); } else { url.searchParams.set('maxPrice', hi); }
            url.searchParams.set('panelOpen', '1');
            syncFilterDot(url);
            var applyBtn = document.querySelector('[onclick="applyPriceFilter()"]');
            if (applyBtn) applyBtn.classList.add('active');
            fetchAndUpdate(url);
        }

        // ── resetAllFilters ──────────────────────────────────────────────────────
        // Clears ONLY filter params. Sort stays untouched.
        function resetAllFilters() {
            var url = new URL(window.location.href);
            ['category','size','onSale','minPrice','maxPrice','search'].forEach(function(k) {
                url.searchParams.delete(k);
            });
            url.searchParams.set('panelOpen', '1');

            document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
            document.querySelectorAll('.filter-btn[data-filter-val=""]').forEach(function(b) { b.classList.add('active'); });

            var rMin = document.getElementById('rangeMin');
            var rMax = document.getElementById('rangeMax');
            if (rMin) rMin.value = rMin.min;
            if (rMax) rMax.value = rMax.max;
            var label = document.getElementById('priceRangeLabel');
            if (label && rMin && rMax) label.innerHTML = '&#8369;' + rMin.min + ' &ndash; &#8369;' + rMax.max;

            var hCat    = document.getElementById('hCategory');   if (hCat)    hCat.value    = '';
            var hSize   = document.getElementById('hSize');        if (hSize)   hSize.value   = '';
            var hOnSale = document.getElementById('hOnSale');      if (hOnSale) hOnSale.value = '';

            var toolbarSearch = document.getElementById('toolbarSearchInput');
            if (toolbarSearch) toolbarSearch.value = '';

            syncFilterDot(url);
            fetchAndUpdate(url);
        }

        // ── animateCards ─────────────────────────────────────────────────────────
        function animateCards() {
            var cards = document.querySelectorAll('.product-card');
            cards.forEach(function(card, i) {
                card.style.opacity    = '0';
                card.style.transform  = 'translateY(12px)';
                card.style.transition = 'opacity .3s ease ' + (i * 0.04) + 's, transform .3s ease ' + (i * 0.04) + 's';
                setTimeout(function(c) { c.style.opacity = '1'; c.style.transform = 'translateY(0)'; }, 50, card);
            });
        }

        // ── Form submit: sync hidden inputs from live URL ─────────────────────────
        (function () {
            var form = document.getElementById('filterForm');
            if (!form) return;
            form.addEventListener('submit', function () {
                var url = new URL(window.location.href);
                ['category','size','onSale','sort'].forEach(function(k) {
                    var hidden = document.getElementById('h' + k.charAt(0).toUpperCase() + k.slice(1));
                    if (!hidden) return;
                    if (!hidden.value) hidden.value = url.searchParams.get(k) || '';
                });
                var panelInput = form.querySelector('input[name="panelOpen"]');
                if (!panelInput) {
                    panelInput = document.createElement('input');
                    panelInput.type  = 'hidden';
                    panelInput.name  = 'panelOpen';
                    form.appendChild(panelInput);
                }
                panelInput.value = '1';
            });
        })();

        // ── Dual-handle price range slider ───────────────────────────────────────
        (function () {
            var rMin  = document.getElementById('rangeMin');
            var rMax  = document.getElementById('rangeMax');
            var iMin  = document.getElementById('minPriceInput');
            var iMax  = document.getElementById('maxPriceInput');
            var label = document.getElementById('priceRangeLabel');
            if (!rMin || !rMax) return;

            function updateLabel() {
                var lo = parseInt(rMin.value);
                var hi = parseInt(rMax.value);
                if (lo > hi) { var tmp = lo; lo = hi; hi = tmp; }
                label.innerHTML = '&#8369;' + lo + ' &ndash; &#8369;' + hi;
                iMin.value = lo <= @globalMin ? '' : lo;
                iMax.value = hi >= @globalMax ? '' : hi;
            }

            rMin.style.pointerEvents = 'all';
            rMax.style.pointerEvents = 'all';
            rMin.addEventListener('input', updateLabel);
            rMax.addEventListener('input', updateLabel);
            updateLabel();
        })();
    </script>
}
