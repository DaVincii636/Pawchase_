@model List<Pawchase.Models.CartItem>
@{
    ViewBag.Title = "Checkout";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var subtotal = Model.Sum(c => c.Subtotal);
    var shipping = subtotal >= 500 ? 0 : 80;
    var total = subtotal + shipping;
}
@section styles {
    <link href="@Url.Content("~/Content/css/cart.css")" rel="stylesheet" />
    <style>
        /* ?? CHECKOUT CONFIRMATION MODAL ?? */
        .pc-modal-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,0.45); z-index: 1000;
            align-items: center; justify-content: center;
        }
        .pc-modal-box {
            background: var(--white); border-radius: var(--radius-lg);
            padding: 2rem; max-width: 420px; width: 90%;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2); text-align: center;
        }
        .pc-modal-icon {
            width: 58px; height: 58px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 1rem; font-size: 1.5rem;
        }
        .pc-modal-title {
            font-size: 1.1rem; font-weight: 700;
            color: var(--text); margin-bottom: .5rem;
        }
        .pc-modal-body {
            font-size: 13px; color: var(--text-mid);
            margin-bottom: 1.5rem; line-height: 1.6;
        }
        .pc-modal-btns {
            display: flex; gap: 10px; justify-content: center;
        }
        .pc-modal-cancel {
            padding: 9px 22px; border-radius: 50px;
            font-size: 13px; font-weight: 600;
            border: 1.5px solid var(--border);
            background: var(--white); color: var(--text-mid);
            cursor: pointer; font-family: 'Poppins', sans-serif;
            transition: all .2s;
        }
        .pc-modal-cancel:hover {
            background: var(--border);
        }
        .pc-modal-confirm-blue {
            padding: 9px 22px; border-radius: 50px;
            font-size: 13px; font-weight: 700;
            background: linear-gradient(135deg, var(--blue), var(--blue-dark));
            color: #fff; border: none;
            cursor: pointer; font-family: 'Poppins', sans-serif;
            transition: all .2s;
            display: inline-flex; align-items: center; gap: 6px;
        }
        .pc-modal-confirm-blue:hover {
            opacity: .9; transform: translateY(-1px);
        }
    </style>
}

<div class="page-hero">
    <h1>Checkout</h1>
    <p>Fill in your delivery details</p>
</div>

<section class="checkout-section">
    <div class="checkout-inner">
        <div>
            <div class="checkout-form-wrap">
                <h2><i class="fa-solid fa-location-dot"></i> Delivery Information</h2>
                <form id="checkoutForm" method="post" action="@Url.Action("PlaceOrder","Cart")">
                    @Html.AntiForgeryToken()

                    @* Hidden inputs for selected items: PlaceOrder accepts arrays selectedId/selectedVariantLabel/selectedQty *@
                    @foreach (var item in Model)
                    {
                        <input type="hidden" name="selectedId" value="@item.Product.Id" />
                        <input type="hidden" name="selectedVariantLabel" value="@(item.SelectedVariant?.Label ?? "")" />
                        <input type="hidden" name="selectedQty" value="@item.Quantity" />
                    }

                    <div class="form-group">
                        <label><i class="fa-regular fa-user"></i> Full Name</label>
                        <input type="text" value="@Session["UserName"]" readonly class="readonly-input" />
                    </div>
                    <div class="form-group">
                        <label><i class="fa-regular fa-envelope"></i> Email</label>
                        <input type="email" value="@Session["UserEmail"]" readonly class="readonly-input" />
                    </div>
                    <div class="form-group">
                        <label><i class="fa-solid fa-phone"></i> Phone Number <span class="required">*</span></label>
                        <input type="tel" name="phone" placeholder="e.g. 09171234567" required 
                               inputmode="numeric" pattern="[0-9]{1,11}" maxlength="11"
                               onkeypress="return /[0-9]/.test(String.fromCharCode(event.which))"
                               title="Phone number must contain only numbers (max 11 digits)" />
                    </div>
                    <div class="form-group">
                        <label><i class="fa-solid fa-location-dot"></i> Delivery Address <span class="required">*</span></label>
                        <textarea name="address" rows="3" placeholder="House No., Street, Barangay, City, Province, ZIP" required></textarea>
                    </div>

                    <h2 style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--border);">
                        <i class="fa-solid fa-credit-card"></i> Payment Method
                    </h2>
                    <div class="payment-options">
                        <label class="payment-opt active">
                            <input type="radio" name="payment" value="COD" checked />
                            <i class="fa-solid fa-money-bill-wave"></i>
                            <span>Cash on Delivery</span>
                        </label>
                        <label class="payment-opt disabled" title="Coming soon">
                            <input type="radio" name="payment" value="GCash" disabled />
                            <i class="fa-solid fa-mobile-screen"></i>
                            <span>GCash <small>(Coming Soon)</small></span>
                        </label>
                    </div>

                    <button type="button" class="btn-primary place-order-btn" onclick="openConfirmModal(event)">
                        <i class="fa-solid fa-circle-check"></i> Place Order
                    </button>
                </form>
            </div>
        </div>

        <div class="checkout-summary">
            <h2><i class="fa-solid fa-receipt" style="color:var(--blue);"></i> Order Summary</h2>
            <div class="checkout-items">
                @foreach (var item in Model)
                {
                    <div class="checkout-item">
                        <div class="co-img">
                            @{ var coImg = (item.SelectedVariant != null && !string.IsNullOrEmpty(item.SelectedVariant.ImageUrl)) ? item.SelectedVariant.ImageUrl : item.Product.ImageUrl; }
                            <img src="@coImg" alt="@item.Product.Name" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                            <div class="img-fallback-sm" style="display:none;"><i class="fa-solid fa-bone"></i></div>
                            <span class="co-qty">@item.Quantity</span>
                        </div>
                        <div class="co-name">
                            @item.Product.Name
                            @if (item.SelectedVariant != null)
                            {
                                <span style="font-size:11px; color:var(--text-light); display:block;">@item.SelectedVariant.Label</span>
                            }
                        </div>
                        <div class="co-price">&#8369;@item.Subtotal.ToString("N2")</div>
                    </div>
                }
            </div>
            <div class="co-summary-row"><span>Subtotal</span><span>&#8369;@subtotal.ToString("N2")</span></div>
            <div class="co-summary-row">
                <span>Shipping</span>
                @if (shipping == 0)
                {<span class="free-ship"><i class="fa-solid fa-truck"></i> FREE</span>}
                else
                {<span>&#8369;80.00</span>}
            </div>
            <div class="co-summary-total"><span>Total</span><span>&#8369;@total.ToString("N2")</span></div>
        </div>
    </div>
</section>

<!-- ?? CHECKOUT CONFIRMATION MODAL ?? -->
<div id="confirmOrderModal" class="pc-modal-overlay">
    <div class="pc-modal-box">
        <div class="pc-modal-icon" style="background:rgba(129,166,198,.12);">
            <i class="fa-solid fa-circle-check" style="color:var(--blue);"></i>
        </div>
        <div class="pc-modal-title">Confirm Order?</div>
        <div class="pc-modal-body">Are you sure you want to place this order? Please review your delivery details and payment method before confirming.</div>
        <div class="pc-modal-btns">
            <button class="pc-modal-cancel" onclick="closeConfirmModal()">Cancel</button>
            <button class="pc-modal-confirm-blue" onclick="submitCheckoutForm()">
               Confirm
            </button>
        </div>
    </div>
</div>

@section scripts {
    <script src="@Url.Content("~/Scripts/cart.js")"></script>
    <script>
        function openConfirmModal(event) {
            event.preventDefault();
            // Validate form before showing modal
            var form = document.getElementById('checkoutForm');
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }
            document.getElementById('confirmOrderModal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function closeConfirmModal() {
            document.getElementById('confirmOrderModal').style.display = 'none';
            document.body.style.overflow = '';
        }

        function submitCheckoutForm() {
            var form = document.getElementById('checkoutForm');
            form.submit();
        }

        // Close modal when clicking outside
        document.getElementById('confirmOrderModal').addEventListener('click', function(e) {
            if (e.target === this) closeConfirmModal();
        });

        // Close modal with Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeConfirmModal();
        });
    </script>
}
